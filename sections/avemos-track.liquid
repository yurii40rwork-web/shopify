{{ 'avemos-style.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

{%- assign logo_height = settings.track123_logo_height | default: 50 -%}

{%- assign bg_size = settings.track123_bg_size -%}
{%- if bg_size == 'custom' -%}
  {%- assign bg_size = settings.track123_bg_size_custom | default: 'cover' -%}
{%- endif -%}

<style>
  /* Page background style override */
  .Avemos-landing-wrapper {
    {%- if settings.track123_bg_image != blank -%}
      background-image: url('{{ settings.track123_bg_image | image_url: width: 2000 }}') !important;
      background-size: {{ bg_size }} !important;
      background-position: {{ settings.track123_bg_position }} !important;
      background-repeat: no-repeat !important;
    {%- endif -%}
    {%- if settings.track123_bg_color != blank and settings.track123_bg_color != 'rgba(0,0,0,0)' and settings.track123_bg_color != 'transparent' -%}
      background-color: {{ settings.track123_bg_color }} !important;
    {%- endif -%}
  }

  /* Target the widget container to change or hide the background image */
  #track123-tracking-page,
  .track123_tracking_page_container,
  .track123_form_wrapper,
  .track123_track_content,
  .tracking-page-container {
    {%- if settings.track123_bg_hide_image -%}
      background-image: none !important;
    {%- elsif settings.track123_bg_image != blank -%}
      background-image: url('{{ settings.track123_bg_image | image_url: width: 2000 }}') !important;
    {%- endif -%}

    {%- if bg_size != blank -%}
      background-size: {{ bg_size }} !important;
    {%- endif -%}
    {%- if settings.track123_bg_position != blank -%}
      background-position: {{ settings.track123_bg_position }} !important;
    {%- endif -%}
  }
</style>

<div class="Avemos-landing-wrapper">
  <!-- Announcement Bar -->
  <div class="announcement-bar">
    <span>{{ settings.track123_announcement_1 }}</span>
    <span class="highlight">{{ settings.track123_announcement_2 }}</span>
  </div>

  <!-- Header -->
  <header class="header">
    <div class="container header-container">
      <!-- Hamburger Menu Button -->
      <button type="button" class="mobile-menu-btn" id="openDrawerBtn" aria-label="Open Menu">
        <i class="fa-solid fa-bars"></i>
      </button>

      <!-- Logo -->
      <a href="/" class="logo">
        {%- if settings.track123_logo != blank -%}
          <img src="{{ settings.track123_logo | image_url: width: 300 }}" alt="{{ settings.track123_logo.alt }}" height="{{ logo_height }}" style="height: {{ logo_height }}px; width: auto; vertical-align: middle;">
        {%- else -%}
          <img src="{{ 'logo-color.png' | asset_url }}" alt="Avemos Logo" height="{{ logo_height }}" style="height: {{ logo_height }}px; width: auto; vertical-align: middle;">
        {%- endif -%}
      </a>
      
      <!-- Navigation Menu -->
      <nav class="header-nav">
        {%- if settings.track123_menu != blank -%}
          {%- for link in settings.track123_menu.links -%}
            <a href="{{ link.url }}" class="header-nav-link">{{ link.title }}</a>
          {%- endfor -%}
        {%- else -%}
          <a href="/" class="header-nav-link">Home</a>
          <a href="/#reviews" class="header-nav-link">Reviews</a>
          <a href="/pages/about-us" class="header-nav-link">About Us</a>
          <a href="/pages/contact-us" class="header-nav-link">Contact Us</a>
          <a href="/apps/track123" class="header-nav-link">Track Order</a>
        {%- endif -%}
      </nav>

      <!-- Cart Button -->
      <a href="/cart" class="cart-icon-btn" aria-label="Open Cart">
        <i class="fa-solid fa-bag-shopping"></i>
        <span class="cart-badge" id="cart-count">{{ cart.item_count }}</span>
      </a>
    </div>
  </header>

  <!-- Mobile Navigation Drawer Overlay -->
  <div class="mobile-nav-drawer" id="mobileNavDrawer">
    <!-- Announcement Bar inside Drawer -->
    <div class="announcement-bar">
      <span>{{ settings.track123_mobile_announcement }}</span>
    </div>
    
    <div class="drawer-header">
      <!-- Close Button -->
      <button type="button" class="mobile-menu-close-btn" id="closeDrawerBtn" aria-label="Close Menu">
        <i class="fa-solid fa-xmark"></i>
      </button>
      
      <!-- Logo in Drawer -->
      <a href="/" class="logo drawer-logo">
        {%- if settings.track123_logo != blank -%}
          <img src="{{ settings.track123_logo | image_url: width: 300 }}" alt="{{ settings.track123_logo.alt | default: 'Avemos Logo' }}" height="{{ logo_height }}" style="height: {{ logo_height }}px; width: auto; vertical-align: middle;">
        {%- else -%}
          <img src="{{ 'logo-color.png' | asset_url }}" alt="Avemos Logo" height="{{ logo_height }}" style="height: {{ logo_height }}px; width: auto; vertical-align: middle;">
        {%- endif -%}
      </a>
      
      <!-- Cart in Drawer -->
      <a href="/cart" class="cart-icon-btn drawer-cart" aria-label="Open Cart">
        <i class="fa-solid fa-bag-shopping"></i>
        <span class="cart-badge" id="drawer-cart-count">{{ cart.item_count }}</span>
      </a>
    </div>
    
    <!-- Drawer Links -->
    <nav class="drawer-nav">
      {%- if settings.track123_menu != blank -%}
        {%- for link in settings.track123_menu.links -%}
          <a href="{{ link.url }}" class="drawer-nav-link">{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        <a href="/" class="drawer-nav-link">Home</a>
        <a href="/#reviews" class="drawer-nav-link">Reviews</a>
        <a href="/pages/about-us" class="drawer-nav-link">About Us</a>
        <a href="/pages/contact-us" class="drawer-nav-link">Contact Us</a>
        <a href="/apps/track123" class="drawer-nav-link">Track Order</a>
      {%- endif -%}
    </nav>
  </div>

  {%- if settings.track123_title != blank or settings.track123_subtitle != blank -%}
    <div style="background-color: var(--bg-secondary); padding: {{ settings.track123_padding_top }}px 0 0 0; text-align: center;">
      <div class="container" style="max-width: 800px;">
        {%- if settings.track123_title != blank -%}
          <h1 style="font-size: 2.5rem; font-weight: 800; margin-bottom: 12px; color: var(--text-primary);">{{ settings.track123_title }}</h1>
        {%- endif -%}
        {%- if settings.track123_subtitle != blank -%}
          <p style="color: var(--text-secondary); font-size: 1.1rem; max-width: 600px; margin: 0 auto; line-height: 1.5;">{{ settings.track123_subtitle }}</p>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const openBtn = document.getElementById('openDrawerBtn');
    const closeBtn = document.getElementById('closeDrawerBtn');
    const drawer = document.getElementById('mobileNavDrawer');
    
    if (openBtn && closeBtn && drawer) {
      openBtn.addEventListener('click', (e) => {
        e.preventDefault();
        drawer.classList.add('active');
        document.body.style.overflow = 'hidden';
      });
      
      closeBtn.addEventListener('click', (e) => {
        e.preventDefault();
        drawer.classList.remove('active');
        document.body.style.overflow = '';
      });
      
      const drawerLinks = drawer.querySelectorAll('.drawer-nav-link');
      drawerLinks.forEach(link => {
        link.addEventListener('click', () => {
          drawer.classList.remove('active');
          document.body.style.overflow = '';
        });
      });
    }
  });
</script>

{% schema %}
{
  "name": "Track123 Customizer",
  "settings": []
}
{% endschema %}

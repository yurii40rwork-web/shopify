{% comment %}
  This section is used in the page template to render store pages like About us
  or Contact us.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/page
{% endcomment %}

{{ 'avemos-style.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <div class="avemos-landing-wrapper">
    <!-- Announcement Bar -->
    <div class="announcement-bar">
      <span>🔥 SPECIAL DEAL: 50% OFF TODAY ONLY!</span>
      <span class="highlight">Free Express Shipping    </span>
    </div>

    <!-- Header -->
    <header class="header">
      <div class="container">
        <a href="/" class="logo">
          <img src="{{ 'logo-color.png' | asset_url }}" alt="Avemos Logo" width="120" height="36" style="height: 36px; width: auto; vertical-align: middle;">
        </a>
        
        <!-- Navigation Menu -->
        <nav class="header-nav">
          <a href="/" class="header-nav-link">Home</a>
          <a href="/pages/about-us" class="header-nav-link">About Us</a>
          <a href="/pages/contact-us" class="header-nav-link">Contact Us</a>
        </nav>
      </div>
    </header>

    <div style="background-color: var(--bg-secondary); padding: 60px 0; min-height: 50vh;">
      <div class="container" style="max-width: 800px;">
        <h1 style="font-size: 2.5rem; font-weight: 800; text-align: center; margin-bottom: 36px;">{{ page.title }}</h1>
        <div class="styled-page-content">
          {{ page.content }}
        </div>
      </div>
    </div>


  </div>

{% schema %}
{
  "name": "t:general.page",
  "settings": []
}
{% endschema %}

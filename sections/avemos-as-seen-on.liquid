{{ 'avemos-style.css' | asset_url | stylesheet_tag }}

{%- style -%}
  {% if section.settings.section_font != blank %}
    {{ section.settings.section_font | font_face: font_display: 'swap' }}
  {% endif %}

  #shopify-section-{{ section.id }} {
    {% if section.settings.section_bg_color != blank %}
      --bg-primary: {{ section.settings.section_bg_color }} !important;
      --bg-secondary: {{ section.settings.section_bg_color }} !important;
      --surface-container-low: {{ section.settings.section_bg_color }} !important;
      --surface-container: {{ section.settings.section_bg_color }} !important;
      background-color: {{ section.settings.section_bg_color }} !important;
    {% endif %}
    {% if section.settings.section_text_color != blank %}
      --text-primary: {{ section.settings.section_text_color }} !important;
      --text-secondary: {{ section.settings.section_text_color }} !important;
      --text-light: {{ section.settings.section_text_color }} !important;
      color: {{ section.settings.section_text_color }} !important;
    {% endif %}
    {% if section.settings.section_font != blank %}
      --font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
      --font-heading: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
      --font-body: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
      font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
    {% endif %}
  }

  #as-seen-on-{{ section.id }} {
    --brand-speed: {{ section.settings.brand_speed }}s;
    --wave-amplitude: {{ section.settings.wave_amplitude }}px;
    --wave-1-speed: {{ section.settings.wave_speed }}s;
    --wave-2-speed: {{ section.settings.wave_2_speed }}s;
    --wave-color: {{ section.settings.wave_color }};
    --wave-opacity: {{ section.settings.wave_opacity | divided_by: 100.0 }};
  }
{%- endstyle -%}

<div class="Avemos-landing-wrapper">
  <!-- As Seen On Banner -->
  <section class="as-seen-on" id="as-seen-on-{{ section.id }}">
    {%- capture logo_items -%}
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="brand-logo-placeholder" {{ block.shopify_attributes }}>
            {%- if block.settings.logo_image != blank -%}
              <img src="{{ block.settings.logo_image | image_url: width: 200 }}" alt="{{ block.settings.name | escape }}">
            {%- else -%}
              {{ block.settings.name }}
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="brand-logo-placeholder">Forbes</div>
        <div class="brand-logo-placeholder">Travel + Leisure</div>
        <div class="brand-logo-placeholder">NY Times</div>
        <div class="brand-logo-placeholder">USA Today</div>
        <div class="brand-logo-placeholder">Bloomberg</div>
      {%- endif -%}
    {%- endcapture -%}

    <div class="brand-logos-container">
      <div class="brand-logos-inner">
        {%- for i in (1..4) -%}
          <div class="brand-logos-group" {% if i > 1 %}aria-hidden="true"{% endif %}>
            {{ logo_items }}
            {{ logo_items }}
            {{ logo_items }}
          </div>
        {%- endfor -%}
      </div>
    </div>
    {%- if section.settings.show_waves -%}
      <div class="as-seen-on-waves">
        <svg class="wave-svg wave-svg-1" viewBox="0 0 1440 120" preserveAspectRatio="none">
          <path d="M 0,60 Q 180,20 360,60 T 720,60 Q 900,20 1080,60 T 1440,60 L 1440,120 L 0,120 Z"></path>
        </svg>
        <svg class="wave-svg wave-svg-2" viewBox="0 0 1440 120" preserveAspectRatio="none">
          <path d="M 0,80 Q 180,110 360,80 T 720,80 Q 900,110 1080,80 T 1440,80 L 1440,120 L 0,120 Z"></path>
        </svg>
      </div>
    {%- endif -%}
  </section>
</div>

{% schema %}
{
  "name": "Avemos As Seen On",
  "settings": [
    {
      "type": "header",
      "content": "Brand Movement"
    },
    {
      "type": "range",
      "id": "brand_speed",
      "min": 5,
      "max": 60,
      "step": 1,
      "unit": "s",
      "label": "Brand Movement Speed",
      "default": 20
    },
    {
      "type": "header",
      "content": "Wave Background"
    },
    {
      "type": "checkbox",
      "id": "show_waves",
      "label": "Show Background Waves",
      "default": true
    },
    {
      "type": "range",
      "id": "wave_amplitude",
      "min": 10,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Wave Amplitude (Height)",
      "default": 60
    },
    {
      "type": "range",
      "id": "wave_speed",
      "min": 2,
      "max": 30,
      "step": 1,
      "unit": "s",
      "label": "Wave 1 Speed",
      "default": 12
    },
    {
      "type": "range",
      "id": "wave_2_speed",
      "min": 2,
      "max": 30,
      "step": 1,
      "unit": "s",
      "label": "Wave 2 Speed",
      "default": 8
    },
    {
      "type": "color",
      "id": "wave_color",
      "label": "Wave Color",
      "default": "#d5e3fc"
    },
    {
      "type": "range",
      "id": "wave_opacity",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Wave Opacity",
      "default": 50
    },
    {
      "type": "header",
      "content": "Section Customization"
    },
    {
      "type": "font_picker",
      "id": "section_font",
      "label": "Section Font",
      "default": "work_sans_n4"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background Color"
    },
    {
      "type": "color",
      "id": "section_text_color",
      "label": "Section Text Color"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Brand Name",
          "default": "Brand"
        },
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "Brand Logo (Image)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Avemos As Seen On",
      "blocks": [
        { "type": "brand", "settings": { "name": "Forbes" } },
        { "type": "brand", "settings": { "name": "Travel + Leisure" } },
        { "type": "brand", "settings": { "name": "NY Times" } },
        { "type": "brand", "settings": { "name": "USA Today" } },
        { "type": "brand", "settings": { "name": "Bloomberg" } }
      ]
    }
  ]
}
{% endschema %}

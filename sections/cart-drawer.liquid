<!-- Cart Drawer Section -->
<div id="cart-drawer" class="cart-drawer-container" aria-hidden="true" 
     data-enable-bogo="{{ settings.enable_bogo | default: false }}"
     data-shipping-threshold="{{ section.settings.free_shipping_threshold | default: 50 }}"
     data-protection-price="{{ section.settings.shipping_protection_price | default: 5.00 }}"
     data-save-percent="{{ section.settings.save_percent | default: 57 }}"
     data-pillow-qty1-price="{{ section.settings.pillow_qty1_price | default: 39.00 }}"
     data-pillow-qty1-original="{{ section.settings.pillow_qty1_original | default: 78.00 }}"
     data-pillow-qty2-price="{{ section.settings.pillow_qty2_price | default: 19.50 }}"
     data-pillow-qty2-info="{{ section.settings.pillow_qty2_info | default: '($19.50 each)' | escape }}"
     data-pillow-qty3-price="{{ section.settings.pillow_qty3_price | default: 26.00 }}"
     data-pillow-qty3-info="{{ section.settings.pillow_qty3_info | default: '($26.00 each)' | escape }}"
     data-pillow-qty4-price="{{ section.settings.pillow_qty4_price | default: 17.00 }}"
     data-pillow-qty4-info="{{ section.settings.pillow_qty4_info | default: '($17.00 each)' | escape }}">
  <div class="cart-drawer-overlay" id="cart-drawer-overlay"></div>
  
  <div class="cart-drawer-panel">
    <!-- Header -->
    <div class="cart-drawer-header">
      <h2 class="cart-drawer-title">{{ section.settings.cart_title | escape }}</h2>
      <button type="button" class="cart-drawer-close-btn" id="cart-drawer-close-btn" aria-label="Close Cart">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    
    <!-- Free Shipping Progress Section -->
    <div class="shipping-progress-container" id="shipping-progress-container">
      <div class="shipping-progress-text" id="shipping-progress-text">
        Congrats! You've unlocked <strong>FREE SHIPPING!</strong>
      </div>
      <div class="shipping-progress-bar-wrapper">
        <div class="shipping-progress-bar" id="shipping-progress-bar"></div>
        <div class="shipping-truck-icon" id="shipping-truck-icon">
          <i class="fa-solid fa-truck-fast"></i>
        </div>
      </div>
    </div>
    
    <!-- Cart Items Scroll Area -->
    <div class="cart-drawer-body">
      <!-- Empty State -->
      <div class="cart-drawer-empty" id="cart-drawer-empty">
        <i class="fa-solid fa-bag-shopping empty-icon"></i>
        <p class="empty-text">Your cart is empty</p>
        <button type="button" class="cart-drawer-continue-btn" id="cart-drawer-continue-btn">Continue Shopping</button>
      </div>
      
      <!-- Items List -->
      <div class="cart-drawer-items-list" id="cart-drawer-items-list">
        <!-- Rendered dynamically -->
      </div>
    </div>
    
    <!-- Footer Section (Fixed at bottom) -->
    <div class="cart-drawer-footer" id="cart-drawer-footer">
      <!-- Shipping Protection -->
      {%- if section.settings.show_shipping_protection -%}
        <div class="shipping-protection-row">
          <div class="protection-icon-details">
            <div class="protection-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.upsell_border_color }}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                <polyline points="9 11 11 13 15 9"></polyline>
              </svg>
            </div>
            <div class="protection-text">
              <div class="protection-title">{{ section.settings.shipping_protection_title | escape }}</div>
              <div class="protection-subtitle">{{ section.settings.shipping_protection_subtitle | escape }}</div>
            </div>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" id="shipping-protection-toggle" checked>
            <span class="slider"></span>
          </label>
        </div>
      {%- endif -%}
      
      <!-- Subtotal -->
      <div class="cart-drawer-subtotal-row">
        <span class="subtotal-label">Subtotal</span>
        <div class="subtotal-prices">
          <span class="subtotal-current" id="drawer-subtotal-current">$0.00</span>
          <span class="subtotal-original" id="drawer-subtotal-original">$0.00</span>
          <span class="subtotal-badge" id="drawer-subtotal-save">Save {{ section.settings.save_percent }}%</span>
        </div>
      </div>
      
      <!-- Checkout Button -->
      <button type="button" class="drawer-checkout-btn" id="drawer-checkout-btn">
        GO TO CHECKOUT
      </button>
      
      <!-- Trust Note & Badges -->
      <div class="drawer-trust-section">
        <div class="trust-guarantee-text">{{ section.settings.trust_guarantee_text | escape }}</div>
        <div class="drawer-payment-badges">
          <!-- Premium styled payment icons -->
          <div class="fallback-payment-badges">
            <span class="payment-badge shop-pay">Shop Pay</span>
            <span class="payment-badge paypal">PayPal</span>
            <span class="payment-badge gpay">G Pay</span>
            <span class="payment-badge visa">Visa</span>
            <span class="payment-badge mastercard">Mastercard</span>
            <span class="payment-badge amex">Amex</span>
            <span class="payment-badge discover">Discover</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>


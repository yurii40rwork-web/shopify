<script>
document.addEventListener('DOMContentLoaded', () => {
  const drawer = document.getElementById('cart-drawer');
  if (!drawer) return;

  const overlay = document.getElementById('cart-drawer-overlay');
  const closeBtn = document.getElementById('cart-drawer-close-btn');
  const continueBtn = document.getElementById('cart-drawer-continue-btn');
  const itemsList = document.getElementById('cart-drawer-items-list');
  const emptyState = document.getElementById('cart-drawer-empty');
  const cartFooter = document.getElementById('cart-drawer-footer');
  
  const subtotalCurrent = document.getElementById('drawer-subtotal-current');
  const subtotalOriginal = document.getElementById('drawer-subtotal-original');
  const subtotalSave = document.getElementById('drawer-subtotal-save');
  
  const progressBar = document.getElementById('shipping-progress-bar');
  const progressText = document.getElementById('shipping-progress-text');
  const truckIcon = document.getElementById('shipping-truck-icon');
  
  const protectionToggle = document.getElementById('shipping-protection-toggle');
  const checkoutBtn = document.getElementById('drawer-checkout-btn');

  let currentCart = null;
  let debounceTimer = null;
  let pendingUpdates = {};

  // Load configs from dataset attributes (from shopify schema)
  const shippingThreshold = parseFloat(drawer.dataset.shippingThreshold || 50) * 100; // in cents
  const protectionPrice = parseFloat(drawer.dataset.protectionPrice || 5.00) * 100; // in cents
  const savePercentVal = parseInt(drawer.dataset.savePercent || 57);
  const bogoEnabled = drawer.dataset.enableBogo === 'true';
  
  const pillowQty1Price = parseFloat(drawer.dataset.pillowQty1Price || 39.00) * 100;
  const pillowQty1Original = parseFloat(drawer.dataset.pillowQty1Original || 78.00) * 100;
  const pillowQty2Price = parseFloat(drawer.dataset.pillowQty2Price || 19.50) * 100;
  const pillowQty2Info = drawer.dataset.pillowQty2Info || '($19.50 each)';
  const pillowQty3Price = parseFloat(drawer.dataset.pillowQty3Price || 26.00) * 100;
  const pillowQty3Info = drawer.dataset.pillowQty3Info || '($26.00 each)';
  const pillowQty4Price = parseFloat(drawer.dataset.pillowQty4Price || 17.00) * 100;
  const pillowQty4Info = drawer.dataset.pillowQty4Info || '($17.00 each)';

  // Toggle open class
  function openCartDrawer() {
    const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;
    if (scrollbarWidth > 0) {
      document.body.style.paddingRight = `${scrollbarWidth}px`;
    }
    drawer.classList.add('active');
    document.body.classList.add('cart-drawer-open');
    drawer.setAttribute('aria-hidden', 'false');
    fetchAndRenderCart();
  }

  function closeCartDrawer() {
    drawer.classList.remove('active');
    document.body.classList.remove('cart-drawer-open');
    document.body.style.paddingRight = '';
    drawer.setAttribute('aria-hidden', 'true');
  }

  if (closeBtn) closeBtn.addEventListener('click', closeCartDrawer);
  if (overlay) overlay.addEventListener('click', closeCartDrawer);
  if (continueBtn) continueBtn.addEventListener('click', closeCartDrawer);

  // Hook into any click to cart links/icons
  function hookCartButtons() {
    const cartButtons = document.querySelectorAll('a[href="/cart"], a[href="{{ routes.cart_url }}"], .cart-icon-btn');
    cartButtons.forEach(btn => {
      // Clone to remove previous event listeners if any
      const newBtn = btn.cloneNode(true);
      btn.parentNode.replaceChild(newBtn, btn);
      newBtn.addEventListener('click', (e) => {
        e.preventDefault();
        openCartDrawer();
      });
    });
  }

  let protectionVariantId = null;

  async function fetchProtectionVariantId() {
    try {
      const res = await fetch('/products/shipping-protection.js');
      if (res.ok) {
        const product = await res.json();
        if (product.variants && product.variants.length > 0) {
          protectionVariantId = product.variants[0].id;
        }
      }
    } catch (err) {
      console.error('Error fetching protection variant:', err);
    }
  }

  // Fetch variant ID immediately on load
  fetchProtectionVariantId();

  async function addProtectionToCart() {
    if (!protectionVariantId) {
      await fetchProtectionVariantId();
    }
    if (!protectionVariantId) return;
    
    drawer.querySelector('.cart-drawer-panel').classList.add('loading-active');
    try {
      const response = await fetch('/cart/update.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({
          updates: {
            [protectionVariantId.toString()]: 1
          }
        })
      });
      const cart = await response.json();
      currentCart = cart;
      renderCart(cart);
    } catch (err) {
      console.error('Error adding shipping protection:', err);
    } finally {
      drawer.querySelector('.cart-drawer-panel').classList.remove('loading-active');
    }
  }

  async function removeProtectionFromCart() {
    if (!protectionVariantId) {
      await fetchProtectionVariantId();
    }
    if (!protectionVariantId) return;

    drawer.querySelector('.cart-drawer-panel').classList.add('loading-active');
    try {
      const response = await fetch('/cart/update.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({
          updates: {
            [protectionVariantId.toString()]: 0
          }
        })
      });
      const cart = await response.json();
      currentCart = cart;
      renderCart(cart);
    } catch (err) {
      console.error('Error removing shipping protection:', err);
    } finally {
      drawer.querySelector('.cart-drawer-panel').classList.remove('loading-active');
    }
  }

  // Fetch cart details from Shopify API and render
  async function fetchAndRenderCart() {
    try {
      const response = await fetch('/cart.js');
      const cart = await response.json();
      currentCart = cart;
      renderCart(cart);
    } catch (error) {
      console.error('Error fetching cart:', error);
    }
  }

  // Render cart items
  function renderCart(cart) {
    currentCart = cart;
    const bodyEl = drawer.querySelector('.cart-drawer-body');
    const scrollTop = bodyEl ? bodyEl.scrollTop : 0;
    
    itemsList.innerHTML = '';
    
    let totalPillowsQty = 0;
    let basePricesSubtotal = 0;
    let originalPricesSubtotal = 0;
    let hasProtectionInCart = false;
    let itemCountExcludingProtection = 0;

    cart.items.forEach(item => {
      const isProtection = item.handle === 'shipping-protection' || item.product_title.toLowerCase().includes('shipping protection');
      if (isProtection) {
        hasProtectionInCart = true;
      } else {
        itemCountExcludingProtection += item.quantity;
        const isPillow = item.product_title.toLowerCase().includes('pillow');
        if (isPillow) {
          totalPillowsQty += item.quantity;
        }
      }
    });

    // Update global cart counts
    const countElements = document.querySelectorAll('#cart-count, #drawer-cart-count');
    countElements.forEach(el => {
      el.textContent = itemCountExcludingProtection;
      el.style.display = itemCountExcludingProtection > 0 ? 'flex' : 'none';
    });

    if (itemCountExcludingProtection === 0) {
      emptyState.style.display = 'flex';
      cartFooter.style.display = 'none';
      progressBar.parentElement.parentElement.style.display = 'none';
      
      // Auto remove protection if it's the only thing left
      if (hasProtectionInCart) {
        removeProtectionFromCart();
      }
      return;
    }

    emptyState.style.display = 'none';
    cartFooter.style.display = 'block';
    progressBar.parentElement.parentElement.style.display = 'block';

    // Auto add protection if cart is not empty, it's not in the cart, and user hasn't explicitly opted out
    if (!hasProtectionInCart && localStorage.getItem('shipping_protection_opt_out') !== 'true') {
      addProtectionToCart();
      return;
    }

    // Sync toggle switch state with cart
    if (protectionToggle) {
      protectionToggle.checked = hasProtectionInCart;
    }

    function getPillowUnitPriceCents(totalQty) {
      if (totalQty === 1) return pillowQty1Price;
      if (totalQty === 2) return pillowQty2Price;
      if (totalQty === 3) return pillowQty3Price;
      return pillowQty4Price;
    }

    function getPillowOriginalUnitPriceCents(totalQty) {
      return pillowQty1Original;
    }

    function getPillowPricingInfo(totalQty, currentPricePerUnit) {
      if (totalQty === 2) return pillowQty2Info || `(${formatMoney(currentPricePerUnit)} each)`;
      if (totalQty === 3) return pillowQty3Info || `(${formatMoney(currentPricePerUnit)} each)`;
      if (totalQty >= 4) return pillowQty4Info || `(${formatMoney(currentPricePerUnit)} each)`;
      return '';
    }

    // Calculate BOGO details
    const lineItemDetails = {};
    if (bogoEnabled) {
      let units = [];
      cart.items.forEach(item => {
        const isProtection = item.handle === 'shipping-protection' || item.product_title.toLowerCase().includes('shipping protection');
        if (isProtection) return;

        const isPillow = item.product_title.toLowerCase().includes('pillow');
        const baseUnitPriceCents = item.price || pillowQty1Price;
        const currentPricePerUnit = isPillow ? getPillowUnitPriceCents(totalPillowsQty) : (item.final_price || item.price);
        const originalPricePerUnit = isPillow ? getPillowOriginalUnitPriceCents(totalPillowsQty) : (item.compare_at_price || item.original_price || (baseUnitPriceCents > pillowQty1Price ? baseUnitPriceCents : pillowQty1Original));

        for (let i = 0; i < item.quantity; i++) {
          units.push({
            key: item.key,
            currentPrice: currentPricePerUnit,
            originalPrice: originalPricePerUnit
          });
        }
      });

      // Sort descending by current price so BOGO discounts the cheaper items
      units.sort((a, b) => b.currentPrice - a.currentPrice);

      units.forEach((unit, idx) => {
        if (idx % 2 === 1) {
          unit.discountedPrice = 0; // FREE
        } else {
          unit.discountedPrice = unit.currentPrice;
        }
      });

      units.forEach(unit => {
        if (!lineItemDetails[unit.key]) {
          lineItemDetails[unit.key] = {
            key: unit.key,
            totalBogoPrice: 0,
            totalOriginalPrice: 0,
            qtyFree: 0,
            qtyPaid: 0
          };
        }
        lineItemDetails[unit.key].totalBogoPrice += unit.discountedPrice;
        lineItemDetails[unit.key].totalOriginalPrice += unit.originalPrice;
        if (unit.discountedPrice === 0) {
          lineItemDetails[unit.key].qtyFree++;
        } else {
          lineItemDetails[unit.key].qtyPaid++;
        }
      });
    }

    // Loop through and render actual cart items
    cart.items.forEach((item, index) => {
      const isProtection = item.handle === 'shipping-protection' || item.product_title.toLowerCase().includes('shipping protection');
      if (isProtection) return;

      const isPillow = item.product_title.toLowerCase().includes('pillow');
      const itemTitle = item.product_title;

      const itemElement = document.createElement('div');
      itemElement.className = 'cart-drawer-item';
      itemElement.dataset.key = item.key;

      // Dynamic prices with cumulative discount rule
      const baseUnitPriceCents = item.price || pillowQty1Price;
      const currentPricePerUnit = isPillow ? getPillowUnitPriceCents(totalPillowsQty) : (item.final_price || item.price);
      let originalPricePerUnit = isPillow ? getPillowOriginalUnitPriceCents(totalPillowsQty) : (item.compare_at_price || item.original_price || (baseUnitPriceCents > pillowQty1Price ? baseUnitPriceCents : pillowQty1Original));
      
      if (originalPricePerUnit <= currentPricePerUnit && !isPillow) {
        originalPricePerUnit = pillowQty1Original; // default compare at if missing
      }

      const hasBogoDetails = bogoEnabled && lineItemDetails[item.key];
      const totalBogoPrice = hasBogoDetails ? lineItemDetails[item.key].totalBogoPrice : (currentPricePerUnit * item.quantity);
      const totalOriginalPrice = hasBogoDetails ? lineItemDetails[item.key].totalOriginalPrice : (originalPricePerUnit * item.quantity);
      const qtyFree = hasBogoDetails ? lineItemDetails[item.key].qtyFree : 0;

      basePricesSubtotal += totalBogoPrice;
      originalPricesSubtotal += totalOriginalPrice;

      const currentLineFormatted = formatMoney(totalBogoPrice);
      const originalLineFormatted = formatMoney(totalOriginalPrice);

      let priceLabelHTML = `<span class="price-current">${currentLineFormatted}</span>`;
      if (qtyFree > 0) {
        priceLabelHTML += ` <span class="subtotal-badge" style="background:#2e6f40; margin-left:4px; font-size:10px; padding: 2px 6px; border-radius: 4px; color:#fff;">${qtyFree} FREE</span>`;
      }

      let originalPriceHTML = '';
      if (totalOriginalPrice > totalBogoPrice) {
        originalPriceHTML = `<span class="price-original">${originalLineFormatted}</span>`;
      } else if (originalPricePerUnit > currentPricePerUnit) {
        originalPriceHTML = `<span class="price-original">${originalLineFormatted}</span>`;
      }

      itemElement.innerHTML = `
        <div class="item-img-col">
          <img src="${item.image ? item.image : '//cdn.shopify.com/s/images/admin/no-image-large.gif'}" alt="${itemTitle}">
        </div>
        <div class="item-info-col">
          <a href="${item.url}" class="item-title">${itemTitle}</a>
          ${item.variant_title && !item.variant_title.includes('Default') ? `<div style="font-size: 12px; color: #75777d; margin-top: 1px;">${item.variant_title}</div>` : ''}
          <div class="item-qty-selector">
            <button type="button" class="item-qty-btn" data-action="minus" data-key="${item.key}">-</button>
            <input type="number" class="item-qty-input" value="${item.quantity}" readonly>
            <button type="button" class="item-qty-btn" data-action="plus" data-key="${item.key}">+</button>
          </div>
        </div>
        <div class="item-price-col">
          <button type="button" class="item-delete-btn" data-action="delete" data-key="${item.key}">
            <i class="fa-regular fa-trash-can"></i>
          </button>
          <div class="item-prices-box">
            ${priceLabelHTML}
            ${item.quantity > 1 ? `<span class="price-each" style="font-size: 11px; color: #75777d; margin-top: 1px; white-space: nowrap;">${isPillow ? getPillowPricingInfo(totalPillowsQty, currentPricePerUnit) : `(${formatMoney(currentPricePerUnit)} each)`}</span>` : ''}
            ${originalPriceHTML}
          </div>
        </div>
      `;

      itemsList.appendChild(itemElement);
    });

    // Shipping protection cost
    let protectionCost = 0;
    if (hasProtectionInCart) {
      protectionCost = protectionPrice; 
    }

    // Subtotal calculations
    const finalSubtotal = basePricesSubtotal + protectionCost;
    const finalOriginal = originalPricesSubtotal + protectionCost;
    const savePercent = finalOriginal > 0 ? Math.round((1 - (finalSubtotal / finalOriginal)) * 100) : savePercentVal;

    subtotalCurrent.textContent = formatMoney(finalSubtotal);
    subtotalOriginal.textContent = formatMoney(finalOriginal);
    subtotalSave.textContent = `Save ${savePercent}%`;

    // Free Shipping Progress calculation
    const baseSubtotalNoProtection = basePricesSubtotal; // exclude protection from threshold
    
    if (baseSubtotalNoProtection >= shippingThreshold) {
      progressBar.style.width = '100%';
      truckIcon.style.left = '100%';
      progressText.innerHTML = 'Congrats! You\'ve unlocked <strong>FREE SHIPPING!</strong>';
    } else {
      const percentage = (baseSubtotalNoProtection / shippingThreshold) * 100;
      progressBar.style.width = `${percentage}%`;
      truckIcon.style.left = `${percentage}%`;
      const difference = formatMoney(shippingThreshold - baseSubtotalNoProtection);
      progressText.innerHTML = `You are only <strong>${difference}</strong> away from <strong>FREE SHIPPING!</strong>`;
    }
    if (bodyEl && scrollTop > 0) {
      bodyEl.scrollTop = scrollTop;
    }
  }

  // Handle AJAX quantity updates with debounce and single batch request
  function queueQtyUpdate(key, newQty) {
    pendingUpdates[key] = newQty;
    
    if (debounceTimer) {
      clearTimeout(debounceTimer);
    }
    
    debounceTimer = setTimeout(async () => {
      drawer.querySelector('.cart-drawer-panel').classList.add('loading-active');
      const updatesToSend = { ...pendingUpdates };
      pendingUpdates = {}; // Clear immediately to capture any new inputs
      
      try {
        const response = await fetch('/cart/update.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ updates: updatesToSend })
        });
        const cart = await response.json();
        // Only update currentCart and re-render if the user has not queued newer changes
        if (Object.keys(pendingUpdates).length === 0) {
          currentCart = cart;
          renderCart(cart);
        }
      } catch (err) {
        console.error('Error changing qty:', err);
        // Fallback: fetch fresh cart
        await fetchAndRenderCart();
      } finally {
        // Only remove loading state if no pending updates are left
        if (Object.keys(pendingUpdates).length === 0) {
          drawer.querySelector('.cart-drawer-panel').classList.remove('loading-active');
        }
      }
    }, 350); // 350ms debounce window
  }

  // Listener for qty buttons click
  itemsList.addEventListener('click', (e) => {
    const btn = e.target.closest('.item-qty-btn, .item-delete-btn');
    if (!btn) return;

    const key = btn.dataset.key;
    const action = btn.dataset.action;
    const card = btn.closest('.cart-drawer-item');
    if (!card) return;

    const input = card.querySelector('.item-qty-input');
    const currentQty = input ? parseInt(input.value) : 1;
    let newQty = currentQty;

    if (action === 'plus') {
      newQty = currentQty + 1;
    } else if (action === 'minus') {
      newQty = Math.max(0, currentQty - 1);
    } else if (action === 'delete') {
      newQty = 0;
    }

    // Update input DOM element immediately for instant response
    if (input) {
      input.value = newQty;
    }

    // Optimistically update our local currentCart object and re-calculate
    if (currentCart && currentCart.items) {
      const itemIndex = currentCart.items.findIndex(item => item.key === key);
      if (itemIndex > -1) {
        if (newQty === 0) {
          currentCart.items.splice(itemIndex, 1);
        } else {
          currentCart.items[itemIndex].quantity = newQty;
        }
        // Re-render instantly based on optimistic data!
        renderCart(currentCart);
      }
    }

    queueQtyUpdate(key, newQty);
  });

  // Protection toggle click
  if (protectionToggle) {
    protectionToggle.addEventListener('change', () => {
      if (protectionToggle.checked) {
        localStorage.setItem('shipping_protection_opt_out', 'false');
        addProtectionToCart();
      } else {
        localStorage.setItem('shipping_protection_opt_out', 'true');
        removeProtectionFromCart();
      }
    });
  }

  // Checkout click with cumulative discount parameter
  if (checkoutBtn) {
    checkoutBtn.addEventListener('click', async (e) => {
      e.preventDefault();
      try {
        const res = await fetch('/cart.js');
        const cart = await res.json();
        let discountCode = '';
        if (bogoEnabled) {
          discountCode = 'BOGO';
        } else {
          let pillowQty = 0;
          cart.items.forEach(item => {
            if (item.product_title && item.product_title.toLowerCase().includes('pillow')) {
              pillowQty += item.quantity;
            }
          });
          
          if (pillowQty === 2) discountCode = 'PILLOWS2';
          else if (pillowQty === 3) discountCode = 'PILLOWS3';
          else if (pillowQty === 4) discountCode = 'PILLOWS4';
          else if (pillowQty === 5) discountCode = 'PILLOWS5';
          else if (pillowQty >= 6) discountCode = 'PILLOWS6';
        }

        if (discountCode) {
          window.location.href = `/discount/${discountCode}?redirect=/checkout`;
        } else {
          window.location.href = '/checkout';
        }
      } catch (err) {
        window.location.href = '/checkout';
      }
    });
  }

  // Money formatter helper
  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(2);
  }

  // Initial hook and global exposure
  hookCartButtons();
  window.openCartDrawer = openCartDrawer;
  window.fetchAndRenderCart = fetchAndRenderCart;

  // Intercept Shopify cart submit forms if any
  document.addEventListener('submit', (e) => {
    const form = e.target;
    if (form.action && form.action.includes('/cart/add')) {
      // If it's a product form add, let the product script handle it and then trigger drawer
    }
  });
});
</script>


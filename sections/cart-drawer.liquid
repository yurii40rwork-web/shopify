<script>
document.addEventListener('DOMContentLoaded', () => {
  const drawer = document.getElementById('cart-drawer');
  if (!drawer) return;

  const overlay = document.getElementById('cart-drawer-overlay');
  const closeBtn = document.getElementById('cart-drawer-close-btn');
  const continueBtn = document.getElementById('cart-drawer-continue-btn');
  const itemsList = document.getElementById('cart-drawer-items-list');
  const emptyState = document.getElementById('cart-drawer-empty');
  const cartFooter = document.getElementById('cart-drawer-footer');
  
  const subtotalCurrent = document.getElementById('drawer-subtotal-current');
  const subtotalOriginal = document.getElementById('drawer-subtotal-original');
  const subtotalSave = document.getElementById('drawer-subtotal-save');
  
  const progressBar = document.getElementById('shipping-progress-bar');
  const progressText = document.getElementById('shipping-progress-text');
  const truckIcon = document.getElementById('shipping-truck-icon');
  
  const protectionToggle = document.getElementById('shipping-protection-toggle');
  const checkoutBtn = document.getElementById('drawer-checkout-btn');

  // Load configs from dataset attributes (from shopify schema)
  const shippingThreshold = parseFloat(drawer.dataset.shippingThreshold || 50) * 100; // in cents
  const protectionPrice = parseFloat(drawer.dataset.protectionPrice || 5.00) * 100; // in cents
  const savePercentVal = parseInt(drawer.dataset.savePercent || 57);

  // Toggle open class
  function openCartDrawer() {
    drawer.classList.add('active');
    document.body.classList.add('cart-drawer-open');
    drawer.setAttribute('aria-hidden', 'false');
    fetchAndRenderCart();
  }

  function closeCartDrawer() {
    drawer.classList.remove('active');
    document.body.classList.remove('cart-drawer-open');
    drawer.setAttribute('aria-hidden', 'true');
  }

  if (closeBtn) closeBtn.addEventListener('click', closeCartDrawer);
  if (overlay) overlay.addEventListener('click', closeCartDrawer);
  if (continueBtn) continueBtn.addEventListener('click', closeCartDrawer);

  // Hook into any click to cart links/icons
  function hookCartButtons() {
    const cartButtons = document.querySelectorAll('a[href="/cart"], a[href="{{ routes.cart_url }}"], .cart-icon-btn');
    cartButtons.forEach(btn => {
      // Clone to remove previous event listeners if any
      const newBtn = btn.cloneNode(true);
      btn.parentNode.replaceChild(newBtn, btn);
      newBtn.addEventListener('click', (e) => {
        e.preventDefault();
        openCartDrawer();
      });
    });
  }

  // Fetch cart details from Shopify API and render
  async function fetchAndRenderCart() {
    try {
      const response = await fetch('/cart.js');
      const cart = await response.json();
      renderCart(cart);
    } catch (error) {
      console.error('Error fetching cart:', error);
    }
  }

  // Render cart items
  function renderCart(cart) {
    itemsList.innerHTML = '';
    
    // Update global cart counts
    const countElements = document.querySelectorAll('#cart-count, #drawer-cart-count');
    countElements.forEach(el => {
      el.textContent = cart.item_count;
      el.style.display = cart.item_count > 0 ? 'flex' : 'none';
    });

    if (cart.items.length === 0) {
      emptyState.style.display = 'flex';
      cartFooter.style.display = 'none';
      progressBar.parentElement.parentElement.style.display = 'none';
      return;
    }

    emptyState.style.display = 'none';
    cartFooter.style.display = 'block';
    progressBar.parentElement.parentElement.style.display = 'block';

    // Helper for cumulative discount calculation (13% off per extra pillow, min $20/ea)
    function getCumulativePillowUnitPriceCents(basePriceCents, totalQty) {
      if (totalQty <= 1) return basePriceCents;
      let baseDollars = basePriceCents / 100;
      let discountedDollars = Math.round(baseDollars * Math.pow(0.87, totalQty - 1));
      let finalDollars = Math.max(20, discountedDollars);
      return finalDollars * 100;
    }

    let totalPillowsQty = 0;
    let basePricesSubtotal = 0;
    let originalPricesSubtotal = 0;

    // Filter items and count pillow qty
    cart.items.forEach(item => {
      const isPillow = item.product_title.toLowerCase().includes('pillow');
      if (isPillow) {
        totalPillowsQty += item.quantity;
      }
    });

    let pillowsRenderedCount = 0;

    // Loop through and render actual cart items
    cart.items.forEach((item, index) => {
      const isPillow = item.product_title.toLowerCase().includes('pillow');
      const itemTitle = item.product_title;

      const itemElement = document.createElement('div');
      itemElement.className = 'cart-drawer-item';
      itemElement.dataset.key = item.key;

      // Dynamic prices with cumulative discount rule
      const baseUnitPriceCents = item.price || 3900;
      const currentPricePerUnit = isPillow ? getCumulativePillowUnitPriceCents(baseUnitPriceCents, totalPillowsQty) : (item.final_price || item.price);
      let originalPricePerUnit = item.compare_at_price || item.original_price || (baseUnitPriceCents > 3900 ? baseUnitPriceCents : 9000);
      
      if (originalPricePerUnit <= currentPricePerUnit) {
        originalPricePerUnit = 9000; // default $90 compare at if missing
      }

      // Cumulative discount tag
      let discountTag = '';
      if (item.line_level_discount_allocations && item.line_level_discount_allocations.length > 0) {
        discountTag = item.line_level_discount_allocations.map(d => d.discount_application.title).join(', ');
      } else if (item.discounts && item.discounts.length > 0) {
        discountTag = item.discounts.map(d => d.title).join(', ');
      } else if (isPillow && totalPillowsQty >= 2) {
        const unitDollars = currentPricePerUnit / 100;
        const totalPctOff = Math.round((1 - (unitDollars / (baseUnitPriceCents / 100))) * 100);
        discountTag = `Cumulative Discount: $${unitDollars}/ea (${totalPctOff}% OFF)`;
      }

      basePricesSubtotal += (currentPricePerUnit * item.quantity);
      originalPricesSubtotal += (originalPricePerUnit * item.quantity);

      const currentUnitFormatted = formatMoney(currentPricePerUnit);
      const originalUnitFormatted = formatMoney(originalPricePerUnit);

      itemElement.innerHTML = `
        <div class="item-img-col">
          <img src="${item.image ? item.image : '//cdn.shopify.com/s/images/admin/no-image-large.gif'}" alt="${itemTitle}">
        </div>
        <div class="item-info-col">
          <a href="${item.url}" class="item-title">${itemTitle}</a>
          ${item.variant_title && !item.variant_title.includes('Default') ? `<div style="font-size: 12px; color: #75777d; margin-top: 1px;">${item.variant_title}</div>` : ''}
          ${discountTag ? `<span class="item-tag">${discountTag}</span>` : ''}
          <div class="item-qty-selector">
            <button type="button" class="item-qty-btn" data-action="minus" data-key="${item.key}">-</button>
            <input type="number" class="item-qty-input" value="${item.quantity}" readonly>
            <button type="button" class="item-qty-btn" data-action="plus" data-key="${item.key}">+</button>
          </div>
        </div>
        <div class="item-price-col">
          <button type="button" class="item-delete-btn" data-action="delete" data-key="${item.key}">
            <i class="fa-regular fa-trash-can"></i>
          </button>
          <div class="item-prices-box">
            <span class="price-current">${currentUnitFormatted}</span>
            ${originalPricePerUnit > currentPricePerUnit ? `<span class="price-original">${originalUnitFormatted}</span>` : ''}
          </div>
        </div>
      `;

      itemsList.appendChild(itemElement);
    });

    // Shipping protection cost
    let protectionCost = 0;
    if (protectionToggle && protectionToggle.checked) {
      protectionCost = protectionPrice; 
    }

    // Subtotal calculations
    const finalSubtotal = basePricesSubtotal + protectionCost;
    const finalOriginal = originalPricesSubtotal + protectionCost;
    const savePercent = finalOriginal > 0 ? Math.round((1 - (finalSubtotal / finalOriginal)) * 100) : savePercentVal;

    subtotalCurrent.textContent = formatMoney(finalSubtotal);
    subtotalOriginal.textContent = formatMoney(finalOriginal);
    subtotalSave.textContent = `Save ${savePercent}%`;

    // Free Shipping Progress calculation
    const baseSubtotalNoProtection = basePricesSubtotal; // exclude protection from threshold
    
    if (baseSubtotalNoProtection >= shippingThreshold) {
      progressBar.style.width = '100%';
      truckIcon.style.left = '100%';
      progressText.innerHTML = 'Congrats! You\'ve unlocked <strong>FREE SHIPPING!</strong>';
    } else {
      const percentage = (baseSubtotalNoProtection / shippingThreshold) * 100;
      progressBar.style.width = `${percentage}%`;
      truckIcon.style.left = `${percentage}%`;
      const difference = formatMoney(shippingThreshold - baseSubtotalNoProtection);
      progressText.innerHTML = `You are only <strong>${difference}</strong> away from <strong>FREE SHIPPING!</strong>`;
    }
  }

  // Handle AJAX quantity updates
  async function updateQty(key, newQty) {
    drawer.querySelector('.cart-drawer-panel').classList.add('loading-active');
    try {
      const response = await fetch('/cart/change.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({ id: key, quantity: newQty })
      });
      const cart = await response.json();
      renderCart(cart);
    } catch (err) {
      console.error('Error changing qty:', err);
    } finally {
      drawer.querySelector('.cart-drawer-panel').classList.remove('loading-active');
    }
  }

  // Listener for qty buttons click
  itemsList.addEventListener('click', (e) => {
    const btn = e.target.closest('.item-qty-btn, .item-delete-btn');
    if (!btn) return;

    const key = btn.dataset.key;
    const action = btn.dataset.action;
    const card = btn.closest('.cart-drawer-item');
    if (!card) return;

    const input = card.querySelector('.item-qty-input');
    const currentQty = input ? parseInt(input.value) : 1;

    if (action === 'plus') {
      updateQty(key, currentQty + 1);
    } else if (action === 'minus') {
      if (currentQty > 1) {
        updateQty(key, currentQty - 1);
      } else {
        updateQty(key, 0);
      }
    } else if (action === 'delete') {
      updateQty(key, 0);
    }
  });

  // Protection toggle click
  if (protectionToggle) {
    protectionToggle.addEventListener('change', () => {
      fetchAndRenderCart();
    });
  }

  // Checkout click
  if (checkoutBtn) {
    checkoutBtn.addEventListener('click', () => {
      window.location.href = '/checkout';
    });
  }

  // Money formatter helper
  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(2);
  }

  // Initial hook and global exposure
  hookCartButtons();
  window.openCartDrawer = openCartDrawer;
  window.fetchAndRenderCart = fetchAndRenderCart;

  // Intercept Shopify cart submit forms if any
  document.addEventListener('submit', (e) => {
    const form = e.target;
    if (form.action && form.action.includes('/cart/add')) {
      // If it's a product form add, let the product script handle it and then trigger drawer
    }
  });
});
</script>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": [
    {
      "type": "text",
      "id": "cart_title",
      "label": "Cart Heading",
      "default": "Your Cart"
    },
    {
      "type": "number",
      "id": "free_shipping_threshold",
      "label": "Free Shipping Threshold (USD)",
      "default": 50
    },
    {
      "type": "checkbox",
      "id": "show_shipping_protection",
      "label": "Show Shipping Protection Option",
      "default": true
    },
    {
      "type": "text",
      "id": "shipping_protection_title",
      "label": "Shipping Protection Title",
      "default": "Shipping Protection $5.00"
    },
    {
      "type": "text",
      "id": "shipping_protection_subtitle",
      "label": "Shipping Protection Subtitle",
      "default": "Protect your order from damage, loss, or theft."
    },
    {
      "type": "number",
      "id": "shipping_protection_price",
      "label": "Shipping Protection Price (USD)",
      "default": 5
    },
    {
      "type": "number",
      "id": "save_percent",
      "label": "Save Percentage Tag (e.g. 57)",
      "default": 57
    },
    {
      "type": "text",
      "id": "trust_guarantee_text",
      "label": "Trust Guarantee Text",
      "default": "60 Day Money Back Guarantee"
    }
  ]
}
{% endschema %}

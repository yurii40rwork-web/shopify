{%- if request.path == '/cart' or template == 'cart' or template.name == 'cart' -%}
  {%- unless request.design_mode -%}
    <script>
      window.location.href = '/?open-cart=1';
    </script>
  {%- else -%}
    <div class="cart-disabled-message" style="padding: 80px 24px; text-align: center; font-family: var(--font-body, sans-serif); max-width: 600px; margin: 0 auto;">
      <span class="material-symbols-outlined" style="font-size: 64px; color: var(--text-light, #75777d); margin-bottom: 24px;">shopping_bag</span>
      <h2 style="font-size: 24px; font-weight: 700; color: var(--text-primary, #181c21); margin-bottom: 12px;">Cart Page is Disabled</h2>
      <p style="color: var(--text-secondary, #44474c); font-size: 16px; margin-bottom: 24px; line-height: 1.5;">The separate cart page is disabled because this theme uses the <strong>Cart Drawer</strong> instead.</p>
      <button onclick="if(window.openCartDrawer) window.openCartDrawer();" style="display: inline-flex; align-items: center; justify-content: center; background-color: #181c21; color: white; font-weight: 600; padding: 12px 28px; border: none; border-radius: 8px; cursor: pointer; transition: opacity 0.2s ease;">
        Open Cart Drawer
      </button>
    </div>
    <style>
      .cart-page-wrapper, .cart-announcement-banner {
        display: none !important;
      }
    </style>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        setTimeout(() => {
          if (window.openCartDrawer) window.openCartDrawer();
        }, 800);
      });
    </script>
  {%- endunless -%}
{%- endif -%}

{{ 'avemos-style.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

<style>
  /* Cart Page Custom Premium Styles */
  .cart-announcement-banner {
    text-align: center;
    padding: 10px 24px;
    font-size: 0.95rem;
    font-weight: 600;
    font-family: var(--font-body);
    letter-spacing: 0.03em;
  }
  
  .cart-page-wrapper {
    background-color: var(--bg-primary);
    min-height: 70vh;
  }
  
  .cart-title {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }
  
  .cart-empty-state-wrapper {
    text-align: center;
    padding: 60px 24px;
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    box-shadow: var(--card-shadow);
    max-width: 600px;
    margin: 40px auto;
  }
  
  .empty-icon-box {
    margin-bottom: 20px;
    color: var(--text-light);
    display: flex;
    justify-content: center;
    align-items: center;
  }
  
  .cart-empty-state-wrapper h2 {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    color: var(--text-primary);
    margin-bottom: 12px;
  }
  
  .cart-empty-state-wrapper p {
    font-family: var(--font-body);
    color: var(--text-secondary);
    font-size: 1rem;
    margin-bottom: 24px;
  }
  
  .continue-shopping-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--primary);
    color: white !important;
    font-family: var(--font-body);
    font-weight: 600;
    padding: 14px 32px;
    border-radius: var(--radius-md);
    transition: background-color var(--transition-fast), transform var(--transition-fast);
    cursor: pointer;
  }
  
  .continue-shopping-btn:hover {
    background-color: var(--primary-hover);
    transform: translateY(-1px);
  }
  
  .cart-grid-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: start;
    margin-top: 20px;
  }
  
  @media (min-width: 992px) {
    .cart-grid-layout {
      grid-template-columns: 1.6fr 1fr;
    }
  }
  
  .cart-items-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  
  .cart-item-card {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 16px;
    padding: 16px;
    background: var(--bg-secondary);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-light);
    box-shadow: 0 4px 12px rgba(125, 139, 161, 0.05);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    position: relative;
  }
  
  .cart-item-card:hover {
    box-shadow: 0 6px 18px rgba(125, 139, 161, 0.08);
  }
  
  @media (min-width: 768px) {
    .cart-item-card {
      grid-template-columns: 100px 2.2fr 1fr 1fr;
      align-items: center;
      gap: 24px;
      padding: 20px;
    }
  }
  
  .cart-item-img-wrapper {
    width: 90px;
    height: 90px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--border-light);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-primary);
  }
  
  @media (min-width: 768px) {
    .cart-item-img-wrapper {
      width: 100px;
      height: 100px;
    }
  }
  
  .cart-item-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .cart-item-details {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  
  .cart-item-vendor {
    font-size: 0.75rem;
    text-transform: uppercase;
    color: var(--text-light);
    font-weight: 600;
    letter-spacing: 0.06em;
  }
  
  .cart-item-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
    transition: color var(--transition-fast);
  }
  
  .cart-item-title:hover {
    color: var(--primary);
  }
  
  .cart-item-variant {
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-family: var(--font-body);
  }
  
  .cart-item-properties {
    font-size: 0.8rem;
    color: var(--text-light);
    margin-top: 4px;
    line-height: 1.4;
  }
  
  .cart-item-price-mobile {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-top: 4px;
  }
  
  @media (min-width: 768px) {
    .cart-item-price-mobile {
      display: none;
    }
  }
  
  .cart-item-quantity-wrapper {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 16px;
    margin-top: 12px;
  }
  
  @media (min-width: 768px) {
    .cart-item-quantity-wrapper {
      flex-direction: column;
      align-items: center;
      gap: 8px;
      margin-top: 0;
    }
  }
  
  .qty-selector {
    display: flex;
    align-items: center;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    background: var(--bg-primary);
    overflow: hidden;
    height: 36px;
  }
  
  .qty-btn {
    background: none;
    border: none;
    width: 32px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--text-secondary);
    transition: background-color var(--transition-fast);
  }
  
  .qty-btn:hover {
    background-color: var(--border-light);
  }
  
  .qty-btn span {
    font-size: 18px;
  }
  
  .qty-input {
    width: 40px;
    height: 100%;
    border: none;
    background: none;
    text-align: center;
    font-family: var(--font-body);
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.95rem;
    -moz-appearance: textfield;
  }
  
  .qty-input::-webkit-outer-spin-button,
  .qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  
  .cart-item-remove-link {
    display: flex;
    align-items: center;
    gap: 4px;
    background: none;
    border: none;
    color: var(--error);
    cursor: pointer;
    font-size: 0.85rem;
    font-family: var(--font-body);
    font-weight: 600;
    transition: opacity var(--transition-fast);
    padding: 4px 8px;
  }
  
  .cart-item-remove-link:hover {
    opacity: 0.75;
  }
  
  .cart-item-remove-link span.material-symbols-outlined {
    font-size: 18px;
  }
  
  .cart-item-total-price-col {
    display: none;
  }
  
  @media (min-width: 768px) {
    .cart-item-total-price-col {
      display: block;
      text-align: right;
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--text-primary);
    }
  }
  
  .cart-summary-sticky {
    position: sticky;
    top: 110px;
  }
  
  .cart-summary-card {
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-light);
    padding: 24px;
    box-shadow: var(--card-shadow);
  }
  
  .summary-title {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-top: 0;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--surface-container);
  }
  
  .summary-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 16px;
    font-family: var(--font-body);
  }
  
  .subtotal-row {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px dashed var(--border-color);
  }
  
  .shipping-info-wrapper {
    font-size: 0.85rem;
    color: var(--text-light);
    margin-bottom: 20px;
    line-height: 1.4;
  }
  
  .order-notes-wrapper {
    margin-bottom: 24px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  
  .order-notes-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-secondary);
    font-family: var(--font-body);
  }
  
  .order-notes-textarea {
    width: 100%;
    height: 80px;
    padding: 12px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 0.9rem;
    resize: vertical;
    background-color: var(--bg-primary);
    color: var(--text-primary);
    transition: border-color var(--transition-fast);
  }
  
  .order-notes-textarea:focus {
    outline: none;
    border-color: var(--primary);
  }
  
  .cart-checkout-btn {
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--primary);
    color: white;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1.1rem;
    padding: 16px 24px;
    border-radius: var(--radius-md);
    border: none;
    cursor: pointer;
    transition: background-color var(--transition-fast), transform var(--transition-fast);
    box-shadow: 0 4px 12px rgba(79, 93, 113, 0.2);

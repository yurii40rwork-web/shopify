  .trust-badges-title {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-secondary);
    margin-top: 0;
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .trust-badge-custom-image img {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
  }
  
  .payment-icons-list {
    display: flex;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  
  .payment-icon {
    width: 38px;
    height: 24px;
  }
  
  .payment-icons-list i {
    font-size: 24px;
    color: var(--text-light);
  }
  
  /* Loading and overlay states */
  .cart-item-card.loading-active {
    opacity: 0.5;
    pointer-events: none;
  }
  
  .cart-item-card.loading-active::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 24px;
    height: 24px;
    margin-top: -12px;
    margin-left: -12px;
    border: 2px solid var(--border-color);
    border-top-color: var(--primary);
    border-radius: 50%;
    animation: spinner 0.6s linear infinite;
  }
  
  @keyframes spinner {
    to { transform: rotate(360deg); }
  }
</style>

{%- if section.settings.show_announcement and section.settings.announcement_text != blank -%}
  <div class="cart-announcement-banner" style="background-color: {{ section.settings.announcement_bg }}; color: {{ section.settings.announcement_color }};">
    {{ section.settings.announcement_text }}
  </div>
{%- endif -%}

{%- assign item_count_excluding_protection = 0 -%}
{%- for item in cart.items -%}
  {%- unless item.handle == 'shipping-protection' -%}
    {%- assign item_count_excluding_protection = item_count_excluding_protection | plus: item.quantity -%}
  {%- endunless -%}
{%- endfor -%}

<div class="Avemos-landing-wrapper cart-page-wrapper" id="cart-page-data" 
     data-pillow-qty1-price="{{ section.settings.pillow_qty1_price | default: 39.00 }}"
     data-pillow-qty2-price="{{ section.settings.pillow_qty2_price | default: 34.00 }}"
     data-pillow-qty3-price="{{ section.settings.pillow_qty3_price | default: 30.00 }}"
     data-pillow-qty4-price="{{ section.settings.pillow_qty4_price | default: 26.00 }}">
  <div class="container" style="padding-top: 40px; padding-bottom: 60px;">
     
    <div class="cart-title-container" style="text-align: {{ section.settings.title_alignment }}; margin-bottom: 30px;">
      <h1 class="cart-title">{{ section.settings.title }}</h1>
    </div>

    <!-- Empty State -->
    <div id="cart-empty-state" class="cart-empty-state-wrapper" {% if item_count_excluding_protection > 0 %}style="display: none;"{% endif %}>
      <div class="empty-icon-box">
        <span class="material-symbols-outlined" style="font-size: 64px;">shopping_bag</span>
      </div>
      <h2>{{ section.settings.empty_cart_title }}</h2>
      <p>{{ section.settings.empty_cart_text }}</p>
      <a href="{{ section.settings.continue_shopping_url }}" class="continue-shopping-btn">
        {{ section.settings.continue_shopping_label }}
      </a>
    </div>

    <!-- Active Cart Layout -->
    <div id="cart-active-state" class="cart-grid-layout" {% if item_count_excluding_protection == 0 %}style="display: none;"{% endif %}>
      
      <!-- Left Column: Cart Items -->
      <div class="cart-items-column">
        <form action="{{ routes.cart_url }}" method="post" id="cart-form">
          <div class="cart-items-list" id="cart-items-container">
            {%- for item in cart.items -%}
              {%- if item.handle == 'shipping-protection' -%}
                {%- continue -%}{%- endif -%}
              <div class="cart-item-card" data-line-item-key="{{ item.key }}" data-line-item-id="{{ item.id }}">
                
                <!-- Item Image -->
                <div class="cart-item-img-wrapper">
                  {%- if item.image -%}
                    <img src="{{ item.image | image_url: width: 240 }}" alt="{{ item.product.title | escape }}" loading="lazy">
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag }}
                  {%- endif -%}
                </div>
                
                <!-- Item Info -->
                <div class="cart-item-details">
                  {%- if section.settings.show_vendor -%}
                    <span class="cart-item-vendor">{{ item.product.vendor }}</span>
                  {%- endif -%}
                  <a href="{{ item.url }}" class="cart-item-title">{{ item.product.title }}</a>
                  
                  <!-- Options / Variant Title -->
                  {%- unless item.product.has_only_default_variant -%}
                    <p class="cart-item-variant">{{ item.variant.title }}</p>
                  {%- endunless -%}
                  
                  <!-- Properties (if any) -->
                  {%- assign property_size = item.properties | size -%}
                  {%- if property_size > 0 -%}
                    <div class="cart-item-properties">
                      {%- for p in item.properties -%}
                        {%- unless p.last == blank -%}
                          <span class="cart-property-label">{{ p.first }}:</span>
                          {%- if p.last contains '/uploads/' -%}
                            <a href="{{ p.last }}">{{ p.last | split: '/' | last }}</a>
                          {%- else -%}
                            {{ p.last }}
                          {%- endif -%}
                          <br>
                        {%- endunless -%}
                      {%- endfor -%}
                    </div>
                  {%- endif -%}

                  <!-- Price Mobile Only -->
                  <div class="cart-item-price-mobile">
                    {{ item.final_price | money }}
                  </div>
                </div>

                <!-- Quantity Column -->
                <div class="cart-item-quantity-wrapper">
                  <div class="qty-selector">
                    <button type="button" class="qty-btn" aria-label="Decrease quantity" data-action="minus">
                      <span class="material-symbols-outlined">remove</span>
                    </button>
                    <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" class="qty-input" data-line-item-key="{{ item.key }}" aria-label="Quantity">
                    <button type="button" class="qty-btn" aria-label="Increase quantity" data-action="plus">
                      <span class="material-symbols-outlined">add</span>
                    </button>
                  </div>
                  
                  <button type="button" class="cart-item-remove-link" aria-label="Remove item" data-action="remove">
                    <span class="material-symbols-outlined">delete</span>
                    <span>Remove</span>
                  </button>
                </div>

                <!-- Line Item Price (Desktop) -->
                <div class="cart-item-total-price-col">
                  <span class="line-price-label">{{ item.final_line_price | money }}</span>
                </div>

              </div>
            {%- endfor -%}
          </div>
        </form>
      </div>

      <!-- Right Column: Cart Summary -->
      <div class="cart-summary-column">
        <div class="cart-summary-sticky">
          <div class="cart-summary-card">
            
            <h2 class="summary-title">Order Summary</h2>
            
            <!-- Subtotal Row -->
            <div class="summary-row subtotal-row">
              <span class="subtotal-label">Subtotal</span>
              <span class="subtotal-value" id="cart-subtotal">{{ cart.total_price | money }}</span>
            </div>

            <!-- Tax / Shipping info -->
            {%- if section.settings.show_shipping_info -%}
              <div class="shipping-info-wrapper">
                <p>{{ section.settings.shipping_info_text }}</p>
              </div>
            {%- endif -%}

            <!-- Order Notes -->
            {%- if section.settings.show_order_note -%}
              <div class="order-notes-wrapper">
                <label for="CartSpecialInstructions" class="order-notes-label">{{ section.settings.order_note_label }}</label>
                <textarea name="note" id="CartSpecialInstructions" class="order-notes-textarea" placeholder="Special instructions for your order...">{{ cart.note }}</textarea>
              </div>
            {%- endif -%}

            <!-- Checkout Action Form -->
            <form action="{{ routes.cart_url }}" method="post" id="checkout-form-submit">
              <button type="submit" name="checkout" class="cart-checkout-btn">
                {{ section.settings.checkout_button_text }}
                <span class="material-symbols-outlined" style="margin-left: 8px;">arrow_forward</span>
              </button>
            </form>

            <!-- Trust / Security Badges -->
            {%- if section.settings.show_trust_badges -%}
              <div class="cart-trust-badges-wrapper">
                <h3 class="trust-badges-title">{{ section.settings.trust_badges_title }}</h3>
                
                {%- if section.settings.trust_badge_image != blank -%}
                  <div class="trust-badge-custom-image">
                    <img src="{{ section.settings.trust_badge_image | image_url: width: 400 }}" alt="{{ section.settings.trust_badges_title | escape }}">
                  </div>
                {%- else -%}
                  <div class="payment-icons-list">
                    {%- for type in shop.enabled_payment_types -%}
                      {{ type | payment_type_svg_tag: class: 'payment-icon' }}
                    {%- else -%}
                      <i class="fa-brands fa-cc-visa"></i>
                      <i class="fa-brands fa-cc-mastercard"></i>
                      <i class="fa-brands fa-cc-amex"></i>
                      <i class="fa-brands fa-cc-discover"></i>
                      <i class="fa-brands fa-cc-apple-pay"></i>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}

          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cartContainer = document.getElementById('cart-items-container');
    const emptyState = document.getElementById('cart-empty-state');
    const activeState = document.getElementById('cart-active-state');
    const subtotalLabel = document.getElementById('cart-subtotal');
    const cartCounts = document.querySelectorAll('#cart-count, #drawer-cart-count');
    const cartPageData = document.getElementById('cart-page-data');
    const pillowQty1Price = parseFloat(cartPageData ? cartPageData.dataset.pillowQty1Price : 39.00) * 100;
    const pillowQty2Price = parseFloat(cartPageData ? cartPageData.dataset.pillowQty2Price : 34.00) * 100;
    const pillowQty3Price = parseFloat(cartPageData ? cartPageData.dataset.pillowQty3Price : 30.00) * 100;
    const pillowQty4Price = parseFloat(cartPageData ? cartPageData.dataset.pillowQty4Price : 26.00) * 100;

    if (!cartContainer) return;

    // Helper: update item quantity on Shopify
    async function updateQuantity(key, quantity) {
      const itemCard = document.querySelector(`.cart-item-card[data-line-item-key="${key}"]`);
      if (itemCard) itemCard.classList.add('loading-active');

      try {
        const response = await fetch('/cart/change.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({
            id: key,
            quantity: quantity
          })
        });

        if (!response.ok) {
          throw new Error('Failed to update cart');
        }

        const cart = await response.json();
        updateCartDOM(cart);
      } catch (error) {
        console.error('Cart update error:', error);
        alert('Could not update cart. Please try again.');
      } finally {
        if (itemCard) itemCard.classList.remove('loading-active');
      }
    }

    function getPillowUnitPriceCents(totalQty) {
      if (totalQty === 1) return pillowQty1Price;
      if (totalQty === 2) return pillowQty2Price;
      if (totalQty === 3) return pillowQty3Price;
      return pillowQty4Price;
    }

    // Helper: update DOM based on new cart JSON
    function updateCartDOM(cart) {
      let totalPillowsQty = 0;
      let itemCountExcludingProtection = 0;
      let hasProtectionInCart = false;

      cart.items.forEach(item => {
        const isProtection = item.handle === 'shipping-protection' || item.product_title.toLowerCase().includes('shipping protection');
        if (isProtection) {
          hasProtectionInCart = true;
        } else {
          itemCountExcludingProtection += item.quantity;
          if (item.product_title.toLowerCase().includes('pillow')) {
            totalPillowsQty += item.quantity;
          }
        }
      });

      let calculatedSubtotal = 0;

      cartCounts.forEach(el => {
        el.textContent = itemCountExcludingProtection;
        if (itemCountExcludingProtection > 0) {
          el.style.display = 'flex';
        } else {
          el.style.display = 'none';
        }
      });

      const keysInCart = new Set();
      cart.items.forEach(item => {
        const isProtection = item.handle === 'shipping-protection' || item.product_title.toLowerCase().includes('shipping protection');
        if (isProtection) {
          calculatedSubtotal += (item.final_price || item.price) * item.quantity;
          return;
        }

        keysInCart.add(item.key);
        
        const isPillow = item.product_title.toLowerCase().includes('pillow');
        const baseUnitPriceCents = item.price || pillowQty1Price;
        const effectiveUnitPrice = isPillow ? getPillowUnitPriceCents(totalPillowsQty) : (item.final_price || item.price);
        const effectiveLinePrice = effectiveUnitPrice * item.quantity;
        calculatedSubtotal += effectiveLinePrice;

        const card = document.querySelector(`.cart-item-card[data-line-item-key="${item.key}"]`);
        if (card) {
          const qtyInput = card.querySelector('.qty-input');
          if (qtyInput) qtyInput.value = item.quantity;

          const linePriceCol = card.querySelector('.cart-item-total-price-col .line-price-label');
          if (linePriceCol) {
            linePriceCol.textContent = formatMoney(effectiveLinePrice);
          }

          const priceMobile = card.querySelector('.cart-item-price-mobile');
          if (priceMobile) {
            priceMobile.textContent = formatMoney(effectiveUnitPrice);
          }
        }
      });

      if (subtotalLabel) {
        subtotalLabel.textContent = formatMoney(calculatedSubtotal);
      }

      const currentCards = document.querySelectorAll('.cart-item-card');
      currentCards.forEach(card => {
        const key = card.dataset.lineItemKey;
        if (!keysInCart.has(key)) {
          card.remove();
        }
      });

      if (itemCountExcludingProtection === 0) {
        if (activeState) activeState.style.display = 'none';
        if (emptyState) emptyState.style.display = 'block';

        if (hasProtectionInCart) {
          const protectionItem = cart.items.find(item => item.handle === 'shipping-protection' || item.product_title.toLowerCase().includes('shipping protection'));
          if (protectionItem) {
            fetch('/cart/change.js', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json'
              },
              body: JSON.stringify({
                id: protectionItem.key,
                quantity: 0
              })
            }).then(() => {
              window.location.reload();
            });
          }
        }
      }
    }

    // Currency Formatter
    const currencySymbol = '{{ cart.currency.symbol }}' || '$';
    function formatMoney(cents) {
      return currencySymbol + (cents / 100).toFixed(2);
    }

    // Note saving debounce mechanism
    const noteTextarea = document.getElementById('CartSpecialInstructions');
    if (noteTextarea) {
      let noteTimeout;
      noteTextarea.addEventListener('input', () => {
        clearTimeout(noteTimeout);
        noteTimeout = setTimeout(async () => {
          try {
            await fetch('/cart/update.js', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json'
              },
              body: JSON.stringify({
                note: noteTextarea.value
              })
            });
            console.log('Order note updated');
          } catch (err) {
            console.error('Failed to update order note:', err);
          }
        }, 1000);
      });
    }

    // Event listener delegation for quantity clicks
    cartContainer.addEventListener('click', (e) => {
      const button = e.target.closest('button, .cart-item-remove-link');
      if (!button) return;

      const card = button.closest('.cart-item-card');
      if (!card) return;

      const key = card.dataset.lineItemKey;
      const qtyInput = card.querySelector('.qty-input');
      if (!qtyInput) return;

      let currentQty = parseInt(qtyInput.value) || 0;
      const action = button.dataset.action;

      if (action === 'minus') {
        if (currentQty > 0) {
          updateQuantity(key, currentQty - 1);
        }
      } else if (action === 'plus') {
        updateQuantity(key, currentQty + 1);
      } else if (action === 'remove' || button.classList.contains('cart-item-remove-link')) {
        updateQuantity(key, 0);
      }
    });

    // Event listener for manual quantity change
    cartContainer.addEventListener('change', (e) => {
      const input = e.target.closest('.qty-input');
      if (!input) return;

      const card = input.closest('.cart-item-card');
      if (!card) return;

      const key = card.dataset.lineItemKey;
      const newQty = Math.max(0, parseInt(input.value) || 0);

      updateQuantity(key, newQty);
    });

    // Intercept checkout form submission on cart page to append discount parameter
    const checkoutForm = document.getElementById('checkout-form-submit');
    if (checkoutForm) {
      checkoutForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        try {
          const res = await fetch('/cart.js');
          const cart = await res.json();
          let pillowQty = 0;
          cart.items.forEach(item => {
            if (item.product_title && item.product_title.toLowerCase().includes('pillow')) {
              pillowQty += item.quantity;
            }
          });

          let discountCode = '';
          if (pillowQty === 2) discountCode = 'PILLOWS2';
          else if (pillowQty === 3) discountCode = 'PILLOWS3';
          else if (pillowQty === 4) discountCode = 'PILLOWS4';
          else if (pillowQty === 5) discountCode = 'PILLOWS5';
          else if (pillowQty >= 6) discountCode = 'PILLOWS6';

          if (discountCode) {
            window.location.href = `/discount/${discountCode}?redirect=/checkout`;
          } else {
            window.location.href = '/checkout';
          }
        } catch (err) {
          window.location.href = '/checkout';
        }
      });
    }
  });
</script>


{% style %}
  {%- assign section_bg_color = section.settings.section_bg_color | default: '#ffffff' -%}
  {%- assign card_bg_color = section.settings.card_bg_color | default: '#f5f5f7' -%}
  {%- assign icon_color = section.settings.icon_color | default: '#000000' -%}
  {%- assign icon_bg_color = section.settings.icon_bg_color | default: 'transparent' -%}
  {%- assign icon_border_color = section.settings.icon_border_color | default: '#000000' -%}

  {% if section.settings.section_font != blank %}
    {{ section.settings.section_font | font_face: font_display: 'swap' }}
  {% endif %}

  #shopify-section-{{ section.id }} {
    {% if section.settings.section_bg_gradient != blank %}
      background: {{ section.settings.section_bg_gradient }} !important;
      --bg-primary: transparent !important;
      --bg-secondary: transparent !important;
    {% else %}
      --bg-primary: {{ section_bg_color }} !important;
      --bg-secondary: {{ section_bg_color }} !important;
      --surface-container-low: {{ section_bg_color }} !important;
      --surface-container: {{ section_bg_color }} !important;
      background-color: {{ section_bg_color }} !important;
    {% endif %}
    {% if section.settings.section_text_color != blank %}
      --text-primary: {{ section.settings.section_text_color }} !important;
      --text-secondary: {{ section.settings.section_text_color }} !important;
      --text-light: {{ section.settings.section_text_color }} !important;
      color: {{ section.settings.section_text_color }} !important;
    {% endif %}
    {% if section.settings.section_font != blank %}
      --font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
      --font-heading: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
      --font-body: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
      font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
    {% endif %}
  }

  #shopify-section-{{ section.id }} .benefit-card {
    background-color: {{ card_bg_color }} !important;
    padding: {{ section.settings.card_padding | default: 16 }}px !important;
  }

  #shopify-section-{{ section.id }} .benefit-icon-placeholder {
    color: {{ icon_color }} !important;
    background-color: {{ icon_bg_color }} !important;
    border-color: {{ icon_border_color }} !important;
  }

  #shopify-section-{{ section.id }} .benefit-media {
    width: 100%;
    border-radius: var(--radius-md, 8px);
    overflow: hidden;
    margin-bottom: 14px;
    position: relative;
    background-color: var(--surface-container-low, #f1f4fb);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .benefit-media.aspect-16-9 {
    aspect-ratio: 16 / 9;
  }

  #shopify-section-{{ section.id }} .benefit-media.aspect-4-3 {
    aspect-ratio: 4 / 3;
  }

  #shopify-section-{{ section.id }} .benefit-media.aspect-1-1 {
    aspect-ratio: 1 / 1;
  }

  #shopify-section-{{ section.id }} .benefit-media.aspect-auto {
    aspect-ratio: auto;
  }

  #shopify-section-{{ section.id }} .benefit-media img,
  #shopify-section-{{ section.id }} .benefit-media video,
  #shopify-section-{{ section.id }} .benefit-media .benefit-video-player {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .benefit-media iframe {
    width: 100%;
    height: 100%;
    border: 0;
    pointer-events: none;
  }
{% endstyle %}

<div class="Avemos-landing-wrapper" id="benefits">
  <!-- Key Benefits -->
  <section class="container" style="margin-top: 40px; margin-bottom: 40px;">
    <h2 class="section-title">{{ section.settings.title }}</h2>
    <p class="section-subtitle">{{ section.settings.subtitle }}</p>
    
    <div class="benefits-grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- assign has_media = false -%}
          {%- if block.settings.video != blank or block.settings.video_url != blank or block.settings.image != blank -%}
            {%- assign has_media = true -%}
          {%- endif -%}
          <div class="benefit-card" {{ block.shopify_attributes }}>
            {%- if has_media -%}
              <div class="benefit-media aspect-{{ section.settings.media_aspect_ratio | default: '16-9' }}">
                {%- if block.settings.video != blank -%}
                  {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, class: 'benefit-video-player' }}
                {%- elsif block.settings.video_url != blank -%}
                  {%- if block.settings.video_url.type == 'youtube' -%}
                    <iframe src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?autoplay=1&muted=1&loop=1&playlist={{ block.settings.video_url.id }}&controls=0&playsinline=1" allow="autoplay; encrypted-media" allowfullscreen title="{{ block.settings.title | escape }}"></iframe>
                  {%- elsif block.settings.video_url.type == 'vimeo' -%}
                    <iframe src="https://player.vimeo.com/video/{{ block.settings.video_url.id }}?autoplay=1&muted=1&loop=1&background=1" allow="autoplay; encrypted-media" allowfullscreen title="{{ block.settings.title | escape }}"></iframe>
                  {%- endif -%}
                {%- elsif block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.image.alt | default: block.settings.title | escape }}" loading="lazy" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}">
                {%- endif -%}
              </div>
            {%- else -%}
              <div class="benefit-icon-placeholder">
                <i class="fa-solid {{ block.settings.icon | default: 'fa-arrows-to-dot' }}"></i>
              </div>
            {%- endif -%}
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="benefit-card">
          <div class="benefit-icon-placeholder">
            <i class="fa-solid fa-arrows-to-dot"></i>
          </div>
          <h3>360° Neck Support</h3>
          <p>Complete head stabilization at any angle. Prevents head drop and neck pain.</p>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon-placeholder">
            <i class="fa-solid fa-brain"></i>
          </div>
          <h3>Memory Foam Core</h3>
          <p>Premium orthopedic memory foam adapts to the unique contours of your body.</p>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon-placeholder">
            <i class="fa-solid fa-wind"></i>
          </div>
          <h3>Breathable Hypoallergenic Fabric</h3>
          <p>Material regulates body temperature, protects against sweat, and repels pet hair.</p>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon-placeholder">
            <i class="fa-solid fa-compress"></i>
          </div>
          <h3>Compact Design</h3>
          <p>Easily compresses to 1/3 of its size. Includes a waterproof travel carry bag.</p>
        </div>
      {%- endif -%}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Avemos Benefits",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Why Travelers Choose Avemos®"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Section Subtitle",
      "default": "Innovative technology for your comfortable sleep on the road"
    },
    {
      "type": "select",
      "id": "media_aspect_ratio",
      "label": "Media Aspect Ratio",
      "options": [
        {
          "value": "16-9",
          "label": "16:9 Landscape"
        },
        {
          "value": "4-3",
          "label": "4:3 Standard"
        },
        {
          "value": "1-1",
          "label": "1:1 Square"
        },
        {
          "value": "auto",
          "label": "Adapt to Media"
        }
      ],
      "default": "16-9"
    },
    {
      "type": "header",
      "content": "Section Customization"
    },
    {
      "type": "font_picker",
      "id": "section_font",
      "label": "Section Font",
      "default": "work_sans_n4"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "section_bg_gradient",
      "label": "Section Background Gradient"
    },
    {
      "type": "color",
      "id": "section_text_color",
      "label": "Section Text Color"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Color",
      "default": "#f5f5f7"
    },
    {
      "type": "range",
      "id": "card_padding",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Card Inner Padding",
      "default": 16
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "icon_bg_color",
      "label": "Icon Background Color",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "icon_border_color",
      "label": "Icon Border/Outline Color",
      "default": "#000000"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "header",
          "content": "Media Options (Picture or Video)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Benefit Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Shopify-hosted Video"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "External Video URL (YouTube / Vimeo)",
          "accept": [
            "youtube",
            "vimeo"
          ]
        },
        {
          "type": "header",
          "content": "Icon Options"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "FontAwesome Icon Class (e.g. fa-brain)",
          "default": "fa-arrows-to-dot"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Benefit Title",
          "default": "Benefit Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Benefit Description",
          "default": "Benefit description goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Avemos Benefits",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon": "fa-arrows-to-dot",
            "title": "360° Neck Support",
            "text": "Complete head stabilization at any angle. Prevents head drop and neck pain."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "fa-brain",
            "title": "Memory Foam Core",
            "text": "Premium orthopedic memory foam adapts to the unique contours of your body."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "fa-wind",
            "title": "Breathable Hypoallergenic Fabric",
            "text": "Material regulates body temperature, protects against sweat, and repels pet hair."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "fa-compress",
            "title": "Compact Design",
            "text": "Easily compresses to 1/3 of its size. Includes a waterproof travel carry bag."
          }
        }
      ]
    }
  ]
}
{% endschema %}

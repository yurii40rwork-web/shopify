{{ 'avemos-style.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

{% style %}
  {% if section.settings.section_font != blank %}
    {{ section.settings.section_font | font_face: font_display: 'swap' }}
  {% endif %}

  #shopify-section-{{ section.id }} {
    {% if section.settings.section_bg_gradient != blank %}
      background: {{ section.settings.section_bg_gradient }} !important;
      --bg-primary: transparent !important;
      --bg-secondary: transparent !important;
    {% elsif section.settings.section_bg_color != blank %}
      --bg-primary: {{ section.settings.section_bg_color }} !important;
      --bg-secondary: {{ section.settings.section_bg_color }} !important;
      --surface-container-low: {{ section.settings.section_bg_color }} !important;
      --surface-container: {{ section.settings.section_bg_color }} !important;
      background-color: {{ section.settings.section_bg_color }} !important;
    {% endif %}
    {% if section.settings.section_text_color != blank %}
      --text-primary: {{ section.settings.section_text_color }} !important;
      --text-secondary: {{ section.settings.section_text_color }} !important;
      --text-light: {{ section.settings.section_text_color }} !important;
      color: {{ section.settings.section_text_color }} !important;
    {% endif %}
    {% if section.settings.section_font != blank %}
      --font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
      --font-heading: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
      --font-body: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
      font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
    {% endif %}
  }

  #shopify-section-{{ section.id }} .benefit-card {
    {% if section.settings.card_bg_color != blank %}
      background-color: {{ section.settings.card_bg_color }} !important;
    {% endif %}
  }

  #shopify-section-{{ section.id }} .benefit-icon-placeholder {
    {% if section.settings.icon_color != blank %}
      color: {{ section.settings.icon_color }} !important;
    {% endif %}
    {% if section.settings.icon_bg_color != blank %}
      background-color: {{ section.settings.icon_bg_color }} !important;
    {% endif %}
    {% if section.settings.icon_border_color != blank %}
      border-color: {{ section.settings.icon_border_color }} !important;
    {% endif %}
  }
{% endstyle %}

<div class="Avemos-landing-wrapper" id="benefits">
  <!-- Key Benefits -->
  <section class="container" style="margin-top: 40px; margin-bottom: 40px;">
    <h2 class="section-title">{{ section.settings.title }}</h2>
    <p class="section-subtitle">{{ section.settings.subtitle }}</p>
    
    <div class="benefits-grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="benefit-card" {{ block.shopify_attributes }}>
            <div class="benefit-icon-placeholder">
              <i class="fa-solid {{ block.settings.icon | default: 'fa-arrows-to-dot' }}"></i>
            </div>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="benefit-card">
          <div class="benefit-icon-placeholder">
            <i class="fa-solid fa-arrows-to-dot"></i>
          </div>
          <h3>360° Neck Support</h3>
          <p>Complete head stabilization at any angle. Prevents head drop and neck pain.</p>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon-placeholder">
            <i class="fa-solid fa-brain"></i>
          </div>
          <h3>Memory Foam Core</h3>
          <p>Premium orthopedic memory foam adapts to the unique contours of your body.</p>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon-placeholder">
            <i class="fa-solid fa-wind"></i>
          </div>
          <h3>Breathable Hypoallergenic Fabric</h3>
          <p>Material regulates body temperature, protects against sweat, and repels pet hair.</p>
        </div>

        <div class="benefit-card">
          <div class="benefit-icon-placeholder">
            <i class="fa-solid fa-compress"></i>
          </div>
          <h3>Compact Design</h3>
          <p>Easily compresses to 1/3 of its size. Includes a waterproof travel carry bag.</p>
        </div>
      {%- endif -%}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Avemos Benefits",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Why Travelers Choose Avemos®"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Section Subtitle",
      "default": "Innovative technology for your comfortable sleep on the road"
    },
    {
      "type": "header",
      "content": "Section Customization"
    },
    {
      "type": "font_picker",
      "id": "section_font",
      "label": "Section Font",
      "default": "work_sans_n4"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "section_bg_gradient",
      "label": "Section Background Gradient"
    },
    {
      "type": "color",
      "id": "section_text_color",
      "label": "Section Text Color"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Color",
      "default": "#f5f5f7"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "icon_bg_color",
      "label": "Icon Background Color",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "icon_border_color",
      "label": "Icon Border/Outline Color",
      "default": "#000000"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "FontAwesome Icon Class (e.g. fa-brain)",
          "default": "fa-arrows-to-dot"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Benefit Title",
          "default": "Benefit Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Benefit Description",
          "default": "Benefit description goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Avemos Benefits",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon": "fa-arrows-to-dot",
            "title": "360° Neck Support",
            "text": "Complete head stabilization at any angle. Prevents head drop and neck pain."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "fa-brain",
            "title": "Memory Foam Core",
            "text": "Premium orthopedic memory foam adapts to the unique contours of your body."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "fa-wind",
            "title": "Breathable Hypoallergenic Fabric",
            "text": "Material regulates body temperature, protects against sweat, and repels pet hair."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "fa-compress",
            "title": "Compact Design",
            "text": "Easily compresses to 1/3 of its size. Includes a waterproof travel carry bag."
          }
        }
      ]
    }
  ]
}
{% endschema %}

{{ 'avemos-style.css' | asset_url | stylesheet_tag }}

<div class="Avemos-landing-wrapper" id="comparison">
  <!-- Comparison Section -->
  <section style="background-color: #f1f5f9; padding: 40px 0;">
    <div class="container">
      <h2 class="section-title">{{ section.settings.title | default: "Comparison with Traditional Pillows" }}</h2>
      <p class="section-subtitle">{{ section.settings.subtitle | default: "Why traditional U-shaped travel pillows are no longer sufficient" }}</p>
      
      <div class="comparison-wrapper">
        <table class="comparison-table">
          <thead>
            <tr>
              <th>Features</th>
              <th class="our-product">{{ section.settings.our_product | default: "Avemos® Pillow" }}</th>
              <th>{{ section.settings.their_product | default: "Traditional U-Shape Pillows" }}</th>
            </tr>
          </thead>
          <tbody>
            {%- if section.blocks.size > 0 -%}
              {%- for block in section.blocks -%}
                <tr {{ block.shopify_attributes }}>
                  <td>{{ block.settings.feature_name }}</td>
                  <td class="our-product">
                    <div class="comparison-cell-value">
                      {%- if block.settings.our_check -%}
                        <span class="comparison-badge badge-success">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"></polyline>
                          </svg>
                        </span>
                      {%- else -%}
                        <span class="comparison-badge badge-danger">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="18" y1="6" x2="6" y2="18"></line>
                            <line x1="6" y1="6" x2="18" y2="18"></line>
                          </svg>
                        </span>
                      {%- endif -%}
                      <span class="comparison-text">{{ block.settings.our_desc }}</span>
                    </div>
                  </td>
                  <td class="other-product">
                    <div class="comparison-cell-value">
                      {%- if block.settings.their_check -%}
                        <span class="comparison-badge badge-success">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"></polyline>
                          </svg>
                        </span>
                      {%- else -%}
                        <span class="comparison-badge badge-danger">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="18" y1="6" x2="6" y2="18"></line>
                            <line x1="6" y1="6" x2="18" y2="18"></line>
                          </svg>
                        </span>
                      {%- endif -%}
                      <span class="comparison-text">{{ block.settings.their_desc }}</span>
                    </div>
                  </td>
                </tr>
              {%- endfor -%}
            {%- else -%}
              <tr>
                <td>Head Stabilization</td>
                <td class="our-product">
                  <div class="comparison-cell-value">
                    <span class="comparison-badge badge-success">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </span>
                    <span class="comparison-text">360° support (no head drop)</span>
                  </div>
                </td>
                <td class="other-product">
                  <div class="comparison-cell-value">
                    <span class="comparison-badge badge-danger">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </span>
                    <span class="comparison-text">Sides only (head falls forward)</span>
                  </div>
                </td>
              </tr>
              <tr>
                <td>Filling</td>
                <td class="our-product">
                  <div class="comparison-cell-value">
                    <span class="comparison-badge badge-success">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </span>
                    <span class="comparison-text">Premium orthopedic memory foam</span>
                  </div>
                </td>
                <td class="other-product">
                  <div class="comparison-cell-value">
                    <span class="comparison-badge badge-danger">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </span>
                    <span class="comparison-text">Air or cheap low-density foam</span>
                  </div>
                </td>
              </tr>
              <tr>
                <td>Hygiene</td>
                <td class="our-product">
                  <div class="comparison-cell-value">
                    <span class="comparison-badge badge-success">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </span>
                    <span class="comparison-text">Machine-washable cover</span>
                  </div>
                </td>
                <td class="other-product">
                  <div class="comparison-cell-value">
                    <span class="comparison-badge badge-danger">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </span>
                    <span class="comparison-text">Non-removable, hard to clean</span>
                  </div>
                </td>
              </tr>
              <tr>
                <td>Size Adjustment</td>
                <td class="our-product">
                  <div class="comparison-cell-value">
                    <span class="comparison-badge badge-success">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </span>
                    <span class="comparison-text">Adjustable Velcro strap</span>
                  </div>
                </td>
                <td class="other-product">
                  <div class="comparison-cell-value">
                    <span class="comparison-badge badge-danger">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </span>
                    <span class="comparison-text">One size fits all (no adjustment)</span>
                  </div>
                </td>
              </tr>
            {%- endif -%}
          </tbody>
        </table>
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Avemos Comparison",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Comparison with Traditional Pillows"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Section Subtitle",
      "default": "Why traditional U-shaped travel pillows are no longer sufficient"
    },
    {
      "type": "text",
      "id": "our_product",
      "label": "Our Product Name",
      "default": "Avemos® Pillow"
    },
    {
      "type": "text",
      "id": "their_product",
      "label": "Traditional Product Name",
      "default": "Traditional U-Shape Pillows"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Row",
      "settings": [
        {
          "type": "text",
          "id": "feature_name",
          "label": "Feature Name",
          "default": "Feature"
        },
        {
          "type": "checkbox",
          "id": "our_check",
          "label": "Our Product Checked?",
          "default": true
        },
        {
          "type": "text",
          "id": "our_desc",
          "label": "Our Product Description",
          "default": "Yes"
        },
        {
          "type": "checkbox",
          "id": "their_check",
          "label": "Traditional Product Checked?",
          "default": false
        },
        {
          "type": "text",
          "id": "their_desc",
          "label": "Traditional Product Description",
          "default": "No"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Avemos Comparison",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "feature_name": "Head Stabilization",
            "our_check": true,
            "our_desc": "360° support (no head drop)",
            "their_check": false,
            "their_desc": "Sides only (head falls forward)"
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature_name": "Filling",
            "our_check": true,
            "our_desc": "Premium orthopedic memory foam",
            "their_check": false,
            "their_desc": "Air or cheap low-density foam"
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature_name": "Hygiene",
            "our_check": true,
            "our_desc": "Machine-washable cover",
            "their_check": false,
            "their_desc": "Non-removable, hard to clean"
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature_name": "Size Adjustment",
            "our_check": true,
            "our_desc": "Adjustable Velcro strap",
            "their_check": false,
            "their_desc": "One size fits all (no adjustment)"
          }
        }
      ]
    }
  ]
}
{% endschema %}

{% style %}
  {%- assign section_bg_color = section.settings.section_bg_color | default: '#f1f5f9' -%}
  {%- assign odd_row_bg = section.settings.odd_row_bg | default: '#ffffff' -%}
  {%- assign even_row_bg = section.settings.even_row_bg | default: '#f9f9f9' -%}
  {%- assign winner_column_bg = section.settings.winner_column_bg | default: '#fff3ee' -%}

  {% if section.settings.section_font != blank %}
    {{ section.settings.section_font | font_face: font_display: 'swap' }}
  {% endif %}

  #shopify-section-{{ section.id }} {
    {% if section.settings.section_bg_gradient != blank %}
      background: {{ section.settings.section_bg_gradient }} !important;
      --bg-primary: transparent !important;
      --bg-secondary: transparent !important;
    {% else %}
      --bg-primary: {{ section_bg_color }} !important;
      --bg-secondary: {{ section_bg_color }} !important;
      --surface-container-low: {{ section_bg_color }} !important;
      --surface-container: {{ section_bg_color }} !important;
      background-color: {{ section_bg_color }} !important;
    {% endif %}
    {% if section.settings.section_text_color != blank %}
      --text-primary: {{ section.settings.section_text_color }} !important;
      --text-secondary: {{ section.settings.section_text_color }} !important;
      --text-light: {{ section.settings.section_text_color }} !important;
      color: {{ section.settings.section_text_color }} !important;
    {% endif %}
    {% if section.settings.section_font != blank %}
      --font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
      --font-heading: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
      --font-body: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
      font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
    {% endif %}
  }

  #shopify-section-{{ section.id }} section {
    {% if section.settings.section_bg_gradient != blank %}
      background: {{ section.settings.section_bg_gradient }} !important;
    {% else %}
      background-color: {{ section_bg_color }} !important;
    {% endif %}
  }

  #shopify-section-{{ section.id }} .comparison-table tbody tr:nth-child(odd) {
    background-color: {{ odd_row_bg }} !important;
  }

  #shopify-section-{{ section.id }} .comparison-table tbody tr:nth-child(even) {
    background-color: {{ even_row_bg }} !important;
  }

  #shopify-section-{{ section.id }} .comparison-table th.our-product,
  #shopify-section-{{ section.id }} .comparison-table td.our-product {
    background-color: {{ winner_column_bg }} !important;
  }

  /* View Switcher Styles */
  #shopify-section-{{ section.id }} .comparison-switch-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: 28px;
  }

  #shopify-section-{{ section.id }} .comparison-switch-toggle {
    display: inline-flex;
    background: rgba(0, 0, 0, 0.05);
    padding: 4px;
    border-radius: 40px;
    gap: 4px;
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  #shopify-section-{{ section.id }} .comparison-switch-btn {
    border: none;
    background: transparent;
    padding: 8px 22px;
    font-size: 0.95rem;
    font-weight: 600;
    color: #64748b;
    border-radius: 30px;
    cursor: pointer;
    transition: all 0.25s ease;
  }

  #shopify-section-{{ section.id }} .comparison-switch-btn:hover {
    color: #1e293b;
  }

  #shopify-section-{{ section.id }} .comparison-switch-btn.active {
    background: #ffffff;
    color: #0f172a;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }

  /* Views Visibility */
  #shopify-section-{{ section.id }} .comparison-view {
    display: none;
    opacity: 0;
    transition: opacity 0.25s ease-in-out;
  }

  #shopify-section-{{ section.id }} .comparison-view.active {
    display: block;
    opacity: 1;
  }

  /* Video View Grid (Image 1 reference layout) */
  #shopify-section-{{ section.id }} .comparison-video-grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 900px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .comparison-video-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: center;
    background: #ffffff;
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-left: none !important;
  }

  #shopify-section-{{ section.id }} .comparison-video-col {
    width: 100%;
  }

  #shopify-section-{{ section.id }} .comparison-video-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    max-height: 250px;
    border-radius: 12px;
    overflow: hidden;
    background-color: #0f172a;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .comparison-video-player, 
  #shopify-section-{{ section.id }} .comparison-video-container iframe, 
  #shopify-section-{{ section.id }} .comparison-video-poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: none;
  }

  #shopify-section-{{ section.id }} .comparison-video-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
  }

  #shopify-section-{{ section.id }} .comparison-video-play-btn {
    width: 56px;
    height: 56px;
    background: rgba(255, 255, 255, 0.92);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0f172a;
    box-shadow: 0 4px 15px rgba(0,0,0,0.25);
    transition: transform 0.2s ease, background-color 0.2s ease;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .comparison-video-play-btn svg {
    width: 24px;
    height: 24px;
    margin-left: 3px;
  }

  #shopify-section-{{ section.id }} .comparison-points-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  #shopify-section-{{ section.id }} .comparison-card-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 4px 0;
  }

  #shopify-section-{{ section.id }} .comparison-points-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  #shopify-section-{{ section.id }} .comparison-points-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.95rem;
    line-height: 1.35;
  }

  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .comparison-video-card {
      grid-template-columns: 1fr;
      gap: 20px;
      padding: 18px;
    }
    
    #shopify-section-{{ section.id }} .comparison-card-their .comparison-points-col {
      order: 2;
    }
    #shopify-section-{{ section.id }} .comparison-card-their .comparison-video-col {
      order: 1;
    }
  }
{% endstyle %}

<div class="Avemos-landing-wrapper" id="comparison">
  <!-- Comparison Section -->
  <section style="background-color: #f1f5f9; padding: 40px 0;">
    <div class="container">
      <h2 class="section-title">{{ section.settings.title }}</h2>
      <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      
      {%- assign display_mode = section.settings.display_mode | default: 'switcher' -%}
      {%- assign default_view = section.settings.default_view | default: 'table' -%}

      {%- if display_mode == 'switcher' -%}
        <div class="comparison-switch-wrapper">
          <div class="comparison-switch-toggle" role="tablist">
            <button type="button" 
                    class="comparison-switch-btn {% if default_view == 'table' %}active{% endif %}" 
                    data-view="table"
                    role="tab"
                    aria-selected="{% if default_view == 'table' %}true{% else %}false{% endif %}">
              <span>{{ section.settings.table_tab_label | default: "Table View" }}</span>
            </button>
            <button type="button" 
                    class="comparison-switch-btn {% if default_view == 'video' %}active{% endif %}" 
                    data-view="video"
                    role="tab"
                    aria-selected="{% if default_view == 'video' %}true{% else %}false{% endif %}">
              <span>{{ section.settings.video_tab_label | default: "Video View" }}</span>
            </button>
          </div>
        </div>
      {%- endif -%}

      <!-- Table View -->
      <div class="comparison-view comparison-table-view {% if display_mode == 'table' or display_mode == 'switcher' and default_view == 'table' %}active{% endif %}" id="comparison-view-table-{{ section.id }}">
        <div class="comparison-wrapper">
          <table class="comparison-table">
            <thead>
              <tr>
                <th>Features</th>
                <th class="our-product">{{ section.settings.our_product }}</th>
                <th>{{ section.settings.their_product }}</th>
              </tr>
            </thead>
            <tbody>
              {%- if section.blocks.size > 0 -%}
                {%- for block in section.blocks -%}
                  <tr {{ block.shopify_attributes }}>
                    <td>{{ block.settings.feature_name }}</td>
                    <td class="our-product">
                      <div class="comparison-cell-value">
                        {%- if block.settings.our_check -%}
                          <span class="comparison-badge badge-success">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                              <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                          </span>
                        {%- else -%}
                          <span class="comparison-badge badge-danger">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                              <line x1="18" y1="6" x2="6" y2="18"></line>
                              <line x1="6" y1="6" x2="18" y2="18"></line>
                            </svg>
                          </span>
                        {%- endif -%}
                        <span class="comparison-text">{{ block.settings.our_desc }}</span>
                      </div>
                    </td>
                    <td class="other-product">
                      <div class="comparison-cell-value">
                        {%- if block.settings.their_check -%}
                          <span class="comparison-badge badge-success">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                              <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                          </span>
                        {%- else -%}
                          <span class="comparison-badge badge-danger">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                              <line x1="18" y1="6" x2="6" y2="18"></line>
                              <line x1="6" y1="6" x2="18" y2="18"></line>
                            </svg>
                          </span>
                        {%- endif -%}
                        <span class="comparison-text">{{ block.settings.their_desc }}</span>
                      </div>
                    </td>
                  </tr>
                {%- endfor -%}
              {%- else -%}
                <tr>
                  <td>Head Stabilization</td>
                  <td class="our-product">
                    <div class="comparison-cell-value">
                      <span class="comparison-badge badge-success">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                      </span>
                      <span class="comparison-text">360° support (no head drop)</span>
                    </div>
                  </td>
                  <td class="other-product">
                    <div class="comparison-cell-value">
                      <span class="comparison-badge badge-danger">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                          <line x1="18" y1="6" x2="6" y2="18"></line>
                          <line x1="6" y1="6" x2="18" y2="18"></line>
                        </svg>
                      </span>
                      <span class="comparison-text">Sides only (head falls forward)</span>
                    </div>
                  </td>
                </tr>
                <tr>
                  <td>Filling</td>
                  <td class="our-product">
                    <div class="comparison-cell-value">
                      <span class="comparison-badge badge-success">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                      </span>
                      <span class="comparison-text">Premium orthopedic memory foam</span>
                    </div>
                  </td>
                  <td class="other-product">
                    <div class="comparison-cell-value">
                      <span class="comparison-badge badge-danger">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                          <line x1="18" y1="6" x2="6" y2="18"></line>
                          <line x1="6" y1="6" x2="18" y2="18"></line>
                        </svg>
                      </span>
                      <span class="comparison-text">Air or cheap low-density foam</span>
                    </div>
                  </td>
                </tr>
                <tr>
                  <td>Hygiene</td>
                  <td class="our-product">
                    <div class="comparison-cell-value">
                      <span class="comparison-badge badge-success">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                      </span>
                      <span class="comparison-text">Machine-washable cover</span>
                    </div>
                  </td>
                  <td class="other-product">
                    <div class="comparison-cell-value">
                      <span class="comparison-badge badge-danger">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                          <line x1="18" y1="6" x2="6" y2="18"></line>
                          <line x1="6" y1="6" x2="18" y2="18"></line>
                        </svg>
                      </span>
                      <span class="comparison-text">Non-removable, hard to clean</span>
                    </div>
                  </td>
                </tr>
                <tr>
                  <td>Size Adjustment</td>
                  <td class="our-product">
                    <div class="comparison-cell-value">
                      <span class="comparison-badge badge-success">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                      </span>
                      <span class="comparison-text">Adjustable Velcro strap</span>
                    </div>
                  </td>
                  <td class="other-product">
                    <div class="comparison-cell-value">
                      <span class="comparison-badge badge-danger">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                          <line x1="18" y1="6" x2="6" y2="18"></line>
                          <line x1="6" y1="6" x2="18" y2="18"></line>
                        </svg>
                      </span>
                      <span class="comparison-text">One size fits all (no adjustment)</span>
                    </div>
                  </td>
                </tr>
              {%- endif -%}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Video View (Image 1 layout) -->
      <div class="comparison-view comparison-video-view {% if display_mode == 'video' or display_mode == 'switcher' and default_view == 'video' %}active{% endif %}" id="comparison-view-video-{{ section.id }}">
        <div class="comparison-video-grid">
          
          <!-- Card 1: Winner / Our Product (Video Left, Points Right) -->
          <div class="comparison-video-card comparison-card-our">
            <div class="comparison-video-col">
              <div class="comparison-video-container">
                {%- if section.settings.our_video != blank -%}
                  {{ section.settings.our_video | video_tag: autoplay: true, loop: true, muted: true, controls: true, playsinline: true, class: 'comparison-video-player' }}
                {%- elsif section.settings.our_video_url != blank -%}
                  {%- if section.settings.our_video_url.type == 'youtube' -%}
                    <iframe src="https://www.youtube.com/embed/{{ section.settings.our_video_url.id }}?autoplay=1&muted=1&loop=1&playlist={{ section.settings.our_video_url.id }}&controls=1&playsinline=1" allow="autoplay; encrypted-media" allowfullscreen title="{{ section.settings.our_product_video_title | default: section.settings.our_product | escape }}"></iframe>
                  {%- elsif section.settings.our_video_url.type == 'vimeo' -%}
                    <iframe src="https://player.vimeo.com/video/{{ section.settings.our_video_url.id }}?autoplay=1&muted=1&loop=1&background=0" allow="autoplay; encrypted-media" allowfullscreen title="{{ section.settings.our_product_video_title | default: section.settings.our_product | escape }}"></iframe>
                  {%- endif -%}
                {%- elsif section.settings.our_video_poster != blank -%}
                  <img src="{{ section.settings.our_video_poster | image_url: width: 800 }}" alt="{{ section.settings.our_product_video_title | default: section.settings.our_product | escape }}" loading="lazy" class="comparison-video-poster">
                  <div class="comparison-video-play-btn">
                    <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                  </div>
                {%- else -%}
                  <div class="comparison-video-placeholder">
                    <div class="comparison-video-play-btn">
                      <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                    </div>
                  </div>
                {%- endif -%}
              </div>
            </div>
            
            <div class="comparison-points-col">
              <h3 class="comparison-card-title">{{ section.settings.our_product_video_title | default: section.settings.our_product }}</h3>
              <ul class="comparison-points-list points-success">
                {%- if section.settings.our_video_points != blank -%}
                  {%- assign our_points = section.settings.our_video_points | newline_to_br | split: '<br />' -%}
                  {%- for pt in our_points -%}
                    {%- assign pt_clean = pt | strip -%}
                    {%- if pt_clean != blank -%}
                      <li>
                        <span class="comparison-badge badge-success">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"></polyline>
                          </svg>
                        </span>
                        <span>{{ pt_clean }}</span>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                {%- elsif section.blocks.size > 0 -%}
                  {%- for block in section.blocks -%}
                    <li>
                      <span class="comparison-badge badge-success">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                      </span>
                      <span><strong>{{ block.settings.feature_name }}:</strong> {{ block.settings.our_desc }}</span>
                    </li>
                  {%- endfor -%}
                {%- else -%}
                  <li>
                    <span class="comparison-badge badge-success">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </span>
                    <span>360° support (no head drop)</span>
                  </li>
                  <li>
                    <span class="comparison-badge badge-success">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </span>
                    <span>Premium orthopedic memory foam</span>
                  </li>
                  <li>
                    <span class="comparison-badge badge-success">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </span>
                    <span>Machine-washable cover</span>
                  </li>
                  <li>
                    <span class="comparison-badge badge-success">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </span>
                    <span>Adjustable Velcro strap</span>
                  </li>
                {%- endif -%}
              </ul>
            </div>
          </div>

          <!-- Card 2: Traditional / Their Product (Points Left, Video Right) -->
          <div class="comparison-video-card comparison-card-their">
            <div class="comparison-points-col">
              <h3 class="comparison-card-title">{{ section.settings.their_product_video_title | default: section.settings.their_product }}</h3>
              <ul class="comparison-points-list points-danger">
                {%- if section.settings.their_video_points != blank -%}
                  {%- assign their_points = section.settings.their_video_points | newline_to_br | split: '<br />' -%}
                  {%- for pt in their_points -%}
                    {%- assign pt_clean = pt | strip -%}
                    {%- if pt_clean != blank -%}
                      <li>
                        <span class="comparison-badge badge-danger">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="18" y1="6" x2="6" y2="18"></line>
                            <line x1="6" y1="6" x2="18" y2="18"></line>
                          </svg>
                        </span>
                        <span>{{ pt_clean }}</span>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                {%- elsif section.blocks.size > 0 -%}
                  {%- for block in section.blocks -%}
                    <li>
                      <span class="comparison-badge badge-danger">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                          <line x1="18" y1="6" x2="6" y2="18"></line>
                          <line x1="6" y1="6" x2="18" y2="18"></line>
                        </svg>
                      </span>
                      <span><strong>{{ block.settings.feature_name }}:</strong> {{ block.settings.their_desc }}</span>
                    </li>
                  {%- endfor -%}
                {%- else -%}
                  <li>
                    <span class="comparison-badge badge-danger">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </span>
                    <span>Sides only (head falls forward)</span>
                  </li>
                  <li>
                    <span class="comparison-badge badge-danger">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </span>
                    <span>Air or cheap low-density foam</span>
                  </li>
                  <li>
                    <span class="comparison-badge badge-danger">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </span>
                    <span>Non-removable, hard to clean</span>
                  </li>
                  <li>
                    <span class="comparison-badge badge-danger">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </span>
                    <span>One size fits all (no adjustment)</span>
                  </li>
                {%- endif -%}
              </ul>
            </div>

            <div class="comparison-video-col">
              <div class="comparison-video-container">
                {%- if section.settings.their_video != blank -%}
                  {{ section.settings.their_video | video_tag: autoplay: true, loop: true, muted: true, controls: true, playsinline: true, class: 'comparison-video-player' }}
                {%- elsif section.settings.their_video_url != blank -%}
                  {%- if section.settings.their_video_url.type == 'youtube' -%}
                    <iframe src="https://www.youtube.com/embed/{{ section.settings.their_video_url.id }}?autoplay=1&muted=1&loop=1&playlist={{ section.settings.their_video_url.id }}&controls=1&playsinline=1" allow="autoplay; encrypted-media" allowfullscreen title="{{ section.settings.their_product_video_title | default: section.settings.their_product | escape }}"></iframe>
                  {%- elsif section.settings.their_video_url.type == 'vimeo' -%}
                    <iframe src="https://player.vimeo.com/video/{{ section.settings.their_video_url.id }}?autoplay=1&muted=1&loop=1&background=0" allow="autoplay; encrypted-media" allowfullscreen title="{{ section.settings.their_product_video_title | default: section.settings.their_product | escape }}"></iframe>
                  {%- endif -%}
                {%- elsif section.settings.their_video_poster != blank -%}
                  <img src="{{ section.settings.their_video_poster | image_url: width: 800 }}" alt="{{ section.settings.their_product_video_title | default: section.settings.their_product | escape }}" loading="lazy" class="comparison-video-poster">
                  <div class="comparison-video-play-btn">
                    <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                  </div>
                {%- else -%}
                  <div class="comparison-video-placeholder">
                    <div class="comparison-video-play-btn">
                      <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                    </div>
                  </div>
                {%- endif -%}
              </div>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>
</div>

<script>
  (function() {
    function initComparisonSwitch() {
      var section = document.getElementById('shopify-section-{{ section.id }}');
      if (!section) return;

      var btns = section.querySelectorAll('.comparison-switch-btn');
      var views = section.querySelectorAll('.comparison-view');

      btns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var viewName = this.getAttribute('data-view');
          
          btns.forEach(function(b) {
            b.classList.remove('active');
            b.setAttribute('aria-selected', 'false');
          });
          this.classList.add('active');
          this.setAttribute('aria-selected', 'true');
          
          views.forEach(function(v) {
            if (v.id === 'comparison-view-' + viewName + '-{{ section.id }}') {
              v.classList.add('active');
            } else {
              v.classList.remove('active');
            }
          });
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initComparisonSwitch);
    } else {
      initComparisonSwitch();
    }

    document.addEventListener('shopify:section:load', function(e) {
      if (e.detail && e.detail.sectionId === '{{ section.id }}') {
        initComparisonSwitch();
      }
    });
  })();
</script>


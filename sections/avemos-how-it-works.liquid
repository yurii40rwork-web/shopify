{% style %}
  {% if section.settings.section_font != blank %}
    {{ section.settings.section_font | font_face: font_display: 'swap' }}
  {% endif %}

  #shopify-section-{{ section.id }} {
    {% if section.settings.section_bg_color != blank %}
      --bg-primary: {{ section.settings.section_bg_color }} !important;
      --bg-secondary: {{ section.settings.section_bg_color }} !important;
      --surface-container-low: {{ section.settings.section_bg_color }} !important;
      --surface-container: {{ section.settings.section_bg_color }} !important;
      background-color: {{ section.settings.section_bg_color }} !important;
    {% endif %}
    {% if section.settings.section_text_color != blank %}
      --text-primary: {{ section.settings.section_text_color }} !important;
      --text-secondary: {{ section.settings.section_text_color }} !important;
      --text-light: {{ section.settings.section_text_color }} !important;
      color: {{ section.settings.section_text_color }} !important;
    {% endif %}
    {% if section.settings.section_font != blank %}
      --font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
      --font-heading: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
      --font-body: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
      font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
    {% endif %}
  }
{% endstyle %}

<div class="Avemos-landing-wrapper" id="how-it-works">
  <!-- How It Works Section -->
  <section class="container" style="margin-top: 40px; margin-bottom: 40px;">
    <h2 class="section-title">{{ section.settings.title }}</h2>
    <p class="section-subtitle">{{ section.settings.subtitle }}</p>
    
    <div class="steps-container">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="step-card" {{ block.shopify_attributes }}>
            <div class="step-image-placeholder" style="padding: 0; background: white;">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.title | escape }}" style="width: 100%; height: 100%; object-fit: cover;">
              {%- else -%}
                {%- capture fallback_img -%}how-it-works-{{ forloop.index }}.png{%- endcapture -%}
                <img src="{{ fallback_img | asset_url }}" alt="{{ block.settings.title | escape }}" style="width: 100%; height: 100%; object-fit: cover;">
              {%- endif -%}
            </div>
            <div class="step-content">
              <span class="step-number">{{ forloop.index }}</span>
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.text }}</p>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="step-card">
          <div class="step-image-placeholder" style="padding: 0; background: white;">
            <img src="{{ 'how-it-works-1.png' | asset_url }}" alt="Step 1" style="width: 100%; height: 100%; object-fit: cover;">
          </div>
          <div class="step-content">
            <span class="step-number">1</span>
            <h3>Place on Your Neck</h3>
            <p>Wrap the pillow around your neck so the elevated cushioned sides support your chin and cheeks.</p>
          </div>
        </div>

        <div class="step-card">
          <div class="step-image-placeholder" style="padding: 0; background: white;">
            <img src="{{ 'how-it-works-2.png' | asset_url }}" alt="Step 2" style="width: 100%; height: 100%; object-fit: cover;">
          </div>
          <div class="step-content">
            <span class="step-number">2</span>
            <h3>Adjust the Strap</h3>
            <p>Tighten the adjustable strap to your desired level of support and head stabilization.</p>
          </div>
        </div>

        <div class="step-card">
          <div class="step-image-placeholder" style="padding: 0; background: white;">
            <img src="{{ 'how-it-works-3.png' | asset_url }}" alt="Step 3" style="width: 100%; height: 100%; object-fit: cover;">
          </div>
          <div class="step-content">
            <span class="step-number">3</span>
            <h3>Enjoy Deep Sleep</h3>
            <p>Relax and sleep. The pillow holds your head in a natural, upright position throughout the journey.</p>
          </div>
        </div>
      {%- endif -%}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Avemos How It Works",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "How It Works"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Section Subtitle",
      "default": "Just 3 simple steps to perfect sleep"
    },
    {
      "type": "header",
      "content": "Section Customization"
    },
    {
      "type": "font_picker",
      "id": "section_font",
      "label": "Section Font",
      "default": "work_sans_n4"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background Color"
    },
    {
      "type": "color",
      "id": "section_text_color",
      "label": "Section Text Color"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Step Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Step Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Step Description",
          "default": "Step description goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Avemos How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Place on Your Neck",
            "text": "Wrap the pillow around your neck so the elevated cushioned sides support your chin and cheeks."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Adjust the Strap",
            "text": "Tighten the adjustable strap to your desired level of support and head stabilization."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Enjoy Deep Sleep",
            "text": "Relax and sleep. The pillow holds your head in a natural, upright position throughout the journey."
          }
        }
      ]
    }
  ]
}
{% endschema %}

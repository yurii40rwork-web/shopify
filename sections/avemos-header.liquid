{{ 'avemos-style.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

{%- assign logo_height = section.settings.logo_height | default: 50 -%}

<div class="Avemos-landing-wrapper">
  {% render 'avemos-header-markup', logo_height: logo_height, section: section %}
</div>

{% schema %}
{
  "name": "Avemos Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 20,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Logo Height",
      "default": 50
    },
    {
      "type": "text",
      "id": "announcement_1",
      "label": "Announcement 1",
      "default": "🔥 SPECIAL DEAL: 50% OFF TODAY ONLY!"
    },
    {
      "type": "text",
      "id": "announcement_2",
      "label": "Announcement 2",
      "default": "Free Express Shipping on orders over $50"
    },
    {
      "type": "text",
      "id": "mobile_announcement",
      "label": "Mobile/Drawer Announcement",
      "default": "🌸 Memorial Day Sale | 50% Off"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation Menu"
    }
  ],
  "presets": [
    {
      "name": "Avemos Header"
    }
  ]
}
{% endschema %}

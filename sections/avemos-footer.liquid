{{ 'avemos-style.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="Avemos-landing-wrapper">
  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h4 style="font-weight: 800;"><i class="fa-solid fa-plane-departure"></i> {{ section.settings.col_1_title | default: "Avemos" }}</h4>
          <p>{{ section.settings.col_1_desc | default: "We create premium products for your comfort during travels all over the world." }}</p>
        </div>
        <div class="footer-col">
          <h4>{{ section.settings.col_2_title | default: "Contact Us" }}</h4>
          <ul class="footer-links">
            {%- if section.settings.email != blank -%}
              <li>Email: {{ section.settings.email }}</li>
            {%- endif -%}
            {%- if section.settings.phone != blank -%}
              <li>Phone: {{ section.settings.phone }}</li>
            {%- endif -%}
            {%- if section.settings.address != blank -%}
              <li>Address: {{ section.settings.address }}</li>
            {%- endif -%}
          </ul>
        </div>
        <div class="footer-col">
          <h4>{{ section.settings.col_3_title | default: "Legal Information" }}</h4>
          <ul class="footer-links">
            {%- if section.settings.menu != blank -%}
              {%- for link in section.settings.menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            {%- else -%}
              <li><a href="/pages/privacy-policy">Privacy Policy</a></li>
              <li><a href="/pages/terms-of-service">Terms of Service</a></li>
              <li><a href="/pages/refund-policy">Refund Policy</a></li>
              <li><a href="/pages/shipping-policy">Shipping Policy</a></li>
              <li><a href="/pages/user-agreement">User Agreement</a></li>
            {%- endif -%}
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>{{ section.settings.copyright_text | default: "&copy; 2026 Avemos® Mock App. All rights reserved." }}</p>
        {%- if section.settings.show_payment_badges -%}

            <span class="mock-payment-badge google-pay-badge" aria-label="Google Pay">
              <svg class="payment-logo" viewBox="0 0 74 25" xmlns="http://www.w3.org/2000/svg">
                <path fill="#4285F4" d="M13.2 12.8c0-.4 0-.8-.1-1.2H7.1v2.3h3.5c-.1.8-.6 1.4-1.2 1.8v1.5h2c1.2-1.1 1.8-2.7 1.8-4.4z"/>

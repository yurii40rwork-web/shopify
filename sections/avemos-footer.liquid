                <path fill="#000000" d="M11.9 13.9c0-1.7 1-3.2 2.5-4.1-1-1.4-2.5-2.2-4.3-2.4-1.8-.2-3.6 1-4.5 1-.9 0-2.4-1-3.9-.9-2 .1-3.9 1.2-4.9 3-2.1 3.6-.5 9 1.5 11.9.9 1.4 2.1 2.9 3.6 2.8 1.5-.1 2-1 3.8-1s2.3.9 3.8.9c1.5 0 2.5-1.4 3.5-2.8 1.1-1.6 1.6-3.2 1.6-3.3 0-.1-2.9-1.1-2.9-4.4M10.1 5.2c.8-1 1.3-2.4 1.2-3.8-1.2.1-2.7.8-3.5 1.8-.7.8-1.3 2.2-1.1 3.6 1.3.1 2.7-.6 3.4-1.6"/>
                <path fill="#000000" d="M22.5 6.9h5.1c1.5 0 2.7.3 3.5 1 .8.7 1.2 1.7 1.2 3.1 0 1.5-.4 2.5-1.2 3.2-.8.7-2 1-3.5 1h-2.7v5.6h-2.4V6.9zm2.4 5.9h2.5c1.4 0 2.2-.5 2.2-1.7 0-1.1-.8-1.6-2.2-1.6h-2.5v3.3zm18.3 2.3c0-2.4-1.8-3.7-4.6-3.7-2.3 0-4.1.8-4.9 1.7l1.1 1.4c.7-.7 2-1.3 3.6-1.3 1.6 0 2.4.6 2.4 1.7v.5h-2.8c-3.1 0-4.7 1.3-4.7 3.3 0 1.9 1.4 3.1 3.6 3.1 1.9 0 3-.9 3.5-1.7v1.5h2.3l.1-6.6zm-2.4 3.3c0 1.1-.9 1.7-2.2 1.7-1.3 0-2-.6-2-1.6 0-1.1.9-1.6 2.5-1.6h1.7v1.5zm16 -4.6l-3.3 7.8c-.8 2-1.7 2.9-3.2 2.9-.6 0-1.2-.1-1.6-.3l.5-1.7c.3.1.6.2 1 .2.8 0 1.3-.5 1.7-1.4l.2-.5-4.4-9h2.5l3.1 6.8 3-6.8h2.5z"/>

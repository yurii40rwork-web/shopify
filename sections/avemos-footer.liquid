{{ 'avemos-style.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

{% style %}
  .Avemos-landing-wrapper .footer {
    background-color: {{ section.settings.footer_bg_color }} !important;
    color: {{ section.settings.footer_text_color }} !important;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .Avemos-landing-wrapper .footer-col h4 {
    color: {{ section.settings.footer_headings_color }} !important;
  }
  .Avemos-landing-wrapper .footer-links a,
  .Avemos-landing-wrapper .footer-links li,
  .Avemos-landing-wrapper .footer-col p,
  .Avemos-landing-wrapper .footer-bottom p {
    color: {{ section.settings.footer_text_color }} !important;
    text-decoration: none;
    transition: color 0.25s ease;
  }
  .Avemos-landing-wrapper .footer-links a:hover {
    color: {{ section.settings.footer_links_hover_color }} !important;
  }
  .Avemos-landing-wrapper .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
{% endstyle %}

<div class="Avemos-landing-wrapper">
  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h4 style="font-weight: 800;"><i class="fa-solid fa-plane-departure"></i> {{ section.settings.col_1_title }}</h4>
          <p>{{ section.settings.col_1_desc }}</p>
        </div>
        <div class="footer-col">
          <h4>{{ section.settings.col_2_title }}</h4>
          <ul class="footer-links">
            {%- if section.settings.email != blank -%}
              <li>Email: {{ section.settings.email }}</li>
            {%- endif -%}
            {%- if section.settings.phone != blank -%}
              <li>Phone: {{ section.settings.phone }}</li>
            {%- endif -%}
            {%- if section.settings.address != blank -%}
              <li>Address: {{ section.settings.address }}</li>
            {%- endif -%}
          </ul>
        </div>
        <div class="footer-col">
          <h4>{{ section.settings.col_3_title }}</h4>
          <ul class="footer-links">
            {%- if section.settings.menu != blank -%}
              {%- for link in section.settings.menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            {%- else -%}
              <li><a href="/pages/privacy-policy">Privacy Policy</a></li>
              <li><a href="/pages/terms-of-service">Terms of Service</a></li>
              <li><a href="/pages/refund-policy">Refund Policy</a></li>
              <li><a href="/pages/shipping-policy">Shipping Policy</a></li>
              <li><a href="/pages/user-agreement">User Agreement</a></li>
            {%- endif -%}
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>{{ section.settings.copyright_text }}</p>
        {%- if section.settings.show_payment_badges -%}
          <div class="mock-payments">
            <span class="mock-payment-badge stripe-badge" aria-label="Stripe">
              {{ 'stripe' | payment_type_svg_tag }}
            </span>
            <span class="mock-payment-badge paypal-badge" aria-label="PayPal">
              {{ 'paypal' | payment_type_svg_tag }}
            </span>
            <span class="mock-payment-badge apple-pay-badge" aria-label="Apple Pay">
              {{ 'apple_pay' | payment_type_svg_tag }}
            </span>
            <span class="mock-payment-badge google-pay-badge" aria-label="Google Pay">
              {{ 'google_pay' | payment_type_svg_tag }}
            </span>
          </div>
        {%- endif -%}
      </div>
    </div>
  </footer>
</div>

{% schema %}
{
  "name": "Avemos Footer",
  "settings": [
    {
      "type": "header",
      "content": "Column 1: Brand Info"
    },
    {
      "type": "text",
      "id": "col_1_title",
      "label": "Brand Title",
      "default": "Avemos"
    },
    {
      "type": "textarea",
      "id": "col_1_desc",
      "label": "Brand Description",
      "default": "We create premium products for your comfort during travels all over the world."
    },
    {
      "type": "header",
      "content": "Column 2: Contact Info"
    },
    {
      "type": "text",
      "id": "col_2_title",
      "label": "Contact Title",
      "default": "Contact Us"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email Address",
      "default": "support@avemosstore.com"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone Number",
      "default": "+380965347984"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Physical Address",
      "default": "Zelena St, 114, Lviv, Ukraine"
    },
    {
      "type": "header",
      "content": "Column 3: Legal Menu"
    },
    {
      "type": "text",
      "id": "col_3_title",
      "label": "Legal Title",
      "default": "Legal Information"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Legal Links Menu"
    },
    {
      "type": "header",
      "content": "Footer Bottom"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "&copy; 2026 Avemos® Mock App. All rights reserved."
    },
    {
      "type": "checkbox",
      "id": "show_payment_badges",
      "label": "Show Payment Badges?",
      "default": true
    },
    {
      "type": "header",
      "content": "Visual Friction Optimization (Styles)"
    },
    {
      "type": "color",
      "id": "footer_bg_color",
      "label": "Footer Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "footer_headings_color",
      "label": "Footer Headings Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "footer_text_color",
      "label": "Footer Text/Links Color",
      "default": "#B3B3B3"
    },
    {
      "type": "color",
      "id": "footer_links_hover_color",
      "label": "Footer Links Hover Color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Avemos Footer"
    }
  ]
}
{% endschema %}

<!-- sections/avemos-airplane.liquid -->
{%- assign size = section.settings.airplane_size | default: 60 -%}
{%- assign velocity = section.settings.airplane_velocity | default: 1.0 -%}
{%- assign color = section.settings.airplane_color | default: '#4f5d71' -%}

<div class="scroll-airplane-container" id="scroll-airplane-{{ section.id }}" aria-hidden="true">
  <svg class="flight-path-svg" viewBox="0 0 100 100" preserveAspectRatio="none">
    <defs>
      <!-- Mask to dynamically reveal the active path behind the plane -->
      <mask id="trail-mask-{{ section.id }}" maskUnits="userSpaceOnUse">
        <path id="mask-path-{{ section.id }}" d="M -15 107 L 115 -7" stroke="white" stroke-width="10" fill="none" stroke-linecap="round" />
      </mask>
    </defs>
    
    <!-- Faint background guide line (stroke is none so it is completely invisible) -->
    <path id="flight-path-guide-{{ section.id }}" class="flight-path-guide" d="M -15 107 L 115 -7" fill="none" stroke="none" />
    
    <!-- Active dashed trail (stroke is none so it is completely invisible) -->
    <path id="flight-path-active-{{ section.id }}" class="flight-path-active" d="M -15 107 L 115 -7" fill="none" stroke="none" mask="url(#trail-mask-{{ section.id }})" />
  </svg>
  
  <div id="scroll-airplane-icon-{{ section.id }}" class="scroll-airplane">
    <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Main solid airplane silhouette (wing and tail shape matching Picture 1) -->
      <path d="M 50 3 C 48 3, 46 6, 46 18 L 46 42 L 5 62 C 3 63, 3 67, 6 67 L 46 55 L 46 85 L 33 92 C 31 93, 31 95, 33 95 L 50 91 L 67 95 C 69 95, 69 93, 67 92 L 54 85 L 54 55 L 94 62 C 97 63, 97 67, 94 67 L 54 55 L 54 42 L 54 18 C 54 6, 52 3, 50 3 Z" fill="currentColor" />
      
      <!-- Left Inner Engine -->
      <rect x="30" y="47" width="3" height="10" rx="1.5" fill="currentColor" />
      <!-- Left Outer Engine -->
      <rect x="18" y="52" width="3" height="9" rx="1.5" fill="currentColor" />
      <!-- Right Inner Engine -->
      <rect x="67" y="47" width="3" height="10" rx="1.5" fill="currentColor" />
      <!-- Right Outer Engine -->
      <rect x="79" y="52" width="3" height="9" rx="1.5" fill="currentColor" />

      <!-- Blinking Beacons (Micro-interaction details) -->
      <!-- Left Wingtip (Red) -->
      <circle cx="5" cy="62" r="2.5" class="beacon beacon-red" fill="#ef4444" />
      
      <!-- Right Wingtip (Green) -->
      <circle cx="95" cy="62" r="2.5" class="beacon beacon-green" fill="#22c55e" />
      
      <!-- Tail Beacon (Red) -->
      <circle cx="50" cy="91" r="2" class="beacon beacon-red-slow" fill="#ef4444" />
    </svg>
  </div>
</div>

<style>
.avemos-landing-wrapper,
.Avemos-landing-wrapper {
  position: relative;
  z-index: 1;
}

#scroll-airplane-{{ section.id }} {
  --airplane-base-size: {{ size }}px;
  --airplane-color: {{ color }};
}

.scroll-airplane-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  pointer-events: none;
  z-index: -1; /* Fly in background, behind page content */
  overflow: hidden;
}

.flight-path-svg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.flight-path-guide {
  stroke: none;
  opacity: 0;
  pointer-events: none;
}

.flight-path-active {
  stroke: none;
  opacity: 0;
  pointer-events: none;
}

.scroll-airplane {
  position: absolute;
  width: var(--airplane-base-size);
  height: var(--airplane-base-size);
  transform: translate(-50%, -50%) rotate(45deg); /* Default angle pointing up-right */
  will-change: transform, left, top;
  color: var(--airplane-color);
  filter: drop-shadow(0 4px 10px rgba(79, 93, 113, 0.22));
  transition: transform 0.1s ease-out, left 0.1s ease-out, top 0.1s ease-out;
  opacity: 0.65;
}

.beacon {
  transform-origin: center;
}

.beacon-red {
  animation: pulse-beacon-red 0.8s infinite;
}

.beacon-green {
  animation: pulse-beacon-green 0.8s infinite;
}

.beacon-red-slow {
  animation: pulse-beacon-red 1.3s infinite;
}

@keyframes pulse-beacon-red {
  0%, 100% { fill-opacity: 0.3; }
  50% { fill-opacity: 1; }
}

@keyframes pulse-beacon-green {
  0%, 100% { fill-opacity: 0.3; }
  50% { fill-opacity: 1; }
}

@media (max-width: 768px) {
  .scroll-airplane {
    width: calc(var(--airplane-base-size) * 0.7);
    height: calc(var(--airplane-base-size) * 0.7);
    opacity: 0.55;
  }
}
</style>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  let destroyed = false;

  // Cleanup function definition
  function cleanupOldInstance() {
    window.activeAvemosAirplanes = window.activeAvemosAirplanes || {};
    const oldInstance = window.activeAvemosAirplanes[sectionId];
    if (oldInstance) {
      if (typeof oldInstance.cleanup === 'function') {
        oldInstance.cleanup();
      }
      delete window.activeAvemosAirplanes[sectionId];
    }
  }

  // Execute cleanup immediately
  cleanupOldInstance();

  const pathGuide = document.getElementById('flight-path-guide-' + sectionId);
  const pathActive = document.getElementById('flight-path-active-' + sectionId);
  const maskPath = document.getElementById('mask-path-' + sectionId);
  const plane = document.getElementById('scroll-airplane-icon-' + sectionId);
  const container = document.getElementById('scroll-airplane-' + sectionId);
  const svg = container ? container.querySelector('.flight-path-svg') : null;

  // Append container to landing wrapper to establish stacking order (above wrapper background, behind content).
  // Fallback to body if wrapper is not present.
  if (container) {
    const wrapper = document.querySelector('.avemos-landing-wrapper') || document.querySelector('.Avemos-landing-wrapper');
    if (wrapper) {
      wrapper.appendChild(container);
    } else {
      document.body.appendChild(container);
    }
  }

  // Straight diagonal path: from off-screen bottom-left (-15, 107) to off-screen top-right (115, -7)
  const pathD = "M -15 107 L 115 -7";
  const speedFactor = parseFloat('{{ velocity }}');

  let totalLength = 0;
  let ticking = false;

  function updatePathD() {
    if (!pathGuide || !pathActive || !maskPath) return;
    
    pathGuide.setAttribute('d', pathD);
    pathActive.setAttribute('d', pathD);
    maskPath.setAttribute('d', pathD);
    
    totalLength = pathActive.getTotalLength();
    maskPath.setAttribute('stroke-dasharray', totalLength);
    maskPath.setAttribute('stroke-dashoffset', totalLength);
    
    onScroll();
  }

  function onScroll() {
    if (!plane || !svg || !pathActive || !maskPath || totalLength === 0) return;
    
    const scrollTop = window.scrollY || document.documentElement.scrollTop;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    
    if (docHeight <= 0) return;
    
    let scrollPct = (scrollTop / docHeight) * speedFactor;
    scrollPct = Math.max(0, Math.min(1, scrollPct));
    
    const dist = scrollPct * totalLength;
    const point = pathActive.getPointAtLength(dist);
    
    plane.style.left = point.x + '%';
    plane.style.top = point.y + '%';
    
    // Direction angle calculation
    const step = 0.5;
    const distAhead = Math.min(totalLength, dist + step);
    const pointAhead = pathActive.getPointAtLength(distAhead);
    
    const svgRect = svg.getBoundingClientRect();
    const px = (point.x / 100) * svgRect.width;
    const py = (point.y / 100) * svgRect.height;
    const pax = (pointAhead.x / 100) * svgRect.width;
    const pay = (pointAhead.y / 100) * svgRect.height;
    
    const dx = pax - px;
    const dy = pay - py;
    
    if (Math.abs(dx) > 0.01 || Math.abs(dy) > 0.01) {
      const angle = Math.atan2(dy, dx) * 180 / Math.PI + 90;
      plane.style.transform = `translate(-50%, -50%) rotate(${angle}deg)`;
    }
    
    maskPath.setAttribute('stroke-dashoffset', totalLength - dist);
  }

  function handleScroll() {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        onScroll();
        ticking = false;
      });
      ticking = true;
    }
  }

  function handleResize() {
    updatePathD();
  }

  const scrollHandler = handleScroll;
  const resizeHandler = handleResize;

  // Cleanup method for this instance
  function cleanup() {
    destroyed = true;
    window.removeEventListener('scroll', scrollHandler);
    window.removeEventListener('resize', resizeHandler);
    document.removeEventListener('shopify:section:load', handleSectionLoad);
    document.removeEventListener('shopify:section:select', handleSectionSelect);
    document.removeEventListener('shopify:section:unload', handleSectionUnload);
    // Explicitly purge the DOM container from body if it exists
    if (container && container.parentNode) {
      container.parentNode.removeChild(container);
    }
  }

  function handleSectionLoad(e) {
    if (e.detail.sectionId === sectionId) {
      updatePathD();
    }
  }

  function handleSectionSelect(e) {
    if (e.detail.sectionId === sectionId) {
      updatePathD();
    }
  }

  function handleSectionUnload(e) {
    if (e.detail.sectionId === sectionId) {
      cleanup();
    }
  }

  // Register this instance
  window.activeAvemosAirplanes[sectionId] = {
    cleanup: cleanup
  };

  // Initialize and attach event listeners
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      if (destroyed) return;
      updatePathD();
      window.addEventListener('scroll', scrollHandler, { passive: true });
      window.addEventListener('resize', resizeHandler, { passive: true });
    });
  } else {
    updatePathD();
    window.addEventListener('scroll', scrollHandler, { passive: true });
    window.addEventListener('resize', resizeHandler, { passive: true });
  }

  // Shopify editor compatibility
  document.addEventListener('shopify:section:load', handleSectionLoad);
  document.addEventListener('shopify:section:select', handleSectionSelect);
  document.addEventListener('shopify:section:unload', handleSectionUnload);
})();
</script>

{% schema %}
{
  "name": "Background Airplane",
  "settings": [
    {
      "type": "paragraph",
      "content": "Floating background airplane silhouette that flies diagonally from bottom-left to top-right on scroll."
    },
    {
      "type": "range",
      "id": "airplane_size",
      "min": 20,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Airplane Size",
      "default": 60
    },
    {
      "type": "range",
      "id": "airplane_velocity",
      "min": 0.2,
      "max": 3.0,
      "step": 0.1,
      "unit": "x",
      "label": "Flight Velocity Factor",
      "default": 1.0
    },
    {
      "type": "color",
      "id": "airplane_color",
      "label": "Airplane Silhouette Color",
      "default": "#4f5d71"
    }
  ],
  "presets": [
    {
      "name": "Background Airplane"
    }
  ]
}
{% endschema %}

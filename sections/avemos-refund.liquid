{% style %}
  {% if section.settings.section_font != blank %}
    {{ section.settings.section_font | font_face: font_display: 'swap' }}
  {% endif %}

  #shopify-section-{{ section.id }} {
    {% if section.settings.section_bg_color != blank %}
      --bg-primary: {{ section.settings.section_bg_color }} !important;
      --bg-secondary: {{ section.settings.section_bg_color }} !important;
      --surface-container-low: {{ section.settings.section_bg_color }} !important;
      --surface-container: {{ section.settings.section_bg_color }} !important;
      background-color: {{ section.settings.section_bg_color }} !important;
    {% endif %}
    {% if section.settings.section_text_color != blank %}
      --text-primary: {{ section.settings.section_text_color }} !important;
      --text-secondary: {{ section.settings.section_text_color }} !important;
      --text-light: {{ section.settings.section_text_color }} !important;
      color: {{ section.settings.section_text_color }} !important;
    {% endif %}
    {% if section.settings.section_font != blank %}
      --font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
      --font-heading: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
      --font-body: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
      font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
    {% endif %}
  }

  #shopify-section-{{ section.id }} section {
    {% if section.settings.section_bg_color != blank %}
      background-color: {{ section.settings.section_bg_color }} !important;
    {% endif %}
  }
{% endstyle %}

<div class="Avemos-landing-wrapper" id="refund">
  <section class="refund-section container" style="margin-top: 60px; margin-bottom: 60px;">
    
    <div class="refund-main-content">
      <!-- Left Column: Media (Video or Image) -->
      <div class="refund-image-col">
        <div class="refund-media-wrapper" data-ratio="{{ section.settings.video_ratio | default: 'adapt' }}">
          {%- if section.settings.video != blank -%}
            {{ section.settings.video | video_tag: autoplay: section.settings.video_autoplay, loop: section.settings.video_loop, muted: section.settings.video_muted, controls: section.settings.video_controls, playsinline: true, class: 'refund-hero-media' }}
          {%- elsif section.settings.video_url != blank -%}
            {%- if section.settings.video_url.type == 'youtube' -%}
              <iframe src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?enablejsapi=1{% if section.settings.video_autoplay %}&autoplay=1&mute=1{% endif %}{% if section.settings.video_loop %}&loop=1&playlist={{ section.settings.video_url.id }}{% endif %}{% unless section.settings.video_controls %}&controls=0{% endunless %}" class="refund-hero-media" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
            {%- elsif section.settings.video_url.type == 'vimeo' -%}
              <iframe src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?{% if section.settings.video_autoplay %}autoplay=1&muted=1{% endif %}{% if section.settings.video_loop %}&loop=1{% endif %}{% unless section.settings.video_controls %}&controls=0{% endunless %}" class="refund-hero-media" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>
            {%- endif -%}
          {%- elsif section.settings.image != blank -%}
            <img src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.heading | escape }}" class="refund-hero-media">
          {%- else -%}
            <!-- Fallback image -->
            <img src="{{ 'hero-product.png' | asset_url }}" alt="Refund policy" class="refund-hero-media">
          {%- endif -%}
        </div>
      </div>
      
      <!-- Right Column: Text & CTA -->
      <div class="refund-text-col">
        <h2 class="refund-heading">{{ section.settings.heading }}</h2>
        <div class="refund-description">{{ section.settings.description }}</div>
        
        {%- if section.settings.button_text != blank -%}
          {%- assign button_target = section.settings.button_link -%}
          {%- if button_target == blank or button_target == '#' -%}
            {%- assign button_target = '#product' -%}
          {%- endif -%}
          <a href="{{ button_target }}" class="refund-cta-btn">
            {{ section.settings.button_text }}
          </a>
        {%- endif -%}
      </div>
    </div>
    
    <!-- Bottom Row: 4 Badges/Features -->
    <div class="refund-badges-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'badge' -%}
          <div class="refund-badge-item" {{ block.shopify_attributes }}>
            <div class="refund-badge-icon-wrapper">
              {%- if block.settings.custom_svg != blank -%}
                {{ block.settings.custom_svg }}
              {%- elsif block.settings.icon == 'fa-truck' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
              {%- elsif block.settings.icon == 'fa-envelope' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              {%- elsif block.settings.icon == 'fa-arrows-rotate' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l.73-.73"/><path d="M12 7v10M9 9h4.5a2.5 2.5 0 0 1 0 5H9.5a2.5 2.5 0 0 0 0 5H15"/></svg>
              {%- elsif block.settings.icon == 'fa-heart' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
              {%- else -%}
                <i class="fa-solid {{ block.settings.icon }}"></i>
              {%- endif -%}
            </div>
            <p class="refund-badge-text">{{ block.settings.text }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    
  </section>
</div>

<style>
  .refund-section {
    display: flex;
    flex-direction: column;
    gap: 60px;
    padding: 20px;
  }
  .refund-main-content {
    display: flex;
    align-items: center;
    gap: 64px;
  }
  .refund-image-col {
    flex: 1;
    display: flex;
    justify-content: center;
    width: 100%;
  }
  .refund-media-wrapper {
    position: relative;
    width: 100%;
    max-width: 100%;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 12px 36px rgba(125, 139, 161, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(0, 0, 0, 0.03);
  }
  .refund-media-wrapper[data-ratio="1/1"] { aspect-ratio: 1 / 1; }
  .refund-media-wrapper[data-ratio="4/3"] { aspect-ratio: 4 / 3; }
  .refund-media-wrapper[data-ratio="16/9"] { aspect-ratio: 16 / 9; }
  .refund-media-wrapper[data-ratio="4/5"] { aspect-ratio: 4 / 5; }
  .refund-media-wrapper[data-ratio="9/16"] { aspect-ratio: 9 / 16; }
  .refund-media-wrapper[data-ratio="adapt"] { aspect-ratio: auto; }

  .refund-hero-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 16px;
    border: none;
  }
  .refund-media-wrapper[data-ratio="adapt"] .refund-hero-media {
    height: auto;
  }
  .refund-text-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 24px;
    align-items: flex-start;
  }
  .refund-heading {
    font-family: var(--font-heading);
    font-size: 38px;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1.2;
    margin: 0;
  }
  .refund-description {
    font-family: var(--font-body);
    font-size: 16.5px;
    color: var(--text-secondary);
    line-height: 1.65;
  }
  @keyframes button-gradient-shift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .refund-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #ff499e, #8f44fd, #ffb300, #ff499e);
    background-size: 300% 300%;
    animation: button-gradient-shift 6s ease infinite;
    color: #ffffff;
    padding: 16px 40px;
    border-radius: 9999px;
    font-family: var(--font-body);
    font-size: 18.5px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.25s ease;
    box-shadow: 0 4px 15px rgba(143, 68, 253, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.25);
    cursor: pointer;
  }
  .refund-cta-btn:hover {
    color: #ffffff;
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 8px 25px rgba(143, 68, 253, 0.5);
  }
  .refund-cta-btn:active {
    transform: translateY(0) scale(0.98);
  }
  
  .refund-badges-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    padding-top: 48px;
  }
  .refund-badge-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
  }
  .refund-badge-icon-wrapper {
    width: 68px;
    height: 68px;
    border: 2px solid #1f242c;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    color: #1f242c;
    transition: all 0.25s ease;
  }
  .refund-badge-text {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
    max-width: 200px;
    line-height: 1.35;
  }

  @media (max-width: 991px) {
    .refund-main-content {
      flex-direction: column;
      gap: 40px;
    }
    .refund-text-col {
      align-items: center;
      text-align: center;
    }
    .refund-cta-btn {
      width: 100%;
      max-width: 320px;
    }
    .refund-badges-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px 20px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const refundCtaBtns = document.querySelectorAll('.refund-cta-btn');
    refundCtaBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const href = btn.getAttribute('href');
        if (href && href.startsWith('#')) {
          const targetEl = document.querySelector(href);
          if (targetEl) {
            e.preventDefault();
            targetEl.scrollIntoView({
              behavior: 'smooth',
              block: 'start'
            });
          }
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Refund Policy & Trust",
  "settings": [
    {
      "type": "header",
      "content": "Media Settings"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Shopify-hosted Video"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Video URL (YouTube or Vimeo)",
      "accept": [
        "youtube",
        "vimeo"
      ]
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image (Used if video is not set)"
    },
    {
      "type": "select",
      "id": "video_ratio",
      "label": "Media / Video Aspect Ratio",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to video/image (Original)"
        },
        {
          "value": "1/1",
          "label": "1:1 (Square)"
        },
        {
          "value": "4/3",
          "label": "4:3 (Standard)"
        },
        {
          "value": "16/9",
          "label": "16:9 (Widescreen)"
        },
        {
          "value": "4/5",
          "label": "4:5 (Portrait)"
        },
        {
          "value": "9/16",
          "label": "9:16 (Vertical)"
        }
      ],
      "default": "adapt"
    },
    {
      "type": "checkbox",
      "id": "video_autoplay",
      "label": "Autoplay Video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_loop",
      "label": "Loop Video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_muted",
      "label": "Mute Video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_controls",
      "label": "Show Video Controls",
      "default": false
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "60 Day Money Back Guaranteed"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Your satisfaction is our guarantee. If for any reason you need to send them back, we've got you covered.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "👉 Get Your FlyHugz®"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Section Customization"
    },
    {
      "type": "font_picker",
      "id": "section_font",
      "label": "Section Font",
      "default": "work_sans_n4"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background Color"
    },
    {
      "type": "color",
      "id": "section_text_color",
      "label": "Section Text Color"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust Badge",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "FontAwesome Icon Class (e.g. fa-truck)",
          "default": "fa-truck"
        },
        {
          "type": "html",
          "id": "custom_svg",
          "label": "Custom SVG (Overrides icon setting)"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Badge Text",
          "default": "Feature Title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Refund Policy & Trust",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "icon": "fa-truck",
            "text": "Free worldwide shipping"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "fa-envelope",
            "text": "24/7 Customer Support"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "fa-arrows-rotate",
            "text": "60 Day money back guarantee"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "fa-heart",
            "text": "Over 18,640 happy customers"
          }
        }
      ]
    }
  ]
}
{% endschema %}


{{ 'avemos-style.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

{%- assign product = section.settings.product | default: product -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}

{%- if template == 'product' and product != blank -%}
  <script>
    window.location.href = "/cart/{{ product.selected_or_first_available_variant.id }}:1";
  </script>
{%- endif -%}

<div class="Avemos-landing-wrapper">
  <!-- Material Symbols Outlined stylesheet -->
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

  <div class="container product-container-wrapper" style="padding-top: 40px; padding-bottom: 60px;">
    {%- if product != blank -%}
      <div class="product-grid-layout">
        
        <!-- Left Column: Image Gallery (7 cols equivalent) -->
        <div class="product-gallery-col">
          <div class="main-image-viewport" style="--image-ratio: {{ section.settings.image_ratio | default: '4/3' | replace: '/', ' / ' }};">
            <!-- Slides Track -->
            <div class="slider-track-container">
            {%- if product.media.size > 0 -%}
              {%- for media in product.media -%}
                <img class="gallery-slide-img{% if forloop.first %} active{% endif %}" src="{{ media | image_url: width: 1000 }}" alt="{{ media.alt | default: product.title | escape }}">
              {%- endfor -%}
            {%- else -%}
              <img class="gallery-slide-img active" src="{{ 'hero-product.png' | asset_url }}" alt="{{ product.title | escape }}">
              <img class="gallery-slide-img" src="{{ 'hero-product-2.png' | asset_url }}" alt="{{ product.title | escape }}">
            {%- endif -%}
          </div>

            <!-- Best Seller Badge -->
            {%- if section.settings.show_badge and section.settings.badge_text != blank -%}
              <div class="best-seller-badge-overlay">{{ section.settings.badge_text | escape }}</div>
            {%- endif -%}

            <!-- Slider Arrows -->
            <button type="button" class="gallery-arrow-btn prev-arrow" aria-label="Previous image">
              <span class="material-symbols-outlined">chevron_left</span>
            </button>
            <button type="button" class="gallery-arrow-btn next-arrow" aria-label="Next image">
              <span class="material-symbols-outlined">chevron_right</span>
            </button>
          </div>

          <!-- Thumbnails Grid -->
          <div class="thumbnails-grid-container">
            {%- if product.media.size > 0 -%}
              {%- for media in product.media -%}
                <div class="thumb-card{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}">
                  <img src="{{ media | image_url: width: 200 }}" alt="{{ media.alt | default: product.title | escape }}">
                  {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
                    <div class="video-play-overlay">
                      <span class="material-symbols-outlined">play_circle</span>
                    </div>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            {%- else -%}
              <div class="thumb-card active" data-index="0">
                <img src="{{ 'hero-product.png' | asset_url }}" alt="Main product">
              </div>
              <div class="thumb-card" data-index="1">
                <img src="{{ 'hero-product-2.png' | asset_url }}" alt="Top product view">
              </div>
            {%- endif -%}
          </div>
        </div>

        <!-- Right Column: Product Details (5 cols equivalent) -->
        <div class="product-details-col">
          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when '@app' -%}
                  {% render block %}
                {%- when 'title' -%}
                  <!-- Title -->
                  <div class="details-header-block" style="display: flex; flex-direction: column; gap: 4px;" {{ block.shopify_attributes }}>
                    <h1 class="main-product-title" style="font-size: 32px; font-weight: 700; color: var(--text-primary); margin: 0; line-height: 1.2;">{{ product.title | replace: "Premium Avemos™ ", "" }}</h1>
                  </div>
                {%- when 'rating' -%}
                  <!-- Rating -->
                  {%- if block.settings.show_rating -%}
                    <div class="ratings-row" style="margin-top: 0px;" {{ block.shopify_attributes }}>
                      <div class="stars-container" style="display: flex; align-items: center;">
                        <span class="material-symbols-outlined fill" style="color: #facc15; font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined fill" style="color: #facc15; font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined fill" style="color: #facc15; font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined fill" style="color: #facc15; font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined fill" style="color: #facc15; font-variation-settings: 'FILL' 1;">star</span>
                        {%- if block.settings.rating_text != blank -%}
                          <span class="reviews-count-text" style="font-family: var(--font-body); font-size: 17.5px; color: var(--text-secondary); margin-left: 8px;">{{ block.settings.rating_text | escape }}</span>
                        {%- endif -%}
                      </div>
                    </div>
                  {%- endif -%}
                {%- when 'description' -%}
                  <!-- Description -->
                  <div class="product-info-description" style="font-family: var(--font-body); color: var(--text-secondary); font-size: 15px; line-height: 1.6; margin-top: -12px;" {{ block.shopify_attributes }}>
                    {%- if block.settings.description_override != blank -%}
                      {{ block.settings.description_override }}
                    {%- elsif product.description != blank -%}
                      {{ product.description }}
                    {%- else -%}
                      <p style="font-size: 20px; font-weight: 800; color: var(--text-primary); margin-bottom: 8px; line-height: 1.3;">Tired of neck pain during long trips?</p>
                      <p style="font-size: 15px; line-height: 1.5;">Meet Avemos™ Travel Pillow — your ticket to painless, restful travel. Ultimate support, anywhere you go.</p>
                      
                      <ul style="list-style: none; padding: 0; margin: 16px 0 0 0; display: flex; flex-direction: column; gap: 8px; font-size: 14px;">
                        <li style="display: flex; align-items: center; gap: 8px;">
                          <span class="material-symbols-outlined" style="color: var(--text-primary); font-size: 18px; font-weight: bold; display: inline-flex; align-items: center; justify-content: center; width: 18px; height: 18px; flex-shrink: 0; line-height: 1;">check_circle</span>
                          <span style="line-height: 1.2; display: inline-block;">Arrive refreshed, completely pain-free.</span>
                        </li>
                        <li style="display: flex; align-items: center; gap: 8px;">
                          <span class="material-symbols-outlined" style="color: var(--text-primary); font-size: 18px; font-weight: bold; display: inline-flex; align-items: center; justify-content: center; width: 18px; height: 18px; flex-shrink: 0; line-height: 1;">check_circle</span>
                          <span style="line-height: 1.2; display: inline-block;">Instant relief for tired shoulders and neck.</span>
                        </li>
                        <li style="display: flex; align-items: center; gap: 8px;">
                          <span class="material-symbols-outlined" style="color: var(--text-primary); font-size: 18px; font-weight: bold; display: inline-flex; align-items: center; justify-content: center; width: 18px; height: 18px; flex-shrink: 0; line-height: 1;">check_circle</span>
                          <span style="line-height: 1.2; display: inline-block;">Space-saving design, ready for any adventure.</span>
                        </li>
                        <li style="display: flex; align-items: center; gap: 8px;">
                          <span class="material-symbols-outlined" style="color: var(--text-primary); font-size: 18px; font-weight: bold; display: inline-flex; align-items: center; justify-content: center; width: 18px; height: 18px; flex-shrink: 0; line-height: 1;">check_circle</span>
                          <span style="line-height: 1.2; display: inline-block;">Love it or your money back. 30-Day Trial.</span>
                        </li>
                      </ul>
                    {%- endif -%}
                  </div>
                {%- when 'promo' -%}
                  <!-- Promo -->
                  {%- if block.settings.promo_text != blank -%}
                    <div style="font-family: var(--font-body); font-weight: 800; color: {{ block.settings.promo_color }}; display: flex; align-items: center; gap: 8px; margin-bottom: -16px; font-size: 20px; line-height: 1.3;" {{ block.shopify_attributes }}>
                      {{ block.settings.promo_text | escape }}
                    </div>
                  {%- endif -%}
                {%- when 'bundles' -%}
                  <!-- Packages / Bundles Section -->
                  {%- assign block_bundle_2_discount_cents = block.settings.bundle_2_discount | times: 100 -%}
                  <div class="bundles-selection-section" {{ block.shopify_attributes }}>
                    <!-- Package 1 (Buy 1) -->
                    <div class="bundle-card active" id="bundle-card-1">
                      <div class="bundle-card-header">
                        <label class="bundle-radio-container" style="display: flex !important; align-items: center !important; cursor: pointer !important; width: auto !important; min-width: 0 !important; margin: 0 !important; position: relative !important;">
                          <input type="radio" name="bundle_option" value="buy_1" checked style="position: absolute !important; opacity: 0 !important; width: 0 !important; height: 0 !important; margin: 0 !important; padding: 0 !important; border: none !important; pointer-events: none !important;">
                          <span class="bundle-radio-checkmark" style="position: relative; display: inline-block; width: 20px; height: 20px; flex-shrink: 0; box-sizing: border-box; border-radius: 50%;"></span>
                          <div class="bundle-title-group">
                            <span class="bundle-title">{{ block.settings.bundle_1_title | escape }}</span>
                            <span class="bundle-subtitle">You Save {{ current_variant.compare_at_price | minus: current_variant.price | money }}</span>
                          </div>
                        </label>
                        <div class="bundle-price-group">
                          <span class="bundle-price">{{ current_variant.price | money }}</span>
                          {%- if current_variant.compare_at_price > current_variant.price -%}
                            <span class="bundle-compare-price">{{ current_variant.compare_at_price | money }}</span>
                          {%- endif -%}
                        </div>
                      </div>
                      
                      <div class="bundle-card-content">
                        <div class="bundle-color-row">
                          <span class="bundle-color-label" style="font-weight: 700; color: var(--text-primary); margin-bottom: 0;">Color:</span>
                          <div class="bundle-select-wrapper">
                            <div class="custom-dropdown" id="bundle-1-variant-select" data-value="{{ product.variants.first.id }}">
                              <div class="custom-dropdown-trigger">
                                <span class="select-color-dot" style="background-color: {% assign first_v = product.variants.first.title | downcase %}{% if first_v contains 'navy' or first_v contains 'blue' %}#3b4857{% elsif first_v contains 'gray' or first_v contains 'grey' %}#9ca3af{% elsif first_v contains 'pink' %}#db2777{% elsif first_v contains 'black' %}#1f2937{% elsif first_v contains 'leopard' %}#c8a45a{% else %}#9ca3af{% endif %};"></span>
                                <span class="custom-dropdown-text">{{ product.variants.first.title }}</span>
                                <span class="custom-dropdown-chevron"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#2a2a2a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></span>
                              </div>
                              <div class="custom-dropdown-options">
                                {%- for variant in product.variants -%}
                                  {%- assign swatch_color = '#9ca3af' -%}
                                  {%- assign v_title = variant.title | downcase -%}
                                  {%- if v_title contains 'navy' or v_title contains 'blue' -%}{%- assign swatch_color = '#3b4857' -%}
                                  {%- elsif v_title contains 'gray' or v_title contains 'grey' -%}{%- assign swatch_color = '#9ca3af' -%}
                                  {%- elsif v_title contains 'pink' -%}{%- assign swatch_color = '#db2777' -%}
                                  {%- elsif v_title contains 'black' -%}{%- assign swatch_color = '#1f2937' -%}
                                  {%- elsif v_title contains 'leopard' -%}{%- assign swatch_color = '#c8a45a' -%}
                                  {%- endif -%}
                                  <div class="custom-dropdown-option{% if forloop.first %} selected{% endif %}" data-value="{{ variant.id }}" data-color="{{ swatch_color }}">
                                    <span class="option-color-dot" style="background-color: {{ swatch_color }};"></span>
                                    <span class="option-label">{{ variant.title }}</span>
                                  </div>
                                {%- endfor -%}
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>

                    <!-- Package 2 (Buy 2) -->
                    {%- assign block_bundle_2_price = current_variant.price | times: 2 | minus: block_bundle_2_discount_cents -%}
                    <div class="bundle-card" id="bundle-card-2" data-discount-cents="{{ block_bundle_2_discount_cents }}">
                      <div class="bundle-card-header">
                        <label class="bundle-radio-container" style="display: flex !important; align-items: center !important; cursor: pointer !important; width: auto !important; min-width: 0 !important; margin: 0 !important; position: relative !important;">
                          <input type="radio" name="bundle_option" value="buy_2" style="position: absolute !important; opacity: 0 !important; width: 0 !important; height: 0 !important; margin: 0 !important; padding: 0 !important; border: none !important; pointer-events: none !important;">
                          <span class="bundle-radio-checkmark" style="position: relative; display: inline-block; width: 20px; height: 20px; flex-shrink: 0; box-sizing: border-box; border-radius: 50%;"></span>
                          <div class="bundle-title-group">
                            <span class="bundle-title">
                              {{ block.settings.bundle_2_title | escape }}
                              {%- if block.settings.bundle_2_subtitle != blank -%}
                                <span class="bundle-title-separator">, </span>
                                <span class="bundle-title-subtitle">{{ block.settings.bundle_2_subtitle | escape }}</span>
                              {%- endif -%}
                            </span>
                            <span class="bundle-subtitle">Best Deal: {{ block_bundle_2_price | divided_by: 2 | money }} Each</span>
                          </div>
                        </label>
                        <div class="bundle-price-group">
                          <span class="bundle-price">{{ block_bundle_2_price | money }}</span>
                          {%- if current_variant.compare_at_price > current_variant.price -%}
                            <span class="bundle-compare-price">{{ current_variant.compare_at_price | times: 2 | money }}</span>
                          {%- endif -%}
                        </div>
                      </div>
                      
                      <div class="bundle-card-content">
                        <div class="bundle-color-row">
                          <span class="bundle-color-label" style="font-weight: 700; color: var(--text-primary); margin-bottom: 0;">Colors:</span>
                          <div class="bundle-select-wrapper">
                            <span class="pillow-badge">Pillow 1</span>
                            <div class="custom-dropdown" id="bundle-2-pillow-1-select" data-value="{{ product.variants.first.id }}">
                              <div class="custom-dropdown-trigger">
                                <span class="select-color-dot" style="background-color: {% assign first_v = product.variants.first.title | downcase %}{% if first_v contains 'navy' or first_v contains 'blue' %}#3b4857{% elsif first_v contains 'gray' or first_v contains 'grey' %}#9ca3af{% elsif first_v contains 'pink' %}#db2777{% elsif first_v contains 'black' %}#1f2937{% elsif first_v contains 'leopard' %}#c8a45a{% else %}#9ca3af{% endif %};"></span>
                                <span class="custom-dropdown-text">{{ product.variants.first.title }}</span>
                                <span class="custom-dropdown-chevron"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#2a2a2a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></span>
                              </div>
                              <div class="custom-dropdown-options">
                                {%- for variant in product.variants -%}
                                  {%- assign swatch_color = '#9ca3af' -%}
                                  {%- assign v_title = variant.title | downcase -%}
                                  {%- if v_title contains 'navy' or v_title contains 'blue' -%}{%- assign swatch_color = '#3b4857' -%}
                                  {%- elsif v_title contains 'gray' or v_title contains 'grey' -%}{%- assign swatch_color = '#9ca3af' -%}
                                  {%- elsif v_title contains 'pink' -%}{%- assign swatch_color = '#db2777' -%}
                                  {%- elsif v_title contains 'black' -%}{%- assign swatch_color = '#1f2937' -%}
                                  {%- elsif v_title contains 'leopard' -%}{%- assign swatch_color = '#c8a45a' -%}
                                  {%- endif -%}
                                  <div class="custom-dropdown-option{% if forloop.first %} selected{% endif %}" data-value="{{ variant.id }}" data-color="{{ swatch_color }}">
                                    <span class="option-color-dot" style="background-color: {{ swatch_color }};"></span>
                                    <span class="option-label">{{ variant.title }}</span>
                                  </div>
                                {%- endfor -%}
                              </div>
                            </div>
                          </div>
                          
                          <div class="bundle-select-wrapper">
                            <span class="pillow-badge">Pillow 2</span>
                            <div class="custom-dropdown" id="bundle-2-pillow-2-select" data-value="{{ product.variants.first.id }}">
                              <div class="custom-dropdown-trigger">
                                <span class="select-color-dot" style="background-color: {% assign first_v = product.variants.first.title | downcase %}{% if first_v contains 'navy' or first_v contains 'blue' %}#3b4857{% elsif first_v contains 'gray' or first_v contains 'grey' %}#9ca3af{% elsif first_v contains 'pink' %}#db2777{% elsif first_v contains 'black' %}#1f2937{% elsif first_v contains 'leopard' %}#c8a45a{% else %}#9ca3af{% endif %};"></span>
                                <span class="custom-dropdown-text">{{ product.variants.first.title }}</span>
                                <span class="custom-dropdown-chevron"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#2a2a2a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></span>
                              </div>
                              <div class="custom-dropdown-options">
                                {%- for variant in product.variants -%}
                                  {%- assign swatch_color = '#9ca3af' -%}
                                  {%- assign v_title = variant.title | downcase -%}
                                  {%- if v_title contains 'navy' or v_title contains 'blue' -%}{%- assign swatch_color = '#3b4857' -%}
                                  {%- elsif v_title contains 'gray' or v_title contains 'grey' -%}{%- assign swatch_color = '#9ca3af' -%}
                                  {%- elsif v_title contains 'pink' -%}{%- assign swatch_color = '#db2777' -%}
                                  {%- elsif v_title contains 'black' -%}{%- assign swatch_color = '#1f2937' -%}
                                  {%- elsif v_title contains 'leopard' -%}{%- assign swatch_color = '#c8a45a' -%}
                                  {%- endif -%}
                                  <div class="custom-dropdown-option{% if forloop.first %} selected{% endif %}" data-value="{{ variant.id }}" data-color="{{ swatch_color }}">
                                    <span class="option-color-dot" style="background-color: {{ swatch_color }};"></span>
                                    <span class="option-label">{{ variant.title }}</span>
                                  </div>
                                {%- endfor -%}
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                {%- when 'buy_buttons' -%}
                  <!-- Add to Cart Block -->
                  <div class="checkout-form-wrapper" {{ block.shopify_attributes }}>
                    {%- form 'product', product, id: 'bundle-add-to-cart-form' -%}
                      <input type="hidden" name="return_to" value="/checkout">
                      <input type="hidden" name="id" id="main-product-variant-id" value="{{ current_variant.id }}">
                      <input type="hidden" name="quantity" id="qty-input-val" value="1">
                      
                      <!-- Main Add to Cart Button -->
                      <button type="submit" class="premium-buy-btn larger-buy-btn">
                        {{ block.settings.button_text | escape }}
                      </button>

                      {%- if block.settings.disclaimer_text != blank -%}
                        <div class="quote-disclaimer" style="font-style: normal !important; font-weight: 750 !important; color: var(--text-primary) !important;">
                          {{ block.settings.disclaimer_text | escape }}
                        </div>
                      {%- endif -%}

                      <!-- Payment Icons Grid -->
                      {%- if block.settings.show_payment_icons -%}
                        {%- assign payment_icons = 'shopify_pay,paypal,google_pay,visa,master,american_express,discover,diners_club' | split: ',' -%}
                        <div class="payment-icons-row-custom">
                          {%- for type in payment_icons -%}
                            <span class="payment-icon-wrapper-custom">
                              {{ type | payment_type_svg_tag: class: 'payment-icon' }}
                            </span>
                          {%- endfor -%}
                        </div>
                      {%- endif -%}
                    {%- endform -%}
                  </div>
                {%- when 'collapsible_tab' -%}
                  <!-- Accordion / Collapsible Tab -->
                  <div class="details-accordions-group" {{ block.shopify_attributes }} style="margin-top: 0; margin-bottom: 0; border-top: none;">
                    <details class="accordion-item" style="border-top: 1px solid var(--border-color); border-bottom: none; padding: 12px 0;">
                      <summary class="accordion-summary">
                        <span style="font-family: var(--font-body); font-weight: 600; font-size: 15px; color: var(--text-primary);">{{ block.settings.heading | escape }}</span>
                        <div class="accordion-chevron">
                          <span class="material-symbols-outlined">expand_more</span>
                        </div>
                      </summary>
                      <div class="accordion-content" style="margin-top: 8px; font-size: 14.5px; line-height: 1.5; color: var(--text-secondary);">
                        {{ block.settings.content }}
                      </div>
                    </details>
                  </div>
              {%- endcase -%}
            {%- endfor -%}
          {%- else -%}
            {%- comment -%} Compatibility Fallback: Render default static block layout {%- endcomment -%}
            <!-- Title & Rating -->
            <div class="details-header-block" style="display: flex; flex-direction: column; gap: 4px;">
              <h1 class="main-product-title" style="font-size: 32px; font-weight: 700; color: var(--text-primary); margin: 0; line-height: 1.2;">{{ product.title | replace: "Premium Avemos™ ", "" }}</h1>
              
              <div class="ratings-row" style="margin-top: 0px;">
                <div class="stars-container" style="display: flex; align-items: center;">
                  <span class="material-symbols-outlined fill" style="color: #facc15; font-variation-settings: 'FILL' 1;">star</span>
                  <span class="material-symbols-outlined fill" style="color: #facc15; font-variation-settings: 'FILL' 1;">star</span>
                  <span class="material-symbols-outlined fill" style="color: #facc15; font-variation-settings: 'FILL' 1;">star</span>
                  <span class="material-symbols-outlined fill" style="color: #facc15; font-variation-settings: 'FILL' 1;">star</span>
                  <span class="material-symbols-outlined fill" style="color: #facc15; font-variation-settings: 'FILL' 1;">star</span>
                  <span class="reviews-count-text" style="font-family: var(--font-body); font-size: 17.5px; color: var(--text-secondary); margin-left: 8px;">4.9/5 (12,659 reviews)</span>
                </div>
              </div>
            </div>

            <!-- Description -->
            <div class="product-info-description" style="font-family: var(--font-body); color: var(--text-secondary); font-size: 15px; line-height: 1.6; margin-top: -12px;">
              {%- if product.description != blank -%}
                {{ product.description }}
              {%- else -%}
                <p style="font-size: 20px; font-weight: 800; color: var(--text-primary); margin-bottom: 8px; line-height: 1.3;">Tired of neck pain during long trips?</p>
                <p style="font-size: 15px; line-height: 1.5;">Meet Avemos™ Travel Pillow — your ticket to painless, restful travel. Ultimate support, anywhere you go.</p>
                
                <ul style="list-style: none; padding: 0; margin: 16px 0 0 0; display: flex; flex-direction: column; gap: 8px; font-size: 14px;">
                  <li style="display: flex; align-items: center; gap: 8px;">
                    <span class="material-symbols-outlined" style="color: var(--text-primary); font-size: 18px; font-weight: bold; display: inline-flex; align-items: center; justify-content: center; width: 18px; height: 18px; flex-shrink: 0; line-height: 1;">check_circle</span>
                    <span style="line-height: 1.2; display: inline-block;">Arrive refreshed, completely pain-free.</span>
                  </li>
                  <li style="display: flex; align-items: center; gap: 8px;">

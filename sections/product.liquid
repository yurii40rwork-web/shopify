{{ 'avemos-style.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

{%- assign bogo_enabled = true -%}
{%- if section.settings.enable_bogo == false and settings.enable_bogo == false -%}
  {%- assign bogo_enabled = false -%}
{%- endif -%}

{% style %}
  {%- assign section_bg_color = section.settings.section_bg_color | default: '#ffffff' -%}
  {%- assign product_title_color = section.settings.product_title_color | default: '#000000' -%}
  {%- assign rating_stars_color = section.settings.rating_stars_color | default: '#ffc107' -%}
  {%- assign benefit_checkmark_color = section.settings.benefit_checkmark_color | default: '#2e6f40' -%}
  {%- assign cta_button_bg = section.settings.cta_button_bg | default: '#c85a32' -%}
  {%- assign cta_button_text = section.settings.cta_button_text | default: '#ffffff' -%}
  {%- assign cta_button_whitespace = section.settings.cta_button_whitespace | default: 24 -%}

  {% if section.settings.section_font != blank %}
    {{ section.settings.section_font | font_face: font_display: 'swap' }}
  {% endif %}

  #shopify-section-{{ section.id }} {
    {% if section.settings.section_bg_gradient != blank %}
      background: {{ section.settings.section_bg_gradient }} !important;
      --bg-primary: transparent !important;
      --bg-secondary: transparent !important;
    {% else %}
      --bg-primary: {{ section_bg_color }} !important;
      --bg-secondary: {{ section_bg_color }} !important;
      --surface-container-low: {{ section_bg_color }} !important;
      --surface-container: {{ section_bg_color }} !important;
      background-color: {{ section_bg_color }} !important;
    {% endif %}
    {% if section.settings.section_text_color != blank %}
      --text-primary: {{ section.settings.section_text_color }} !important;
      --text-secondary: {{ section.settings.section_text_color }} !important;
      --text-light: {{ section.settings.section_text_color }} !important;
      color: {{ section.settings.section_text_color }} !important;
    {% endif %}
    {% if section.settings.section_font != blank %}
      --font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
      --font-heading: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
      --font-body: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
      font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
    {% endif %}
  }

  #shopify-section-{{ section.id }} .main-product-title {
    color: {{ product_title_color }} !important;
  }

  #shopify-section-{{ section.id }} .stars-container .material-symbols-outlined {
    color: {{ rating_stars_color }} !important;
  }

  #shopify-section-{{ section.id }} .product-info-description ul li .material-symbols-outlined {
    color: {{ benefit_checkmark_color }} !important;
  }

  #shopify-section-{{ section.id }} .premium-buy-btn {
    background-color: {{ cta_button_bg }} !important;
    border-color: {{ cta_button_bg }} !important;
    color: {{ cta_button_text }} !important;
    margin-top: {{ cta_button_whitespace }}px !important;
    margin-bottom: {{ cta_button_whitespace }}px !important;
    transition: background-color 0.2s ease, filter 0.2s ease, transform 0.2s ease !important;
  }

  #shopify-section-{{ section.id }} .premium-buy-btn:hover {
    filter: brightness(0.85) !important;
  }
{% endstyle %}

{%- assign product = section.settings.product | default: product -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}

{%- if template == 'product' and product != blank -%}
  <script>
    window.location.href = "/cart/{{ product.selected_or_first_available_variant.id }}:1";
  </script>
{%- endif -%}

<div class="Avemos-landing-wrapper" id="product">
  <!-- Material Symbols Outlined stylesheet -->
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

  <div class="container product-container-wrapper" style="padding-top: 40px; padding-bottom: 60px;">
    {%- if product != blank -%}
      <div class="product-grid-layout">
        
        <!-- Left Column: Image Gallery (7 cols equivalent) -->
        <div class="product-gallery-col">
          <div class="main-image-viewport" style="--image-ratio: {{ section.settings.image_ratio | default: '4/3' | replace: '/', ' / ' }};">
            <!-- Slides Track -->
            <div class="slider-track-container">
            {%- if product.media.size > 0 -%}
              {%- for media in product.media -%}
                <img class="gallery-slide-img{% if forloop.first %} active{% endif %}" src="{{ media | image_url: width: 1000 }}" alt="{{ media.alt | default: product.title | escape }}">
              {%- endfor -%}
            {%- else -%}
              <img class="gallery-slide-img active" src="{{ 'hero-product.png' | asset_url }}" alt="{{ product.title | escape }}">
              <img class="gallery-slide-img" src="{{ 'hero-product-2.png' | asset_url }}" alt="{{ product.title | escape }}">
            {%- endif -%}
          </div>

            <!-- Best Seller Badge -->
            {%- if section.settings.show_badge and section.settings.badge_text != blank -%}
              <div class="best-seller-badge-overlay">{{ section.settings.badge_text | escape }}</div>
            {%- endif -%}

            <!-- Slider Arrows -->
            <button type="button" class="gallery-arrow-btn prev-arrow" aria-label="Previous image">
              <span class="material-symbols-outlined">chevron_left</span>
            </button>
            <button type="button" class="gallery-arrow-btn next-arrow" aria-label="Next image">
              <span class="material-symbols-outlined">chevron_right</span>
            </button>

            <!-- Swipe Hint for Mobile -->
            <div class="swipe-hint-overlay" id="gallery-swipe-hint">
              <span>Swipe</span>
              <span class="material-symbols-outlined hint-arrow">chevron_right</span>
            </div>
          </div>

          <!-- Thumbnails Grid -->
          <div class="thumbnails-grid-container">
            {%- if product.media.size > 0 -%}
              {%- for media in product.media -%}
                <div class="thumb-card{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}">
                  <img src="{{ media | image_url: width: 200 }}" alt="{{ media.alt | default: product.title | escape }}">
                  {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
                    <div class="video-play-overlay">
                      <span class="material-symbols-outlined">play_circle</span>
                    </div>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            {%- else -%}
              <div class="thumb-card active" data-index="0">
                <img src="{{ 'hero-product.png' | asset_url }}" alt="Main product">
              </div>
              <div class="thumb-card" data-index="1">
                <img src="{{ 'hero-product-2.png' | asset_url }}" alt="Top product view">
              </div>
            {%- endif -%}
          </div>

          <!-- Gallery Indicators / Dots -->
          <div class="gallery-indicators">
            {%- if product.media.size > 0 -%}
              {%- for media in product.media -%}
                <span class="indicator-dot{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}"></span>
              {%- endfor -%}
            {%- else -%}
              <span class="indicator-dot active" data-index="0"></span>
              <span class="indicator-dot" data-index="1"></span>
            {%- endif -%}
          </div>
        </div>

        <!-- Right Column: Product Details (5 cols equivalent) -->
        <div class="product-details-col">
          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when '@app' -%}
                  {% render block %}
                {%- when 'title' -%}
                  <!-- Title -->
                  <div class="details-header-block" style="display: flex; flex-direction: column; gap: 4px;" {{ block.shopify_attributes }}>
                    <h1 class="main-product-title" style="font-size: 32px; font-weight: 700; color: var(--text-primary); margin: 0; line-height: 1.2;">{{ product.title | replace: "Premium Avemos™ ", "" }}</h1>
                  </div>
                {%- when 'rating' -%}
                  <!-- Rating -->
                  {%- if block.settings.show_rating -%}
                    <div class="ratings-row" style="margin-top: 0px;" {{ block.shopify_attributes }}>
                      <div class="stars-container" style="display: flex; align-items: center;">
                        <span class="material-symbols-outlined fill" style="color: #facc15; font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined fill" style="color: #facc15; font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined fill" style="color: #facc15; font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined fill" style="color: #facc15; font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined fill" style="color: #facc15; font-variation-settings: 'FILL' 1;">star</span>
                        {%- if block.settings.rating_text != blank -%}
                          <span class="reviews-count-text" style="font-family: var(--font-body); font-size: 17.5px; color: var(--text-secondary); margin-left: 8px;">{{ block.settings.rating_text | escape }}</span>
                        {%- endif -%}
                      </div>
                    </div>
                  {%- endif -%}
                {%- when 'description' -%}
                  <!-- Description -->
                  <div class="product-info-description" style="font-family: var(--font-body); color: var(--text-secondary); font-size: 15px; line-height: 1.6; margin-top: -12px;" {{ block.shopify_attributes }}>
                    {%- if block.settings.description_override != blank -%}
                      {{ block.settings.description_override }}
                    {%- elsif product.description != blank -%}
                      {{ product.description }}
                    {%- else -%}
                      <p style="font-size: 20px; font-weight: 800; color: var(--text-primary); margin-bottom: 8px; line-height: 1.3;">Tired of neck pain during long trips?</p>
                      <p style="font-size: 15px; line-height: 1.5;">Meet Avemos™ Travel Pillow — your ticket to painless, restful travel. Ultimate support, anywhere you go.</p>
                      
                      <ul style="list-style: none; padding: 0; margin: 16px 0 0 0; display: flex; flex-direction: column; gap: 8px; font-size: 14px;">
                        <li style="display: flex; align-items: center; gap: 8px;">
                          <span class="material-symbols-outlined" style="color: var(--text-primary); font-size: 18px; font-weight: bold; display: inline-flex; align-items: center; justify-content: center; width: 18px; height: 18px; flex-shrink: 0; line-height: 1;">check_circle</span>
                          <span style="line-height: 1.2; display: inline-block;">Arrive refreshed, completely pain-free.</span>
                        </li>
                        <li style="display: flex; align-items: center; gap: 8px;">
                          <span class="material-symbols-outlined" style="color: var(--text-primary); font-size: 18px; font-weight: bold; display: inline-flex; align-items: center; justify-content: center; width: 18px; height: 18px; flex-shrink: 0; line-height: 1;">check_circle</span>
                          <span style="line-height: 1.2; display: inline-block;">Instant relief for tired shoulders and neck.</span>
                        </li>
                        <li style="display: flex; align-items: center; gap: 8px;">
                          <span class="material-symbols-outlined" style="color: var(--text-primary); font-size: 18px; font-weight: bold; display: inline-flex; align-items: center; justify-content: center; width: 18px; height: 18px; flex-shrink: 0; line-height: 1;">check_circle</span>
                          <span style="line-height: 1.2; display: inline-block;">Space-saving design, ready for any adventure.</span>
                        </li>
                        <li style="display: flex; align-items: center; gap: 8px;">
                          <span class="material-symbols-outlined" style="color: var(--text-primary); font-size: 18px; font-weight: bold; display: inline-flex; align-items: center; justify-content: center; width: 18px; height: 18px; flex-shrink: 0; line-height: 1;">check_circle</span>
                          <span style="line-height: 1.2; display: inline-block;">Love it or your money back. 30-Day Trial.</span>
                        </li>
                      </ul>
                    {%- endif -%}
                  </div>
                {%- when 'promo' -%}
                  <!-- Promo -->
                  {%- if block.settings.promo_text != blank -%}
                    <div style="font-family: var(--font-body); font-weight: 800; color: {{ block.settings.promo_color }}; display: flex; align-items: center; gap: 8px; margin-bottom: -16px; font-size: 20px; line-height: 1.3;" {{ block.shopify_attributes }}>
                      {{ block.settings.promo_text | escape }}
                    </div>
                  {%- endif -%}
                {%- when 'bundles' -%}
                  <!-- Packages / Bundles Section -->
                  {%- assign block_bundle_2_discount_cents = block.settings.bundle_2_discount | times: 100 -%}
                  {%- assign block_bundle_3_discount_cents = block.settings.bundle_3_discount | times: 100 -%}
                  
                  {%- assign block_bundle_2_price = current_variant.price | times: 2 | minus: block_bundle_2_discount_cents -%}
                  {%- assign block_bundle_3_price = current_variant.price | times: 3 | minus: block_bundle_3_discount_cents -%}

                  {%- assign badge_position = block.settings.badge_position | default: 'top-right' -%}
                  {%- case badge_position -%}
                    {%- when 'top-right' -%}
                      {%- assign badge_top = '-10px' -%}
                      {%- assign badge_right = '16px' -%}
                      {%- assign badge_left = 'auto' -%}
                      {%- assign badge_transform = 'none' -%}
                      {%- assign card_padding_top = '24px' -%}
                    {%- when 'top-left' -%}
                      {%- assign badge_top = '-10px' -%}
                      {%- assign badge_right = 'auto' -%}
                      {%- assign badge_left = '16px' -%}
                      {%- assign badge_transform = 'none' -%}
                      {%- assign card_padding_top = '24px' -%}
                    {%- when 'top-center' -%}
                      {%- assign badge_top = '-10px' -%}
                      {%- assign badge_right = 'auto' -%}
                      {%- assign badge_left = '50%' -%}
                      {%- assign badge_transform = 'translateX(-50%)' -%}
                      {%- assign card_padding_top = '24px' -%}
                    {%- when 'inside-top-right' -%}
                      {%- assign badge_top = '10px' -%}
                      {%- assign badge_right = '16px' -%}
                      {%- assign badge_left = 'auto' -%}
                      {%- assign badge_transform = 'none' -%}
                      {%- assign card_padding_top = '42px' -%}
                    {%- when 'inside-top-left' -%}
                      {%- assign badge_top = '10px' -%}
                      {%- assign badge_right = 'auto' -%}
                      {%- assign badge_left = '16px' -%}
                      {%- assign badge_transform = 'none' -%}
                      {%- assign card_padding_top = '42px' -%}
                  {%- endcase -%}

                  <div class="bundles-container-box" {{ block.shopify_attributes }} style="
                    --selected-border-color: {{ block.settings.selected_border_color | default: '#ff5a3d' }};
                    --selected-pin-color: {{ block.settings.selected_pin_color | default: '#ff5a3d' }};
                    --badge-top: {{ badge_top }};
                    --badge-right: {{ badge_right }};
                    --badge-left: {{ badge_left }};
                    --badge-transform: {{ badge_transform }};
                    --card-has-badge-padding-top: {{ card_padding_top }};
                    --badge-font-size: {{ block.settings.badge_font_size | default: 10 }}px;
                    --badge-padding-vertical: {{ block.settings.badge_vertical_padding | default: 6 }}px;
                    --badge-padding-horizontal: {{ block.settings.badge_horizontal_padding | default: 16 }}px;
                    --badge-border-radius: {{ block.settings.badge_border_radius | default: 6 }}px;
                    --badge-bg-color: {{ block.settings.badge_bg_color | default: '#0f2e6e' }};
                    --badge-text-color: {{ block.settings.badge_text_color | default: '#ffffff' }};
                    --discount-badge-font-size: {{ block.settings.discount_badge_font_size | default: 10 }}px;
                    --discount-badge-padding-vertical: {{ block.settings.discount_badge_vertical_padding | default: 4 }}px;
                    --discount-badge-padding-horizontal: {{ block.settings.discount_badge_horizontal_padding | default: 16 }}px;
                    --discount-badge-border-radius: {{ block.settings.discount_badge_border_radius | default: 4 }}px;
                    --discount-badge-bg-color: {{ block.settings.discount_badge_bg_color | default: '#ff5a3d' }};
                    --discount-badge-text-color: {{ block.settings.discount_badge_text_color | default: '#ffffff' }};
                  ">
                    {%- if block.settings.promo_header_text != blank -%}
                      <div class="bundles-promo-header" style="background-color: {{ block.settings.promo_header_bg | default: '#fee2e2' }}; color: {{ block.settings.promo_header_color | default: '#991b1b' }};">
                        {{ block.settings.promo_header_text | escape }}
                      </div>
                    {%- endif -%}

                    <div class="bundles-list-wrapper">
                      <!-- Package 1 (Buy 1) -->
                      <div class="bundle-card-new active" id="bundle-card-1">
                        {%- if product.featured_media != blank -%}
                          {%- assign bundle_img_url = product.featured_media | image_url: width: 120 -%}
                        {%- else -%}
                          {%- assign bundle_img_url = 'hero-product.png' | asset_url -%}
                        {%- endif -%}
                        
                        <div class="bundle-card-header-new">
                          <label class="bundle-radio-container-new">
                            <input type="radio" name="bundle_option" value="buy_1" checked>
                            <span class="bundle-radio-checkmark"></span>
                            <div class="bundle-title-group">
                              <div class="bundle-title-row">
                                <span class="bundle-title">{{ block.settings.bundle_1_title | escape }}</span>
                                {%- if block.settings.bundle_1_save_text != blank -%}
                                  <span class="bundle-save-badge">{{ block.settings.bundle_1_save_text | escape }}</span>
                                {%- endif -%}
                              </div>
                              {%- if block.settings.bundle_1_subtitle != blank -%}
                                <div class="bundle-subtitle">{{ block.settings.bundle_1_subtitle | escape }}</div>
                              {%- endif -%}
                            </div>
                          </label>
                          
                          <div class="bundle-price-group-new" style="margin-right: 16px !important;">
                            {%- if current_variant.compare_at_price > current_variant.price or block.settings.bundle_1_original_price != blank -%}
                              <span class="bundle-compare-price">
                                {%- if block.settings.bundle_1_original_price != blank -%}
                                  {{ block.settings.bundle_1_original_price | escape }}
                                {%- else -%}
                                  {{ current_variant.compare_at_price | money }}
                                {%- endif -%}
                              </span>
                            {%- endif -%}
                            <span class="bundle-price">{{ current_variant.price | money }}</span>
                            <span class="bundle-each-price">{{ current_variant.price | divided_by: 2 | money }} each</span>
                          </div>
                        </div>
                        
                        <div class="bundle-card-content">
                          <div class="bundle-color-separator"></div>
                          <div class="bundle-color-row multi-selects">
                            <div class="bundle-select-column">
                              <span class="bundle-color-label">Pillow 1</span>
                              <div class="bundle-select-wrapper">
                                <div class="custom-dropdown" id="bundle-1-pillow-1-select" data-value="{{ product.variants.first.id }}">
                                  <div class="custom-dropdown-trigger">
                                    <span class="select-color-dot" style="background-color: {% assign first_v = product.variants.first.title | downcase %}{% if first_v contains 'navy' or first_v contains 'blue' %}#3b4857{% elsif first_v contains 'gray' or first_v contains 'grey' %}#9ca3af{% elsif first_v contains 'pink' %}#db2777{% elsif first_v contains 'black' %}#1f2937{% elsif first_v contains 'leopard' %}#c8a45a{% else %}#9ca3af{% endif %};"></span>
                                    <span class="custom-dropdown-text">{{ product.variants.first.title }}</span>
                                    <span class="custom-dropdown-chevron"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#2a2a2a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></span>
                                  </div>
                                  <div class="custom-dropdown-options">
                                    {%- for variant in product.variants -%}
                                      {%- assign swatch_color = '#9ca3af' -%}
                                      {%- assign v_title = variant.title | downcase -%}
                                      {%- if v_title contains 'navy' or v_title contains 'blue' -%}{%- assign swatch_color = '#3b4857' -%}
                                      {%- elsif v_title contains 'gray' or v_title contains 'grey' -%}{%- assign swatch_color = '#9ca3af' -%}
                                      {%- elsif v_title contains 'pink' -%}{%- assign swatch_color = '#db2777' -%}
                                      {%- elsif v_title contains 'black' -%}{%- assign swatch_color = '#1f2937' -%}
                                      {%- elsif v_title contains 'leopard' -%}{%- assign swatch_color = '#c8a45a' -%}
                                      {%- endif -%}
                                      <div class="custom-dropdown-option{% if forloop.first %} selected{% endif %}" data-value="{{ variant.id }}" data-color="{{ swatch_color }}">
                                        <span class="option-color-dot" style="background-color: {{ swatch_color }};"></span>
                                        <span class="option-label">{{ variant.title }}</span>
                                      </div>
                                    {%- endfor -%}
                                  </div>
                                </div>
                              </div>
                            </div>
                            
                            <div class="bundle-select-column">
                              <span class="bundle-color-label">Pillow 2{% if bogo_enabled %} <span style="color: #2e6f40; font-weight: 800; margin-left: 4px;">(FREE)</span>{% endif %}</span>
                              <div class="bundle-select-wrapper">
                                <div class="custom-dropdown" id="bundle-1-pillow-2-select" data-value="{{ product.variants.first.id }}">
                                  <div class="custom-dropdown-trigger">
                                    <span class="select-color-dot" style="background-color: {% assign first_v = product.variants.first.title | downcase %}{% if first_v contains 'navy' or first_v contains 'blue' %}#3b4857{% elsif first_v contains 'gray' or first_v contains 'grey' %}#9ca3af{% elsif first_v contains 'pink' %}#db2777{% elsif first_v contains 'black' %}#1f2937{% elsif first_v contains 'leopard' %}#c8a45a{% else %}#9ca3af{% endif %};"></span>
                                    <span class="custom-dropdown-text">{{ product.variants.first.title }}</span>
                                    <span class="custom-dropdown-chevron"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#2a2a2a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></span>
                                  </div>
                                  <div class="custom-dropdown-options">
                                    {%- for variant in product.variants -%}
                                      {%- assign swatch_color = '#9ca3af' -%}
                                      {%- assign v_title = variant.title | downcase -%}
                                      {%- if v_title contains 'navy' or v_title contains 'blue' -%}{%- assign swatch_color = '#3b4857' -%}
                                      {%- elsif v_title contains 'gray' or v_title contains 'grey' -%}{%- assign swatch_color = '#9ca3af' -%}
                                      {%- elsif v_title contains 'pink' -%}{%- assign swatch_color = '#db2777' -%}
                                      {%- elsif v_title contains 'black' -%}{%- assign swatch_color = '#1f2937' -%}
                                      {%- elsif v_title contains 'leopard' -%}{%- assign swatch_color = '#c8a45a' -%}
                                      {%- endif -%}
                                      <div class="custom-dropdown-option{% if forloop.first %} selected{% endif %}" data-value="{{ variant.id }}" data-color="{{ swatch_color }}">
                                        <span class="option-color-dot" style="background-color: {{ swatch_color }};"></span>
                                        <span class="option-label">{{ variant.title }}</span>
                                      </div>
                                    {%- endfor -%}
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>

                      <!-- Package 2 (Buy 2) -->
                      <div class="bundle-card-new{% if block.settings.bundle_2_tag != blank %} has-badge{% endif %}" id="bundle-card-2" data-discount-cents="{{ block_bundle_2_discount_cents }}">
                        {%- if block.settings.bundle_2_tag != blank -%}
                          <div class="bundle-tag-badge">{{ block.settings.bundle_2_tag | escape }}</div>
                        {%- endif -%}
                        
                        <div class="bundle-card-header-new">
                          <label class="bundle-radio-container-new">

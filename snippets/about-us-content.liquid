{{ 'avemos-style.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="Avemos-landing-wrapper">
  {% render 'avemos-header-markup', logo_height: 50 %}

{%- liquid
  assign title = section.settings.title | default: "About Us"
  assign story_title = section.settings.story_title | default: "Our Story & Mission"
  assign story_text_1 = section.settings.story_text_1 | default: "The Avemos® brand was born out of frustration from a group of frequent travelers and ergonomic specialists. We were tired of the standard U-shaped travel pillows on the market—whether they were inflatable ones that deflated midway, or cheap foam ones that offered zero support, causing the head to bob forward and leaving our necks stiff and painful after sleeping."
  assign story_text_2 = section.settings.story_text_2 | default: "After prototyping over 20 different designs on long-haul flights and consulting with orthopedic experts, we developed the Avemos Travel Pillow. Our mission is to make every journey comfortable and pain-free, helping travelers arrive at their destinations refreshed and fully energized."
  assign features_title = section.settings.features_title | default: "Premium Product Features"
  assign dtc_title = section.settings.dtc_title | default: "Our DTC Model & Location"
  assign dtc_text = section.settings.dtc_text | default: "We operate as a DTC (Direct-to-Consumer) brand, shipping globally straight from our design hub. Our primary office and fulfillment logistics center are located in Ukraine: Zelena St, 114, Lviv. We cut out traditional retail markups to bring you high-end travel gear at an honest price."
  assign responsible_title = section.settings.responsible_title | default: "Responsible Person & Contact"
  assign responsible_name = section.settings.responsible_name | default: "Yurii Lepkyi"
  assign responsible_role = section.settings.responsible_role | default: "Responsible Person & Business Owner"
  assign responsible_email = section.settings.responsible_email | default: "lepkyimanagm@gmail.com"
  assign responsible_desc = section.settings.responsible_desc | default: "As the lead director and business owner of the Avemos® brand, Yurii manages product operations, DTC logistics, and quality assurance. If you have any business inquiries or partnership suggestions, feel free to reach out directly."

  if section.settings.hero_image != blank
    assign hero_image_url = section.settings.hero_image | image_url: width: 800
  else
    assign hero_image_url = 'about-us-hero.jpg' | asset_url
  endif
-%}

  <div style="background-color: var(--bg-secondary); padding: 60px 0;">
    <div class="container" style="max-width: 800px;">
      <h1 style="font-size: 2.5rem; font-weight: 800; text-align: center; margin-bottom: 24px;">{{ title }}</h1>
      
      <div style="width: 100%; aspect-ratio: 16 / 9; border-radius: var(--radius-md); overflow: hidden; margin-bottom: 36px; border: 1px solid var(--border-color);">
        <img src="{{ hero_image_url }}" alt="Avemos Team" width="800" height="450" style="width: 100%; height: auto; object-fit: cover;">
      </div>

      <!-- Story and Mission -->
      <div style="font-size: 1.1rem; color: var(--text-secondary); display: flex; flex-direction: column; gap: 20px; line-height: 1.7;">
        <h2 style="font-size: 1.6rem; color: var(--text-primary); font-weight: 700; margin-top: 12px;">{{ story_title }}</h2>
        <p>
          {{ story_text_1 }}
        </p>
        <p>
          {{ story_text_2 }}
        </p>

        <h2 style="font-size: 1.6rem; color: var(--text-primary); font-weight: 700; margin-top: 12px;">{{ features_title }}</h2>
        <ul style="padding-left: 20px; display: flex; flex-direction: column; gap: 12px;">
          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'feature' -%}
                <li {{ block.shopify_attributes }}>
                  <strong>{{ block.settings.title }}:</strong> {{ block.settings.text }}
                </li>
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}
            <li>
              <strong>Orthopedic Memory Foam Core:</strong> The core of our pillow is made of high-density, temperature-sensitive memory foam. It reacts to body heat to perfectly mold to the contours of your neck and shoulders, absorbing travel vibrations.
            </li>
            <li>
              <strong>Ergonomic 360° Neck Support:</strong> Unlike traditional pillows, Avemos features an asymmetrical wrap-around contour and an adjustable strap. This keeps your chin and cheeks supported, preventing forward and lateral head bobbing.
            </li>
            <li>
              <strong>Ultra-Breathable cover:</strong> The removable cover is crafted from premium sweat-wicking hypoallergenic fabric. It stays cool in warm conditions and prevents dust or pet hair accumulation, and is fully machine washable.
            </li>
            <li>
              <strong>Smart Compression Design:</strong> The pillow easily compresses to 1/3 of its size to fit inside the included waterproof travel bag, taking up minimal space in your carry-on luggage.
            </li>
          {%- endif -%}
        </ul>

        <h2 style="font-size: 1.6rem; color: var(--text-primary); font-weight: 700; margin-top: 12px;">{{ dtc_title }}</h2>
        <p>
          {{ dtc_text }}
        </p>

        <h2 style="font-size: 1.6rem; color: var(--text-primary); font-weight: 700; margin-top: 12px;">{{ responsible_title }}</h2>
        <div style="background-color: var(--bg-primary); padding: 24px; border-radius: var(--radius-md); display: flex; align-items: center; gap: 20px; border: 1px solid var(--border-color); margin-top: 12px;">
          <div style="width: 80px; height: 80px; border-radius: 50%; background-color: var(--primary); display: flex; align-items: center; justify-content: center; color: white; font-size: 1.8rem; font-weight: 700; flex-shrink: 0;">
            <i class="fa-solid fa-user-tie"></i>
          </div>
          <div>
            <h3 style="font-size: 1.2rem; color: var(--text-primary); font-weight: 700; margin-bottom: 4px;">{{ responsible_name }}</h3>
            <p style="font-size: 0.95rem; color: var(--primary); font-weight: 600; margin-bottom: 8px;">{{ responsible_role }}</p>
            <p style="font-size: 0.95rem; color: var(--text-secondary); line-height: 1.5; margin-bottom: 8px;">
              Personal Email: <a href="mailto:{{ responsible_email }}" style="color: var(--primary); text-decoration: underline;">{{ responsible_email }}</a>
            </p>
            <p style="font-size: 0.95rem; color: var(--text-secondary); line-height: 1.5;">
              {{ responsible_desc }}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h4 style="font-weight: 800;"><i class="fa-solid fa-plane-departure"></i> Avemos</h4>
          <p>We create premium products for your comfort during travels all over the world.</p>
        </div>
        <div class="footer-col">
          <h4>Contact Us</h4>
          <ul class="footer-links">
            <li>Email: support@avemosstore.com</li>
            <li>Phone: +380965347984</li>
            <li>Address: Zelena St, 114, Lviv, Ukraine</li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Legal Information</h4>
          <ul class="footer-links">
            <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
            <li><a href="/policies/terms-of-service">Terms of Service</a></li>
            <li><a href="/policies/refund-policy">Refund Policy</a></li>
            <li><a href="/policies/shipping-policy">Shipping Policy</a></li>
            <li><a href="/policies/user-agreement">User Agreement</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 Avemos® Mock App. All rights reserved.</p>
        <div class="mock-payments">
          <span class="mock-payment-badge">Stripe</span>
          <span class="mock-payment-badge">PayPal</span>
          <span class="mock-payment-badge">Apple Pay</span>
          <span class="mock-payment-badge">Google Pay</span>
        </div>
      </div>
    </div>
  </footer>
</div>

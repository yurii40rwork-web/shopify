{{ 'avemos-style.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="Avemos-landing-wrapper">
  {% render 'avemos-header-markup', logo_height: 50 %}

{%- liquid
  assign title = section.settings.title | default: "Contact Us"
  assign subtitle = section.settings.subtitle | default: "Have questions about the Avemos pillow or your order? We'd love to help!"
  assign info_title = section.settings.info_title | default: "Contact Info"
  assign email_title = section.settings.email_title | default: "Email Support"
  assign email_address = section.settings.email_address | default: "support@avemosstore.com"
  assign email_helper = section.settings.email_helper | default: "We reply within 12-24 hours."
  assign phone_title = section.settings.phone_title | default: "Phone Line"
  assign phone_number = section.settings.phone_number | default: "+380965347984"
  assign phone_helper = section.settings.phone_helper | default: "Mon-Fri from 9:00 AM to 6:00 PM (GMT+2)."
  assign address_title = section.settings.address_title | default: "Office & Warehouse"
  assign address_text = section.settings.address_text | default: "Avemos,\nZelena St, 114,\nLviv, 79000, Ukraine"
  assign form_title = section.settings.form_title | default: "Send Us a Message"
-%}

  <div style="background-color: var(--bg-secondary); padding: 60px 0; min-height: 70vh;">
    <div class="container" style="max-width: 800px;">
      <h1 style="font-size: 2.5rem; font-weight: 800; text-align: center; margin-bottom: 12px;">{{ title }}</h1>
      <p style="text-align: center; color: var(--text-secondary); margin-bottom: 48px; font-size: 1.1rem;">
        {{ subtitle }}
      </p>

      <div style="display: grid; grid-template-columns: 1fr 1.2fr; gap: 40px; align-items: start;">
        
        <!-- Contact Info -->
        <div style="background-color: var(--bg-primary); padding: 32px; border-radius: var(--radius-md); border: 1px solid var(--border-color); display: flex; flex-direction: column; gap: 24px;">
          <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--text-primary); border-bottom: 2px solid var(--primary); padding-bottom: 8px; width: fit-content;">{{ info_title }}</h3>
          
          <!-- Email -->
          <div style="display: flex; gap: 14px; align-items: flex-start;">
            <i class="fa-solid fa-envelope" style="font-size: 1.3rem; color: var(--primary); margin-top: 3px;"></i>
            <div>
              <h4 style="font-weight: 700; font-size: 0.95rem; margin-bottom: 2px;">{{ email_title }}</h4>
              <p style="font-size: 0.9rem; color: var(--text-secondary);">{{ email_address }}</p>
              <p style="font-size: 0.8rem; color: var(--text-light); margin-top: 2px;">{{ email_helper }}</p>
            </div>
          </div>

          <!-- Phone -->
          <div style="display: flex; gap: 14px; align-items: flex-start;">
            <i class="fa-solid fa-phone" style="font-size: 1.3rem; color: var(--primary); margin-top: 3px;"></i>
            <div>
              <h4 style="font-weight: 700; font-size: 0.95rem; margin-bottom: 2px;">{{ phone_title }}</h4>
              <p style="font-size: 0.9rem; color: var(--text-secondary);">{{ phone_number }}</p>
              <p style="font-size: 0.8rem; color: var(--text-light); margin-top: 2px;">{{ phone_helper }}</p>
            </div>
          </div>

          <!-- Address -->
          <div style="display: flex; gap: 14px; align-items: flex-start;">
            <i class="fa-solid fa-location-dot" style="font-size: 1.3rem; color: var(--primary); margin-top: 3px;"></i>
            <div>
              <h4 style="font-weight: 700; font-size: 0.95rem; margin-bottom: 2px;">{{ address_title }}</h4>
              <p style="font-size: 0.9rem; color: var(--text-secondary); line-height: 1.4;">
                {{ address_text | newline_to_br }}
              </p>
            </div>
          </div>
        </div>

        <!-- Shopify Form Embed -->
        <div>
          <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--text-primary); margin-bottom: 24px;">{{ form_title }}</h3>
          
          {%- form 'contact', id: 'ContactForm', class: 'contact-form' -%}
            {%- if form.posted_successfully? -%}
              <div style="background-color: #dcfce7; color: #16a34a; padding: 16px; border-radius: var(--radius-sm); margin-bottom: 20px; font-weight: 600; font-size: 0.95rem;">
                Thank you! Your message has been sent successfully. We will get back to you shortly.
              </div>
            {%- elsif form.errors -%}
              <div style="background-color: #fee2e2; color: #dc2626; padding: 16px; border-radius: var(--radius-sm); margin-bottom: 20px; font-size: 0.95rem;">
                An error occurred. Please check the form details and try again.
              </div>
            {%- endif -%}

            <div style="display: flex; flex-direction: column; gap: 16px;">
              <div class="form-group">
                <label for="ContactForm-name" style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 6px;">Your Name</label>
                <input type="text" name="contact[Name]" id="ContactForm-name" class="form-input" placeholder="John Doe" required>
              </div>
              
              <div class="form-group">
                <label for="ContactForm-email" style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 6px;">Your Email</label>
                <input type="email" name="contact[email]" id="ContactForm-email" class="form-input" placeholder="john@email.com" required>
              </div>

              <div class="form-group">
                <label for="ContactForm-body" style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 6px;">Message</label>
                <textarea rows="5" name="contact[body]" id="ContactForm-body" class="form-input" placeholder="Describe your question in detail..." style="resize: vertical; font-family: var(--font-family);" required></textarea>
              </div>

              <button type="submit" class="submit-payment-btn" style="background-color: var(--primary); box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);">
                <i class="fa-solid fa-paper-plane"></i> Send Message
              </button>
            </div>
          {%- endform -%}
        </div>

      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h4 style="font-weight: 800;"><i class="fa-solid fa-plane-departure"></i> Avemos</h4>
          <p>We create premium products for your comfort during travels all over the world.</p>
        </div>
        <div class="footer-col">
          <h4>Contact Us</h4>
          <ul class="footer-links">
            <li>Email: support@avemosstore.com</li>
            <li>Phone: +380965347984</li>
            <li>Address: Zelena St, 114, Lviv, Ukraine</li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Legal Information</h4>
          <ul class="footer-links">
            <li><a href="/pages/privacy-policy">Privacy Policy</a></li>
            <li><a href="/pages/terms-of-service">Terms of Service</a></li>
            <li><a href="/pages/refund-policy">Refund Policy</a></li>
            <li><a href="/pages/shipping-policy">Shipping Policy</a></li>
            <li><a href="/pages/user-agreement">User Agreement</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 Avemos® All rights reserved.</p>
        <div class="mock-payments">
          <span class="mock-payment-badge">Stripe</span>
          <span class="mock-payment-badge">PayPal</span>
          <span class="mock-payment-badge">Apple Pay</span>
          <span class="mock-payment-badge">Google Pay</span>
        </div>
      </div>
    </div>
  </footer>
</div>

<nav class="sections-sidebar-nav" aria-label="Page Sections" id="sections-sidebar-nav">
  <div class="sections-sidebar-nav-container">
    <a href="#product" class="sections-nav-item" data-target="product">
      <span class="sections-nav-label">Overview</span>
      <span class="sections-nav-strip"></span>
    </a>
    <a href="#benefits" class="sections-nav-item" data-target="benefits">
      <span class="sections-nav-label">Benefits</span>
      <span class="sections-nav-strip"></span>
    </a>
    <a href="#comparison" class="sections-nav-item" data-target="comparison">
      <span class="sections-nav-label">Compare</span>
      <span class="sections-nav-strip"></span>
    </a>
    <a href="#how-it-works" class="sections-nav-item" data-target="how-it-works">
      <span class="sections-nav-label">How It Works</span>
      <span class="sections-nav-strip"></span>
    </a>
    <a href="#faq" class="sections-nav-item" data-target="faq">
      <span class="sections-nav-label">FAQ</span>
      <span class="sections-nav-strip"></span>
    </a>
    <a href="#reviews" class="sections-nav-item" data-target="reviews">
      <span class="sections-nav-label">Reviews</span>
      <span class="sections-nav-strip"></span>
    </a>
    <a href="#refund" class="sections-nav-item" data-target="refund">
      <span class="sections-nav-label">Guarantee</span>
      <span class="sections-nav-strip"></span>
    </a>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sidebarNav = document.getElementById('sections-sidebar-nav');
    if (!sidebarNav) return;

    const navItems = sidebarNav.querySelectorAll('.sections-nav-item');
    const validSections = [];
    
    // Check which sections actually exist in the DOM, hide the rest of the navigation links
    navItems.forEach(item => {
      const targetId = item.getAttribute('href');
      const targetEl = document.querySelector(targetId);
      if (targetEl) {
        validSections.push(targetEl);
      } else {
        item.style.display = 'none';
      }
    });

    // If there are at least two visible sections, show the sidebar navigation
    if (validSections.length >= 2) {
      sidebarNav.classList.add('visible');
      
      // Dynamic scrollspy tracker using IntersectionObserver
      const observerOptions = {
        root: null,
        rootMargin: '-30% 0px -50% 0px', // Trigger active state when section is in middle viewport area
        threshold: 0
      };
      
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const activeId = entry.target.getAttribute('id');
            navItems.forEach(item => {
              const itemHref = item.getAttribute('href');
              if (itemHref === `#${activeId}`) {
                item.classList.add('active');
              } else {
                item.classList.remove('active');
              }
            });
          }
        });
      }, observerOptions);
      
      validSections.forEach(section => observer.observe(section));
      
      // Smooth scroll on click
      navItems.forEach(item => {
        item.addEventListener('click', (e) => {
          e.preventDefault();
          const targetId = item.getAttribute('href');
          const targetEl = document.querySelector(targetId);
          if (targetEl) {
            targetEl.scrollIntoView({
              behavior: 'smooth',
              block: 'start'
            });
          }
        });
      });
    }
  });
</script>

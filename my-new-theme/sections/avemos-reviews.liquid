{{ 'avemos-style.css' | asset_url | stylesheet_tag }}

<div class="Avemos-landing-wrapper" id="reviews">
  <!-- Reviews Section -->
  <section style="background-color: var(--bg-secondary); border-top: 1px solid var(--border-color); padding: 80px 0;">
    <div class="container">
      <h2 class="section-title">What Our Customers Say</h2>
      <p class="section-subtitle">Real reviews from verified buyers</p>
      
      <!-- Rating Overview Block -->
      <div class="reviews-overview" style="display: flex; flex-wrap: wrap; gap: 40px; margin-bottom: 50px; background-color: var(--bg-primary); padding: 30px; border-radius: var(--radius-lg); border: 1px solid var(--border-light); align-items: center; justify-content: center;">
        <div class="rating-summary" style="text-align: center; flex: 1 1 250px;">
          <div style="font-size: 3rem; font-weight: 700; color: var(--text-primary); line-height: 1;">4.9</div>
          <div class="rating-stars" style="color: #facc15; font-size: 1.5rem; margin: 10px 0;">
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
          </div>
          <div style="color: var(--text-light); font-size: 0.95rem;">Based on 1,248 reviews</div>
        </div>
        
        <div class="rating-bars" style="flex: 2 1 400px; display: flex; flex-direction: column; gap: 8px; width: 100%;">
          <div class="rating-bar-row" style="display: flex; align-items: center; gap: 12px;">
            <span style="font-size: 0.9rem; min-width: 50px; text-align: right; color: var(--text-secondary);">5 stars</span>
            <div class="progress-bar-bg" style="flex-grow: 1; height: 8px; background-color: var(--surface-container); border-radius: var(--radius-full); overflow: hidden;">
              <div class="progress-bar-fill" style="width: 92%; height: 100%; background-color: #facc15; border-radius: var(--radius-full);"></div>
            </div>
            <span style="font-size: 0.9rem; min-width: 40px; color: var(--text-light);">92%</span>
          </div>
          <div class="rating-bar-row" style="display: flex; align-items: center; gap: 12px;">
            <span style="font-size: 0.9rem; min-width: 50px; text-align: right; color: var(--text-secondary);">4 stars</span>
            <div class="progress-bar-bg" style="flex-grow: 1; height: 8px; background-color: var(--surface-container); border-radius: var(--radius-full); overflow: hidden;">
              <div class="progress-bar-fill" style="width: 6%; height: 100%; background-color: #facc15; border-radius: var(--radius-full);"></div>
            </div>
            <span style="font-size: 0.9rem; min-width: 40px; color: var(--text-light);">6%</span>
          </div>
          <div class="rating-bar-row" style="display: flex; align-items: center; gap: 12px;">
            <span style="font-size: 0.9rem; min-width: 50px; text-align: right; color: var(--text-secondary);">3 stars</span>
            <div class="progress-bar-bg" style="flex-grow: 1; height: 8px; background-color: var(--surface-container); border-radius: var(--radius-full); overflow: hidden;">
              <div class="progress-bar-fill" style="width: 1%; height: 100%; background-color: #facc15; border-radius: var(--radius-full);"></div>
            </div>
            <span style="font-size: 0.9rem; min-width: 40px; color: var(--text-light);">1%</span>
          </div>
          <div class="rating-bar-row" style="display: flex; align-items: center; gap: 12px;">
            <span style="font-size: 0.9rem; min-width: 50px; text-align: right; color: var(--text-secondary);">2 stars</span>
            <div class="progress-bar-bg" style="flex-grow: 1; height: 8px; background-color: var(--surface-container); border-radius: var(--radius-full); overflow: hidden;">
              <div class="progress-bar-fill" style="width: 0.5%; height: 100%; background-color: #facc15; border-radius: var(--radius-full);"></div>
            </div>
            <span style="font-size: 0.9rem; min-width: 40px; color: var(--text-light);"><1%</span>
          </div>
          <div class="rating-bar-row" style="display: flex; align-items: center; gap: 12px;">
            <span style="font-size: 0.9rem; min-width: 50px; text-align: right; color: var(--text-secondary);">1 star</span>
            <div class="progress-bar-bg" style="flex-grow: 1; height: 8px; background-color: var(--surface-container); border-radius: var(--radius-full); overflow: hidden;">
              <div class="progress-bar-fill" style="width: 0.5%; height: 100%; background-color: #facc15; border-radius: var(--radius-full);"></div>
            </div>
            <span style="font-size: 0.9rem; min-width: 40px; color: var(--text-light);"><1%</span>
          </div>
        </div>
      </div>
      
      <!-- Review Cards Grid -->
      <div class="reviews-grid">
        <!-- Review 1 -->
        <div class="review-card">
          <div class="review-card-inner">
            <div class="review-header">
              <div class="reviewer-info">
                <div class="reviewer-avatar">JD</div>
                <div>
                  <div class="reviewer-name">John D.</div>
                  <div class="verified-badge">
                    <i class="fa-solid fa-circle-check"></i> Verified Buyer
                  </div>
                </div>
              </div>
              <span class="review-date">2 days ago</span>
            </div>
            
            <div class="stars">
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
            </div>
            
            <h4 class="review-title">The ultimate travel companion!</h4>
            <p class="review-text">
              I've used many travel pillows before, but this one is on another level. The memory foam is incredibly supportive and the adjustable strap lets me lock in the perfect fit. Slept like a baby on my 10-hour flight!
            </p>
          </div>
        </div>

        <!-- Review 2 -->
        <div class="review-card">
          <div class="review-card-inner">
            <div class="review-header">
              <div class="reviewer-info">
                <div class="reviewer-avatar">SM</div>
                <div>
                  <div class="reviewer-name">Sarah M.</div>
                  <div class="verified-badge">
                    <i class="fa-solid fa-circle-check"></i> Verified Buyer
                  </div>
                </div>
              </div>
              <span class="review-date">1 week ago</span>
            </div>
            
            <div class="stars">
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
            </div>
            
            <h4 class="review-title">Super compact & easy to wash</h4>
            <p class="review-text">
              I love that it rolls up into a tiny carrying bag so I can easily clip it to my backpack. The removable cover was super easy to zip off and wash after my trip. Definitely worth every penny!
            </p>
          </div>
        </div>

        <!-- Review 3 -->
        <div class="review-card">
          <div class="review-card-inner">
            <div class="review-header">
              <div class="reviewer-info">
                <div class="reviewer-avatar">TH</div>
                <div>
                  <div class="reviewer-name">Thomas H.</div>
                  <div class="verified-badge">
                    <i class="fa-solid fa-circle-check"></i> Verified Buyer
                  </div>
                </div>
              </div>
              <span class="review-date">2 weeks ago</span>
            </div>
            
            <div class="stars">
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
            </div>
            
            <h4 class="review-title">No more neck pain!</h4>
            <p class="review-text">
              I always end up with a stiff neck when sleeping in cars or planes. I tried the Avemos pillow on a road trip last weekend and for the first time, woke up without any pain. The ergonomic support is real.
            </p>
          </div>
        </div>

        <!-- Review 4 -->
        <div class="review-card">
          <div class="review-card-inner">
            <div class="review-header">
              <div class="reviewer-info">
                <div class="reviewer-avatar">EL</div>
                <div>
                  <div class="reviewer-name">Emily L.</div>
                  <div class="verified-badge">
                    <i class="fa-solid fa-circle-check"></i> Verified Buyer
                  </div>
                </div>
              </div>
              <span class="review-date">3 weeks ago</span>
            </div>
            
            <div class="stars">
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
            </div>
            
            <h4 class="review-title">Amazing quality & soft touch</h4>
            <p class="review-text">
              The fabric feels extremely soft against the skin, unlike cheap inflatable pillows. It doesn't get hot at all, which was my main concern. Excellent design and superb quality.
            </p>
          </div>
        </div>

        <!-- Review 5 -->
        <div class="review-card">
          <div class="review-card-inner">
            <div class="review-header">
              <div class="reviewer-info">
                <div class="reviewer-avatar">AB</div>
                <div>
                  <div class="reviewer-name">Alex B.</div>
                  <div class="verified-badge">
                    <i class="fa-solid fa-circle-check"></i> Verified Buyer
                  </div>
                </div>
              </div>
              <span class="review-date">1 month ago</span>
            </div>
            
            <div class="stars">
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
            </div>
            
            <h4 class="review-title">Highly recommend!</h4>
            <p class="review-text">
              My wife and I both got one for our trip to Europe and we couldn't be happier. We used them on flights, trains, and even in hotels with flat pillows. Customer service was also very responsive.
            </p>
          </div>
        </div>

        <!-- Review 6 -->
        <div class="review-card">
          <div class="review-card-inner">
            <div class="review-header">
              <div class="reviewer-info">
                <div class="reviewer-avatar">NK</div>
                <div>
                  <div class="reviewer-name">Natalie K.</div>
                  <div class="verified-badge">
                    <i class="fa-solid fa-circle-check"></i> Verified Buyer
                  </div>
                </div>
              </div>
              <span class="review-date">1 month ago</span>
            </div>
            
            <div class="stars">
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
            </div>
            
            <h4 class="review-title">Life changer for road trips</h4>
            <p class="review-text">
              As someone who travels by bus frequently, this pillow has completely transformed my travel experience. No more bobbing head or waking up with aches. The strap keeps it securely in place.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  
  .review-card {
    background-color: var(--bg-primary);
    border-radius: var(--radius-lg);
    padding: 24px;
    border: 1px solid var(--border-light);
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  }
  
  .review-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--card-shadow-hover);
  }
  
  .review-card-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  
  .review-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }
  
  .reviewer-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  
  .reviewer-avatar {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    background-color: var(--secondary-container);
    color: var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 0.9rem;
  }
  
  .reviewer-name {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.95rem;
  }
  
  .verified-badge {
    display: flex;
    align-items: center;
    gap: 4px;
    color: #10b981;
    font-size: 0.75rem;
    font-weight: 500;
  }
  
  .review-date {
    font-size: 0.8rem;
    color: var(--text-light);
  }
  
  .review-card .stars {
    color: #facc15;
    font-size: 0.9rem;
    margin-bottom: 12px;
  }
  
  .review-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 8px;
  }
  
  .review-text {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  @media (max-width: 1024px) {
    .reviews-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 768px) {
    .reviews-grid {
      grid-template-columns: 1fr;
    }
    .reviews-overview {
      flex-direction: column;
      text-align: center;
      gap: 20px !important;
    }
    .rating-bars {
      flex: 1 1 auto !important;
    }
  }
</style>

{% schema %}
{
  "name": "Avemos Reviews",
  "settings": [],
  "presets": [
    {
      "name": "Avemos Reviews"
    }
  ]
}
{% endschema %}

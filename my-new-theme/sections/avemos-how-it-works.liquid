{{ 'avemos-style.css' | asset_url | stylesheet_tag }}

<div class="Avemos-landing-wrapper">
  <!-- How It Works Section -->
  <section class="container" style="margin-top: 40px; margin-bottom: 40px;">
    <h2 class="section-title">How It Works</h2>
    <p class="section-subtitle">Just 3 simple steps to perfect sleep</p>
    
    <div class="steps-container">
      <div class="step-card">
        <div class="step-image-placeholder" style="padding: 0; background: white;">
          <img src="{{ 'how-it-works-1.png' | asset_url }}" alt="Step 1" style="width: 100%; height: 100%; object-fit: cover;">
        </div>
        <div class="step-content">
          <span class="step-number">1</span>
          <h3>Place on Your Neck</h3>
          <p>Wrap the pillow around your neck so the elevated cushioned sides support your chin and cheeks.</p>
        </div>
      </div>

      <div class="step-card">
        <div class="step-image-placeholder" style="padding: 0; background: white;">
          <img src="{{ 'how-it-works-2.png' | asset_url }}" alt="Step 2" style="width: 100%; height: 100%; object-fit: cover;">
        </div>
        <div class="step-content">
          <span class="step-number">2</span>
          <h3>Adjust the Strap</h3>
          <p>Tighten the adjustable strap to your desired level of support and head stabilization.</p>
        </div>
      </div>

      <div class="step-card">
        <div class="step-image-placeholder" style="padding: 0; background: white;">
          <img src="{{ 'how-it-works-3.png' | asset_url }}" alt="Step 3" style="width: 100%; height: 100%; object-fit: cover;">
        </div>
        <div class="step-content">
          <span class="step-number">3</span>
          <h3>Enjoy Deep Sleep</h3>
          <p>Relax and sleep. The pillow holds your head in a natural, upright position throughout the journey.</p>
        </div>
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Avemos How It Works",
  "settings": [],
  "presets": [
    {
      "name": "Avemos How It Works"
    }
  ]
}
{% endschema %}

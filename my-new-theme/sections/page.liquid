{% comment %}
  This section is used in the page template to render store pages like About us
  or Contact us.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/page
{% endcomment %}

{{ 'avemos-style.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

{% if request.path == '/pages/about-us' %}
  {% render 'about-us-content' %}
{% elsif request.path == '/pages/contact-us' %}
  {% render 'contact-us-content' %}
{% elsif request.path == '/pages/shipping-policy' %}
  {% render 'shipping-policy-content' %}
{% elsif request.path == '/pages/refund-policy' %}
  {% render 'refund-policy-content' %}
{% elsif request.path == '/pages/user-agreement' %}
  {% render 'user-agreement-content' %}
{% elsif request.path == '/pages/terms-of-service' %}
  {% render 'terms-of-service-content' %}
{% else %}
  <div class="avemos-landing-wrapper">
    <!-- Announcement Bar -->
    <div class="announcement-bar">
      <span>🔥 SPECIAL DEAL: 50% OFF TODAY ONLY!</span>
      <span class="highlight">Free Express Shipping on orders over $50</span>
    </div>

    <!-- Header -->
    <header class="header">
      <div class="container">
        <a href="/" class="logo">
          <img src="{{ 'logo-color.png' | asset_url }}" alt="Avemos Logo" width="120" height="36" style="height: 36px; width: auto; vertical-align: middle;">
        </a>
        
        <!-- Navigation Menu -->
        <nav class="header-nav">
          <a href="/" class="header-nav-link">Home</a>
          <a href="/pages/about-us" class="header-nav-link">About Us</a>
          <a href="/pages/contact-us" class="header-nav-link">Contact Us</a>
        </nav>
      </div>
    </header>

    <div style="background-color: var(--bg-secondary); padding: 60px 0; min-height: 50vh;">
      <div class="container" style="max-width: 800px;">
        <h1 style="font-size: 2.5rem; font-weight: 800; text-align: center; margin-bottom: 36px;">{{ page.title }}</h1>
        <div class="styled-page-content">
          {{ page.content }}
        </div>
      </div>
    </div>

    <!-- Footer -->
    <footer class="footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-col">
            <h4 style="font-weight: 800;"><i class="fa-solid fa-plane-departure"></i> Avemos</h4>
            <p>We create premium products for your comfort during travels all over the world.</p>
          </div>
          <div class="footer-col">
            <h4>Contact Us</h4>
            <ul class="footer-links">
              <li>Email: support@avemosstore.com</li>
              <li>Phone: +380965347984</li>
              <li>Address: Zelena St, 114, Lviv, Ukraine</li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Legal Information</h4>
            <ul class="footer-links">
              <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
              <li><a href="/policies/terms-of-service">Terms of Service</a></li>
              <li><a href="/policies/refund-policy">Refund Policy</a></li>
              <li><a href="/policies/shipping-policy">Shipping Policy</a></li>
              <li><a href="/policies/user-agreement">User Agreement</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; 2026 Avemos® Mock App. All rights reserved.</p>
          <div class="mock-payments">
            <span class="mock-payment-badge">Stripe</span>
            <span class="mock-payment-badge">PayPal</span>
            <span class="mock-payment-badge">Apple Pay</span>
            <span class="mock-payment-badge">Google Pay</span>
          </div>
        </div>
      </div>
    </footer>
  </div>
{% endif %}

{% schema %}
{
  "name": "t:general.page",
  "settings": []
}
{% endschema %}

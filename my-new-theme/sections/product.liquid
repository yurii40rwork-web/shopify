</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Quantity adjustments
    const qtyMinusBtn = document.getElementById('qty-minus-btn');
    const qtyPlusBtn = document.getElementById('qty-plus-btn');
    const qtyInputVal = document.getElementById('qty-input-val');
    
    if (qtyMinusBtn && qtyPlusBtn && qtyInputVal) {
      qtyMinusBtn.addEventListener('click', (e) => {
        e.preventDefault();
        let currentQty = parseInt(qtyInputVal.value) || 1;
        if (currentQty > 1) {
          qtyInputVal.value = currentQty - 1;
        }
      });
      
      qtyPlusBtn.addEventListener('click', (e) => {
        e.preventDefault();
        let currentQty = parseInt(qtyInputVal.value) || 1;
        qtyInputVal.value = currentQty + 1;
      });
    }

    // Bundle Radio click selection handler
    const bundleCards = document.querySelectorAll('.bundle-card');
    const variantIdInput = document.getElementById('main-product-variant-id');
    const priceDisplay = document.getElementById('main-product-price');

    bundleCards.forEach(card => {
      card.addEventListener('click', (e) => {
        // Prevent click trigger loop if clicking selectors or radios directly
        if (e.target.closest('.bundle-color-dropdown') || e.target.tagName === 'OPTION') {
          return;
        }

        const radio = card.querySelector('input[type="radio"]');
        if (radio) {
          radio.checked = true;
        }

        // Toggle active status UI
        bundleCards.forEach(c => {
          c.classList.remove('active');
          const content = c.querySelector('.bundle-card-content');
          if (content) content.style.display = 'none';
        });

        card.classList.add('active');
        const content = card.querySelector('.bundle-card-content');
        if (content) content.style.display = 'block';

        updatePriceAndVariant();
      });
    });

    // Color dropdowns change handler
    const colorDropdowns = document.querySelectorAll('.bundle-color-dropdown');
    
    colorDropdowns.forEach(dropdown => {
      // Initialize dot colors
      updateDotColor(dropdown);

      dropdown.addEventListener('change', () => {
        updateDotColor(dropdown);
        updatePriceAndVariant();
      });
    });

    function updateDotColor(dropdown) {
      const selectedOpt = dropdown.options[dropdown.selectedIndex];
      const colorHex = selectedOpt.getAttribute('data-color-hex') || '#9ca3af';
      const wrapper = dropdown.closest('.bundle-select-wrapper');
      if (wrapper) {
        const dot = wrapper.querySelector('.select-color-dot');
        if (dot) dot.style.backgroundColor = colorHex;
      }
    }

    function updatePriceAndVariant() {
      const activeOption = document.querySelector('input[name="bundle_option"]:checked').value;
      if (activeOption === 'buy_1') {
        const select1 = document.getElementById('bundle-1-variant-select');
        if (select1 && variantIdInput) {
          variantIdInput.value = select1.value;
        }
      } else {
        // Buy 2 uses Pillow 1's variant ID for standard fallback, but cart additions use custom AJAX
        const select2_1 = document.getElementById('bundle-2-pillow-1-select');
        if (select2_1 && variantIdInput) {
          variantIdInput.value = select2_1.value;
        }
      }
    }

    // Intercept form submit for AJAX Multi-Add
    const addToCartForm = document.getElementById('bundle-add-to-cart-form');
    if (addToCartForm) {
      addToCartForm.addEventListener('submit', (e) => {
        e.preventDefault();
        
        const activeOption = document.querySelector('input[name="bundle_option"]:checked').value;
        const qtyMultiplier = parseInt(qtyInputVal.value) || 1;
        
        let items = [];
        
        if (activeOption === 'buy_1') {
          const varId = document.getElementById('bundle-1-variant-select').value;
          items.push({ id: parseInt(varId), quantity: 1 * qtyMultiplier });
        } else {
          const varId1 = document.getElementById('bundle-2-pillow-1-select').value;
          const varId2 = document.getElementById('bundle-2-pillow-2-select').value;
          
          if (varId1 === varId2) {
            items.push({ id: parseInt(varId1), quantity: 2 * qtyMultiplier });
          } else {
            items.push({ id: parseInt(varId1), quantity: 1 * qtyMultiplier });
            items.push({ id: parseInt(varId2), quantity: 1 * qtyMultiplier });
          }
        }

        // Show loading state on buy button
        const buyBtn = addToCartForm.querySelector('.premium-buy-btn');
        const originalText = buyBtn.innerHTML;
        buyBtn.disabled = true;
        buyBtn.innerHTML = '<span class="material-symbols-outlined">sync</span> Loading...';

        // Clear cart first, then add selected items, then redirect to checkout
        fetch('/cart/clear.js', {
          method: 'POST'
        }).then(() => {
          return fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: items })
          });
        }).then(res => res.json())
          .then(data => {
            // Apply a discount code if configured in your Shopify admin (e.g. automatic bundle discount)
            // Redirect straight to checkout
            window.location.href = '/checkout';
          }).catch(err => {
            console.error('Error adding items to cart:', err);
            buyBtn.disabled = false;
            buyBtn.innerHTML = originalText;
          });
      });
    }

    // Gallery switcher
    const slides = document.querySelectorAll('.gallery-slide-img');
    const thumbnails = document.querySelectorAll('.thumb-card');
    const prevArrow = document.querySelector('.prev-arrow');
    const nextArrow = document.querySelector('.next-arrow');
    
    let currentSlide = 0;
    const totalSlides = slides.length;
    
    function goToSlide(index) {
      if (index < 0) {
        currentSlide = totalSlides - 1;
      } else if (index >= totalSlides) {
        currentSlide = 0;
      } else {
        currentSlide = index;
      }
      
      slides.forEach((slide, i) => {
        if (i === currentSlide) {
          slide.classList.add('active');
        } else {
          slide.classList.remove('active');
        }
      });
      
      thumbnails.forEach((t, i) => {
        if (i === currentSlide) {
          t.classList.add('active');
        } else {
          t.classList.remove('active');
        }
      });
    }
    
    if (prevArrow && nextArrow) {
      prevArrow.addEventListener('click', (e) => {
        e.preventDefault();
        goToSlide(currentSlide - 1);
      });
      
      nextArrow.addEventListener('click', (e) => {
        e.preventDefault();
        goToSlide(currentSlide + 1);
      });
    }
    
    thumbnails.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const index = parseInt(thumb.getAttribute('data-index')) || 0;
        goToSlide(index);
      });
    });
  });
</script>


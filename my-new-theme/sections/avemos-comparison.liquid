{{ 'avemos-style.css' | asset_url | stylesheet_tag }}

<div class="Avemos-landing-wrapper">
  <!-- Comparison Section -->
  <section style="background-color: #f1f5f9; padding: 40px 0;">
    <div class="container">
      <h2 class="section-title">Comparison with Traditional Pillows</h2>
      <p class="section-subtitle">Why traditional U-shaped travel pillows are no longer sufficient</p>
      
      <div class="comparison-wrapper">
        <table class="comparison-table">
          <thead>
            <tr>
              <th>Features</th>
              <th class="our-product">Avemos® Pillow</th>
              <th>Traditional U-Shape Pillows</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Head Stabilization</td>
              <td class="our-product"><span class="check-icon">✓</span> 360° support (no head drop)</td>
              <td class="other-product"><span class="cross-icon">✗</span> Sides only (head falls forward)</td>
            </tr>
            <tr>
              <td>Filling</td>
              <td class="our-product"><span class="check-icon">✓</span> Premium orthopedic memory foam</td>
              <td class="other-product"><span class="cross-icon">✗</span> Air or cheap low-density foam</td>
            </tr>
            <tr>
              <td>Hygiene</td>
              <td class="our-product"><span class="check-icon">✓</span> Machine-washable cover</td>
              <td class="other-product"><span class="cross-icon">✗</span> Non-removable, hard to clean</td>
            </tr>
            <tr>
              <td>Size Adjustment</td>
              <td class="our-product"><span class="check-icon">✓</span> Adjustable Velcro strap</td>
              <td class="other-product"><span class="cross-icon">✗</span> One size fits all (no adjustment)</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Avemos Comparison",
  "settings": [],
  "presets": [
    {
      "name": "Avemos Comparison"
    }
  ]
}
{% endschema %}

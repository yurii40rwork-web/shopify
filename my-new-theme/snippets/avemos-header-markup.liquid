{%- assign logo_height = logo_height | default: 50 -%}

<!-- Announcement Bar -->
<div class="announcement-bar">
  <span>🔥 SPECIAL DEAL: 50% OFF TODAY ONLY!</span>
  <span class="highlight">Free Express Shipping on orders over $50</span>
</div>

<!-- Header -->
<header class="header">
  <div class="container header-container">
    <!-- Hamburger Menu Button -->
    <button type="button" class="mobile-menu-btn" id="openDrawerBtn" aria-label="Open Menu">
      <i class="fa-solid fa-bars"></i>
    </button>

    <!-- Logo -->
    <a href="/" class="logo">
      <img src="{{ 'logo-color.png' | asset_url }}" alt="Avemos Logo" height="{{ logo_height }}" style="height: {{ logo_height }}px; width: auto; vertical-align: middle;">
    </a>
    
    <!-- Navigation Menu (Desktop only) -->
    <nav class="header-nav">
      <a href="/" class="header-nav-link">Home</a>
      <a href="/#reviews" class="header-nav-link">Reviews</a>
      <a href="/pages/about-us" class="header-nav-link">About Us</a>
      <a href="/pages/contact-us" class="header-nav-link">Contact Us</a>
      <a href="/apps/track123" class="header-nav-link">Track Order</a>
    </nav>

    <!-- Cart Button -->
    <a href="/cart" class="cart-icon-btn" aria-label="Open Cart">
      <i class="fa-solid fa-bag-shopping"></i>
      <span class="cart-badge" id="cart-count">{{ cart.item_count }}</span>
    </a>
  </div>
</header>

<!-- Mobile Navigation Drawer Overlay -->
<div class="mobile-nav-drawer" id="mobileNavDrawer">
  <!-- Announcement Bar inside Drawer -->
  <div class="announcement-bar">
    <span>🌸 Memorial Day Sale | 50% Off</span>
  </div>
  
  <div class="drawer-header">
    <!-- Close Button -->
    <button type="button" class="mobile-menu-close-btn" id="closeDrawerBtn" aria-label="Close Menu">
      <i class="fa-solid fa-xmark"></i>
    </button>
    
    <!-- Logo in Drawer -->
    <a href="/" class="logo drawer-logo">
      <img src="{{ 'logo-color.png' | asset_url }}" alt="Avemos Logo" height="{{ logo_height }}" style="height: {{ logo_height }}px; width: auto; vertical-align: middle;">
    </a>
    
    <!-- Cart in Drawer -->
    <a href="/cart" class="cart-icon-btn drawer-cart" aria-label="Open Cart">
      <i class="fa-solid fa-bag-shopping"></i>
      <span class="cart-badge" id="drawer-cart-count">{{ cart.item_count }}</span>
    </a>
  </div>
  
  <!-- Drawer Links -->
  <nav class="drawer-nav">
    <a href="/" class="drawer-nav-link">Home</a>
    <a href="/#reviews" class="drawer-nav-link">Reviews</a>
    <a href="/pages/about-us" class="drawer-nav-link">About Us</a>
    <a href="/pages/contact-us" class="drawer-nav-link">Contact Us</a>
    <a href="/apps/track123" class="drawer-nav-link">Track Order</a>
  </nav>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const openBtn = document.getElementById('openDrawerBtn');
    const closeBtn = document.getElementById('closeDrawerBtn');
    const drawer = document.getElementById('mobileNavDrawer');
    
    if (openBtn && closeBtn && drawer) {
      openBtn.addEventListener('click', (e) => {
        e.preventDefault();
        drawer.classList.add('active');
        document.body.style.overflow = 'hidden';
      });
      
      closeBtn.addEventListener('click', (e) => {
        e.preventDefault();
        drawer.classList.remove('active');
        document.body.style.overflow = '';
      });
      
      // Close drawer when clicking a link
      const drawerLinks = drawer.querySelectorAll('.drawer-nav-link');
      drawerLinks.forEach(link => {
        link.addEventListener('click', () => {
          drawer.classList.remove('active');
          document.body.style.overflow = '';
        });
      });
    }
  });
</script>
